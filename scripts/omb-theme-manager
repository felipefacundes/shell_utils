    "zitron"
    "powerline"
    "vscode"
    "candy"
    "font"
    "pete"
    "morris"
    "zitron"
    "roderik"
    "rainbowbrite"
    "binaryanomaly"
    "mbriggs"
    "tonotdo"
    "hawaii50"
    "powerline-naked"
    "powerline-icon"
