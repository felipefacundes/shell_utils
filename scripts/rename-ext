#!/usr/bin/env bash
# License: GPLv3
# Credits: Felipe Facundes

# Color definitions
BOLD_WHITE='\033[1;37m'
BOLD_YELLOW='\033[1;33m'
BOLD_RED='\033[1;31m'
GREEN='\033[0;32m'
BOLD_GREEN='\033[1;32m'
CYAN='\033[0;36m'
BOLD_CYAN='\033[1;36m'
MAGENTA='\033[0;35m'
BOLD_MAGENTA='\033[1;35m'
RED='\033[0;31m'
YELLOW='\033[0;33m'
RESET='\033[0m'

# Function to display help
show_help() {
    cat << EOF | { echo -e "$(cat)"; }
${BOLD_CYAN}Rename Extensions - Batch File Extension Renamer${RESET}

${BOLD_WHITE}USAGE:${RESET}
    ${BOLD_GREEN}$(basename "$0")${RESET} [OPTIONS] [DIRECTORY]

${BOLD_WHITE}DESCRIPTION:${RESET}
    Renames file extensions in a specified directory. The script searches for
    files with a given extension and changes them to a new extension. This is
    a rename operation only, not a file conversion.

    ${BOLD_YELLOW}Important:${RESET} The search is ${BOLD_WHITE}case-insensitive${RESET}, meaning that files with
    extensions like .PNG, .Png, .pNG, etc. will all be found when searching
    for "png". However, the original filename casing is preserved.

${BOLD_WHITE}OPTIONS:${RESET}
    ${BOLD_GREEN}-h, --here${RESET}          Use the current directory instead of providing one
    ${BOLD_GREEN}-i, --input${RESET} EXT     Specify the input extension to search for
    ${BOLD_GREEN}-o, --output${RESET} EXT    Specify the output extension to rename to
    ${BOLD_GREEN}--help${RESET}              Display this help message and exit

${BOLD_WHITE}ARGUMENTS:${RESET}
    ${BOLD_GREEN}DIRECTORY${RESET}           Directory containing the files to rename
                        ${BOLD_YELLOW}Required unless -h/--here is used${RESET}

${BOLD_WHITE}INTERACTIVE MODE:${RESET}
    If -i or -o options are not provided, the script will prompt for the
    missing information interactively. If only one of -i or -o is provided,
    the script will smartly ask only for the missing extension.

${BOLD_WHITE}EXTENSION FORMAT:${RESET}
    Extensions can be provided with or without the leading dot:
        png     (same as .png)
        .avif   (same as avif)

    Valid characters: alphanumeric (a-z, A-Z, 0-9), dot (.), underscore (_), hyphen (-)
    Invalid characters: spaces, !@#\$%^&*() and other special characters

${BOLD_WHITE}RENAME TOOL:${RESET}
    Uses ${BOLD_GREEN}advmv${RESET} if available (preserves extended attributes), 
    otherwise falls back to ${BOLD_GREEN}mv${RESET}.

${BOLD_WHITE}EXAMPLES:${RESET}
    ${CYAN}# Interactive mode in specific directory${RESET}
    \$ $(basename "$0") /path/to/images

    ${CYAN}# Interactive mode in current directory${RESET}
    \$ $(basename "$0") --here
    \$ $(basename "$0") -h

    ${CYAN}# Specify extensions via arguments${RESET}
    \$ $(basename "$0") -i png -o avif /path/to/images
    \$ $(basename "$0") --input .jpg --output .webp -h

    ${CYAN}# Mixed mode (provide one extension, prompt for the other)${RESET}
    \$ $(basename "$0") -i png /path/to/images
    \$ $(basename "$0") -o avif -h

${BOLD_WHITE}AUTHOR:${RESET}
    Created for batch file extension renaming operations.
    Part of the shell-script utilities collection.

${BOLD_WHITE}VERSION:${RESET}
    1.0.0
EOF
    exit 0
}

# Function to validate extension string
# Returns 0 if valid, 1 if invalid
validate_extension() {
    local ext="$1"
    # Remove leading dot if present for validation
    ext="${ext#.}"
    
    # Check if extension contains any special characters (except . _ -)
    if [[ "$ext" =~ [^a-zA-Z0-9._-] ]]; then
        return 1
    fi
    
    # Check if extension is empty
    if [[ -z "$ext" ]]; then
        return 1
    fi
    
    return 0
}

# Function to normalize extension (add dot if missing)
normalize_extension() {
    local ext="$1"
    # If extension doesn't start with dot, add it
    if [[ "$ext" != .* ]]; then
        ext=".$ext"
    fi
    echo "$ext"
}

# Function to count files with specific extension in directory
count_files_with_extension() {
    local directory="$1"
    local ext="$2"
    local count=0
    
    # Remove dot for case-insensitive matching
    ext="${ext#.}"
    
    # Enable case-insensitive globbing
    shopt -s nocaseglob
    
    for file in "$directory"/*.$ext; do
        if [[ -f "$file" ]]; then
            ((count++))
        fi
    done
    
    # Disable case-insensitive globbing
    shopt -u nocaseglob
    
    echo "$count"
}

# Function to perform the rename operation
rename_files() {
    local directory="$1"
    local old_ext="$2"
    local new_ext="$3"
    
    # Normalize extensions
    local old_ext_display; old_ext_display=$(normalize_extension "$old_ext")
    local new_ext_display; new_ext_display=$(normalize_extension "$new_ext")
    
    # Remove dot for case-insensitive matching
    old_ext="${old_ext#.}"
    new_ext="${new_ext#.}"
    
    # Check if advmv exists, otherwise use mv
    local mv_cmd="mv"
    if command -v advmv &> /dev/null; then
        mv_cmd="advmv"
        echo -e "${CYAN}Using advmv for rename operations${RESET}"
    else
        echo -e "${CYAN}Using mv for rename operations${RESET}"
    fi
    
    # Counter for renamed files
    local count=0
    local found=false
    
    # Enable case-insensitive globbing
    shopt -s nocaseglob
    
    # Process files in the directory
    for file in "$directory"/*.$old_ext; do
        # Check if file exists (to handle case where no matches found)
        if [[ -f "$file" ]]; then
            found=true
            # Get the filename without path
            local filename; filename=$(basename "$file")
            # Get the basename by removing the extension (preserving original case)
            local basename="${filename%.*}"
            local new_file="$directory/$basename.$new_ext"
            
            # Perform the rename
            if $mv_cmd "$file" "$new_file" 2>/dev/null; then
                echo -e "${BOLD_WHITE}Renamed: ${BOLD_YELLOW}${filename}${BOLD_RED} -> ${GREEN}$(basename "$new_file")${RESET}"
                ((count++))
            else
                echo -e "${RED}Error renaming: ${filename}${RESET}" >&2
            fi
        fi
    done
    
    # Disable case-insensitive globbing
    shopt -u nocaseglob
    
    if [[ "$found" == false ]]; then
        echo -e "${YELLOW}No files with extension '${old_ext_display}' found in ${directory}${RESET}"
    else
        echo -e "\n${BOLD_GREEN}Total files renamed: ${BOLD_WHITE}${count}${RESET}"
    fi
}

# Main script
main() {
    local directory=""
    local use_current_dir=false
    local input_ext=""
    local output_ext=""
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--here)
                use_current_dir=true
                directory="."
                shift
                ;;
            --help)
                show_help
                ;;
            -i|--input)
                if [[ -z "$2" || "$2" == -* ]]; then
                    echo -e "${RED}Error: -i/--input requires an extension argument${RESET}" >&2
                    echo -e "${YELLOW}Usage: ${0##*/} -i <extension>${RESET}" >&2
                    exit 1
                fi
                input_ext="$2"
                shift 2
                ;;
            -o|--output)
                if [[ -z "$2" || "$2" == -* ]]; then
                    echo -e "${RED}Error: -o/--output requires an extension argument${RESET}" >&2
                    echo -e "${YELLOW}Usage: ${0##*/} -o <extension>${RESET}" >&2
                    exit 1
                fi
                output_ext="$2"
                shift 2
                ;;
            *)
                # If not a flag, treat as directory
                if [[ -z "$directory" || "$directory" == "." ]]; then
                    directory="$1"
                else
                    echo -e "${RED}Error: Multiple directories specified${RESET}" >&2
                    exit 1
                fi
                shift
                ;;
        esac
    done
    
    # If no directory specified and not using current dir, show error
    if [[ -z "$directory" ]]; then
        echo -e "${RED}Error: Directory argument is required${RESET}" >&2
        echo -e "${YELLOW}Usage: ${0##*/} <directory> [-h|--here]${RESET}" >&2
        echo -e "${YELLOW}Try '${0##*/} --help' for more information${RESET}" >&2
        exit 1
    fi
    
    # Validate directory exists
    if [[ ! -d "$directory" ]]; then
        echo -e "${RED}Error: '$directory' is not a valid directory${RESET}" >&2
        exit 1
    fi
    
    # Convert to absolute path for display
    directory="$(cd "$directory" && pwd)"
    
    # Display header
    echo -e "\n${BOLD_CYAN}╔══════════════════════════════════════════════════════════╗${RESET}"
    echo -e "${BOLD_CYAN}║${RESET}          ${BOLD_WHITE}Rename Extensions - File Extension Renamer${RESET}      ${BOLD_CYAN}║${RESET}"
    echo -e "${BOLD_CYAN}╚══════════════════════════════════════════════════════════╝${RESET}"
    echo -e "${CYAN}Directory:${RESET} ${BOLD_WHITE}${directory}${RESET}"
    
    # Handle input extension (prompt if not provided)
    if [[ -z "$input_ext" ]]; then
        while true; do
            read -rp "$(echo -e "${BOLD_WHITE}Enter the current file extension${RESET} ${CYAN}(e.g., png or .png)${RESET}: ")" input_ext
            
            if validate_extension "$input_ext"; then
                break
            else
                echo -e "${RED}Invalid extension!${RESET} ${YELLOW}Please use only alphanumeric characters, dots, underscores, or hyphens.${RESET}" >&2
            fi
        done
    else
        # Validate provided input extension
        if ! validate_extension "$input_ext"; then
            echo -e "${RED}Error: Invalid input extension '${input_ext}'${RESET}" >&2
            echo -e "${YELLOW}Please use only alphanumeric characters, dots, underscores, or hyphens.${RESET}" >&2
            exit 1
        fi
    fi
    
    # Count files with input extension
    local input_display; input_display=$(normalize_extension "$input_ext")
    local file_count; file_count=$(count_files_with_extension "$directory" "$input_ext")
    
    # Check if files with the extension exist
    if [[ "$file_count" -eq 0 ]]; then
        echo -e "\n${YELLOW}No files with extension '${input_display}' found in the directory.${RESET}"
        echo -e "${YELLOW}Operation cancelled - nothing to rename.${RESET}"
        exit 0
    fi
    
    # Display input extension with file count
    if [[ -z "$input_ext_original" ]]; then
        echo -e "${CYAN}Input extension provided:${RESET} ${BOLD_YELLOW}${input_ext}${RESET} ${CYAN}(${file_count} file$([ "$file_count" -gt 1 ] && echo "s" || echo "") found)${RESET}"
    fi
    
    # Handle output extension (prompt if not provided)
    if [[ -z "$output_ext" ]]; then
        while true; do
            read -rp "$(echo -e "${BOLD_WHITE}Enter the new file extension${RESET} ${CYAN}(e.g., avif or .avif)${RESET}: ")" output_ext
            
            if validate_extension "$output_ext"; then
                break
            else
                echo -e "${RED}Invalid extension!${RESET} ${YELLOW}Please use only alphanumeric characters, dots, underscores, or hyphens.${RESET}" >&2
            fi
        done
    else
        # Validate provided output extension
        if ! validate_extension "$output_ext"; then
            echo -e "${RED}Error: Invalid output extension '${output_ext}'${RESET}" >&2
            echo -e "${YELLOW}Please use only alphanumeric characters, dots, underscores, or hyphens.${RESET}" >&2
            exit 1
        fi
        echo -e "${CYAN}Output extension provided:${RESET} ${BOLD_YELLOW}${output_ext}${RESET}"
    fi
    
    # Display operation summary
    local output_display; output_display=$(normalize_extension "$output_ext")
    
    echo -e "\n${BOLD_WHITE}Operation Summary:${RESET}"
    echo -e "  ${CYAN}From:${RESET} ${BOLD_YELLOW}${input_display}${RESET} ${CYAN}(${file_count} file$([ "$file_count" -gt 1 ] && echo "s" || echo ""))${RESET}"
    echo -e "  ${CYAN}To:${RESET}   ${GREEN}${output_display}${RESET}"
    
    # Confirm operation
    echo ""
    read -rp "$(echo -e "${BOLD_WHITE}Proceed with rename?${RESET} ${CYAN}(y/N)${RESET}: ")" confirm
    
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        echo -e "\n${BOLD_CYAN}Starting rename operation...${RESET}\n"
        rename_files "$directory" "$input_ext" "$output_ext"
    else
        echo -e "\n${YELLOW}Operation cancelled.${RESET}"
        exit 0
    fi
}

# Run main function with all arguments
main "$@"