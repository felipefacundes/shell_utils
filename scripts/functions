#!/usr/bin/env bash

# Pure Bash Function Browser with Fuzzy Search and Preview
# No external dependencies required - Optimized version with minimal flicker

# Colors (minimal set for better performance)
BOLD=$'\033[1m'
CYAN=$'\033[0;36m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
BLUE=$'\033[0;34m'
RESET=$'\033[0m'
BG_SELECTED=$'\033[48;5;240m'
BG_CURSOR=$'\033[48;5;235m'

# Terminal control
HIDE_CURSOR=$'\033[?25l'
SHOW_CURSOR=$'\033[?25h'
CLEAR_SCREEN=$'\033[2J'
CURSOR_HOME=$'\033[H'
CLEAR_LINE=$'\033[2K'
CLEAR_TO_END=$'\033[0J'

# Cleanup function for trap
cleanup() {
    printf "%s" "$SHOW_CURSOR"
    stty echo icanon
    clear
    echo "Goodbye!"
    exit 0
}

# Set trap for Ctrl+C and other signals
trap cleanup SIGINT SIGTERM

# Get all function names
get_functions() {
    declare -F | awk '{print $3}'
}

# Simple fuzzy matching - busca substring em qualquer parte do nome
fuzzy_match() {
    local pattern="$1"
    local string="$2"
    
    # Case insensitive: verifica se pattern é substring de string
    [[ "${string,,}" == *"${pattern,,}"* ]]
}

# Highlight matching characters - destaca a substring encontrada
highlight_match() {
    local pattern="$1"
    local string="$2"
    local pattern_lower="${pattern,,}"
    local string_lower="${string,,}"
    
    # Se não há pattern para buscar, retorna a string normal
    if [[ -z "$pattern" ]]; then
        printf "%s" "$string"
        return
    fi
    
    # Encontra a posição da substring (case insensitive)
    local pos=$(awk -v s="$string_lower" -v p="$pattern_lower" 'BEGIN{print index(s,p)}')
    
    if [[ $pos -gt 0 ]]; then
        # Parte antes do match
        printf "%s" "${string:0:$((pos-1))}"
        # Parte do match destacada
        printf "${BOLD}${YELLOW}%s${RESET}" "${string:$((pos-1)):${#pattern}}"
        # Parte depois do match
        printf "%s" "${string:$((pos-1+${#pattern}))}"
    else
        printf "%s" "$string"
    fi
}

# Get function preview
get_function_preview() {
    local func_name="$1"
    
    # Try to get function definition
    local func_def
    func_def=$(declare -f "$func_name" 2>/dev/null)
    
    if [[ -z "$func_def" ]]; then
        echo "Function not found: $func_name"
        return 1
    fi
    
    # Show all lines with line limit
    echo "$func_def" | head -n 25
}

# Main interactive loop
main() {
    # Get all functions
    local all_functions=($(get_functions))
    local filtered_functions=("${all_functions[@]}")
    local selected_index=0
    local search_term=""
    local cursor_pos=0
    local previous_search_term=""
    local previous_selected_index=-1
    
    # Terminal setup
    stty -echo -icanon time 0 min 0
    printf "%s" "$HIDE_CURSOR"
    
    # Initial screen draw
    printf "%s" "$CLEAR_SCREEN"
    printf "%s" "$CURSOR_HOME"
    
    # Draw static header
    printf "%s\n" "${BOLD}${CYAN}╔══════════════════════════════════════════════════════════════╗${RESET}"
    printf "%s\n" "${BOLD}${CYAN}║              Pure Bash Function Browser                      ║${RESET}"
    printf "%s\n" "${BOLD}${CYAN}╚══════════════════════════════════════════════════════════════╝${RESET}"
    printf "%s\n" "${GREEN}Type to search | ↑↓: Navigate | Enter: Full view | q: Quit${RESET}"
    printf "\n"
    
    while true; do
        # Check if we need to redraw the search line
        if [[ "$search_term" != "$previous_search_term" ]]; then
            # Move cursor to search line (line 6)
            printf "\033[6;1H"
            printf "%s" "$CLEAR_LINE"
            printf "${BOLD}Search: ${RESET}"
            if [[ ${#search_term} -gt 0 ]]; then
                if [[ $cursor_pos -lt ${#search_term} ]]; then
                    printf "%s" "${search_term:0:$cursor_pos}"
                    printf "${BG_CURSOR}%s${RESET}" "${search_term:$cursor_pos:1}"
                    printf "%s" "${search_term:$((cursor_pos + 1))}"
                else
                    printf "%s" "${search_term}"
                    printf "${BG_CURSOR} ${RESET}"
                fi
            else
                printf "${BG_CURSOR} ${RESET}"
            fi
            printf "  ${GREEN}[%d matches]${RESET}" "${#filtered_functions[@]}"
            previous_search_term="$search_term"
        fi
        
        # Move to function list area
        printf "\033[8;1H"
        printf "%s" "$CLEAR_TO_END"
        
        # Show filtered functions header
        printf "${BOLD}Functions:${RESET}\n"
        printf "${CYAN}────────────────────────────────────────────────────────────────${RESET}\n"
        
        local max_display=10  # Fixed number of functions to display
        local start_idx=0
        
        if [[ $selected_index -ge $max_display ]]; then
            start_idx=$((selected_index - max_display + 1))
        fi
        
        for ((i = start_idx; i < ${#filtered_functions[@]} && i < start_idx + max_display; i++)); do
            if [[ $i -eq $selected_index ]]; then
                printf "${BG_SELECTED}${BOLD}> "
                printf "%s" "$(highlight_match "$search_term" "${filtered_functions[$i]}")"
                printf "${RESET}\n"
            else
                printf "  %s\n" "$(highlight_match "$search_term" "${filtered_functions[$i]}")"
            fi
        done
        
        # Show count if there are more functions
        if [[ ${#filtered_functions[@]} -gt $max_display ]]; then
            printf "\n${GREEN}... and %d more functions${RESET}\n" $((${#filtered_functions[@]} - max_display))
        fi
        
        # Show preview
        printf "\n${BOLD}Preview:${RESET}\n"
        printf "${CYAN}────────────────────────────────────────────────────────────────${RESET}\n"
        
        if [[ ${#filtered_functions[@]} -gt 0 ]] && [[ $selected_index -lt ${#filtered_functions[@]} ]]; then
            get_function_preview "${filtered_functions[$selected_index]}"
        fi
        
        # Update previous selected index
        previous_selected_index=$selected_index
        
        # Read keyboard input
        local key=""
        read -r -n 1 key
        
        case "$key" in
            $'\x1b')  # ESC sequence
                read -r -n 2 -t 0.001 key2
                case "$key2" in
                    '[A')  # Up arrow
                        ((selected_index > 0)) && ((selected_index--))
                        ;;
                    '[B')  # Down arrow
                        ((selected_index < ${#filtered_functions[@]} - 1)) && ((selected_index++))
                        ;;
                    '[C')  # Right arrow
                        ((cursor_pos < ${#search_term})) && ((cursor_pos++))
                        previous_search_term=""  # Force redraw of search line
                        ;;
                    '[D')  # Left arrow
                        ((cursor_pos > 0)) && ((cursor_pos--))
                        previous_search_term=""  # Force redraw of search line
                        ;;
                esac
                ;;
            $'\x7f')  # Backspace
                if [[ ${#search_term} -gt 0 ]] && [[ $cursor_pos -gt 0 ]]; then
                    search_term="${search_term:0:$((cursor_pos - 1))}${search_term:$cursor_pos}"
                    ((cursor_pos--))
                fi
                ;;
            '')  # Enter
                if [[ ${#filtered_functions[@]} -gt 0 ]]; then
                    stty echo icanon
                    printf "%s" "$SHOW_CURSOR"
                    clear
                    printf "${BOLD}${CYAN}Full definition: ${YELLOW}%s${RESET}\n" "${filtered_functions[$selected_index]}"
                    printf "${CYAN}════════════════════════════════════════════════════════════════${RESET}\n"
                    declare -f "${filtered_functions[$selected_index]}"
                    printf "\n"
                    printf "${GREEN}Press Enter to continue...${RESET}"
                    read -r
                    stty -echo -icanon
                    printf "%s" "$HIDE_CURSOR"
                    printf "%s" "$CLEAR_SCREEN"
                    printf "%s" "$CURSOR_HOME"
                    # Redraw header
                    printf "%s\n" "${BOLD}${CYAN}╔══════════════════════════════════════════════════════════════╗${RESET}"
                    printf "%s\n" "${BOLD}${CYAN}║              Pure Bash Function Browser                      ║${RESET}"
                    printf "%s\n" "${BOLD}${CYAN}╚══════════════════════════════════════════════════════════════╝${RESET}"
                    printf "%s\n" "${GREEN}Type to search | ↑↓: Navigate | Enter: Full view | q: Quit${RESET}"
                    printf "\n"
                    previous_search_term=""
                fi
                ;;
            $'\x71'|$'\x51')  # 'q' or 'Q' to quit
                cleanup
                ;;
            [[:print:]])  # Printable characters
                search_term="${search_term:0:$cursor_pos}${key}${search_term:$cursor_pos}"
                ((cursor_pos++))
                ;;
        esac
        
        # Filter functions
        if [[ "$search_term" != "$previous_search_term" ]]; then
            filtered_functions=()
            if [[ -z "$search_term" ]]; then
                filtered_functions=("${all_functions[@]}")
            else
                for func in "${all_functions[@]}"; do
                    if fuzzy_match "$search_term" "$func"; then
                        filtered_functions+=("$func")
                    fi
                done
            fi
            
            # Adjust selected index
            if [[ $selected_index -ge ${#filtered_functions[@]} ]]; then
                selected_index=$((${#filtered_functions[@]} - 1))
            fi
            if [[ $selected_index -lt 0 ]]; then
                selected_index=0
            fi
        fi
    done
}

# Run the main function
main