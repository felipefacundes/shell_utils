#!/usr/bin/env bash
# License: GPLv3
# Credits: Felipe Facundes
#
# ble.sh — Bash Line Editor
#
# INSTALAÇÃO — adicione como ÚLTIMA linha do ~/.bashrc:
#   source ~/ble.sh
#
# Como funciona:
#   1. source retorna imediatamente — apenas define funções e
#      configura PROMPT_COMMAND="_ble_start". NÃO trava.
#   2. Quando o bash vai exibir o primeiro prompt (após o bashrc
#      terminar), chama _ble_start via PROMPT_COMMAND.
#   3. _ble_start inicia o loop stty raw — terminal está pronto,
#      todo o ambiente do bashrc já foi carregado.
#   4. O loop executa comandos com eval no shell pai — cd, export,
#      aliases e tudo mais funcionam normalmente.
#
# Compatibilidade: Bash 4.3+

[[ "${_BLE_LOADED:-}" == "1" ]] && return 0
_BLE_LOADED=1

(( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 3) )) && {
    printf 'ble.sh: requer Bash 4.3+  (atual: %s)\n' "$BASH_VERSION" >&2
    return 1
}

# ══════════════════════════════════════════════════════════════
# CORES
# ══════════════════════════════════════════════════════════════
_b0=$'\e[0m'
_bb=$'\e[1m'
_bG=$'\e[38;5;82m'
_bR=$'\e[38;5;196m'
_bA=$'\e[38;5;252m'
_bO=$'\e[38;5;75m'
_bS=$'\e[38;5;214m'
_bN=$'\e[38;5;183m'
_bP=$'\e[38;5;220m'
_bH=$'\e[38;5;240m'
_bPR=$'\e[38;5;117m'
_bGT=$'\e[38;5;213m'
_bAK=$'\e[38;5;82m'
_bAE=$'\e[38;5;196m'
_bSL=$'\e[48;5;25m\e[38;5;231m\e[1m'
_bHD=$'\e[48;5;235m\e[38;5;245m'

# ══════════════════════════════════════════════════════════════
# LS_COLORS
# ══════════════════════════════════════════════════════════════
_ble_ensure_lscolors() {
    if [[ -n "${LS_COLORS:-}" ]]; then export LS_COLORS; return; fi
    command -v dircolors &>/dev/null || return
    local f
    for f in "$HOME/.dircolors" "$HOME/.dir_colors" \
             /etc/dircolors /etc/DIR_COLORS; do
        [[ -f "$f" ]] && { eval "$(dircolors -b "$f" 2>/dev/null)"; export LS_COLORS; return; }
    done
    eval "$(dircolors -b 2>/dev/null)"; export LS_COLORS
}

_ble_lscolor() {
    local key="$1" entry val="" _IFS="$IFS"; IFS=:
    for entry in ${LS_COLORS:-}; do
        IFS="$_IFS"
        [[ "$entry" == "${key}="* ]] && { val="${entry#*=}"; break; }
    done
    IFS="$_IFS"
    [[ -n "$val" ]] && printf '\e[%sm' "$val" && return
    case "$key" in
        di) printf '\e[1;34m' ;; ln) printf '\e[1;36m' ;;
        ex) printf '\e[1;32m' ;; *)  printf '\e[0m'    ;;
    esac
}

_ble_file_color() {
    local f="$1"
    [[ -d "$f" ]] && { _ble_lscolor "di"; return; }
    [[ -L "$f" ]] && { _ble_lscolor "ln"; return; }
    [[ -x "$f" && -f "$f" ]] && { _ble_lscolor "ex"; return; }
    if [[ -n "${LS_COLORS:-}" && "$f" == *.* ]]; then
        local ext="*.${f##*.}" entry val="" _IFS="$IFS"; IFS=:
        for entry in $LS_COLORS; do
            IFS="$_IFS"
            [[ "$entry" == "${ext}="* ]] && { val="${entry#*=}"; break; }
        done
        IFS="$_IFS"
        [[ -n "$val" ]] && { printf '\e[%sm' "$val"; return; }
    fi
    _ble_lscolor "fi"
}

_ble_file_suffix() {
    [[ -d "$1" ]] && printf '/' && return
    [[ -L "$1" ]] && printf '@' && return
    [[ -x "$1" && -f "$1" ]] && printf '*'
}

# ══════════════════════════════════════════════════════════════
# VERIFICAÇÃO DE COMANDO
# Funciona aqui porque estamos no loop stty raw (não bind -x).
# type -t enxerga aliases, funções, builtins e PATH.
# ══════════════════════════════════════════════════════════════
_ble_cmd_valid() {
    [[ -z "$1" ]] && return 1
    # </dev/null impede que type -t consuma stdin do terminal raw
    builtin type -t "$1" </dev/null &>/dev/null 2>&1
}

# ══════════════════════════════════════════════════════════════
# SYNTAX HIGHLIGHT — zero subshells no caminho crítico
# Todas as funções escrevem em variáveis globais em vez de stdout
# capturado via $(...), evitando consumo de stdin em stty raw.
# ══════════════════════════════════════════════════════════════
_BLE_HL=""
_BLE_RET=""   # variável global de retorno (substitui subshells)

# Escreve cor ANSI de chave LS_COLORS em _BLE_RET
_ble_lscolor_r() {
    local key="$1" entry val="" _IFS="$IFS"; IFS=:
    for entry in ${LS_COLORS:-}; do
        IFS="$_IFS"
        [[ "$entry" == "${key}="* ]] && { val="${entry#*=}"; break; }
    done
    IFS="$_IFS"
    if [[ -n "$val" ]]; then
        _BLE_RET=$'\e['"${val}"'m'
    else
        case "$key" in
            di) _BLE_RET=$'\e[1;34m' ;; ln) _BLE_RET=$'\e[1;36m' ;;
            ex) _BLE_RET=$'\e[1;32m' ;; *)  _BLE_RET=$'\e[0m'    ;;
        esac
    fi
}

# Escreve cor de arquivo em _BLE_RET
_ble_file_color_r() {
    local f="$1"
    if   [[ -d "$f" ]]; then _ble_lscolor_r "di"
    elif [[ -L "$f" ]]; then _ble_lscolor_r "ln"
    elif [[ -x "$f" && -f "$f" ]]; then _ble_lscolor_r "ex"
    elif [[ -n "${LS_COLORS:-}" && "$f" == *.* ]]; then
        local ext="*.${f##*.}" entry val="" _IFS="$IFS"; IFS=:
        for entry in $LS_COLORS; do
            IFS="$_IFS"
            [[ "$entry" == "${ext}="* ]] && { val="${entry#*=}"; break; }
        done
        IFS="$_IFS"
        if [[ -n "$val" ]]; then _BLE_RET=$'\e['"${val}"'m'
        else _ble_lscolor_r "fi"
        fi
    else
        _BLE_RET="$_b0"
    fi
}

# Escreve sufixo de arquivo em _BLE_RET
_ble_file_suffix_r() {
    if   [[ -d "$1" ]]; then _BLE_RET="/"
    elif [[ -L "$1" ]]; then _BLE_RET="@"
    elif [[ -x "$1" && -f "$1" ]]; then _BLE_RET="*"
    else _BLE_RET=""
    fi
}

# Acrescenta em colored_rest a cor de um argumento (sem subshell)
_ble_append_arg() {
    local w="$1"
    case "$w" in
        --*|-[a-zA-Z]*) colored_rest+="${_bO}${w}${_b0} " ;;
        [0-9]*)         colored_rest+="${_bN}${w}${_b0} " ;;
        \$*)            colored_rest+="${_bN}${w}${_b0} " ;;
        \'*|\"*)        colored_rest+="${_bS}${w}${_b0} " ;;
        */*)
            _ble_file_color_r "$w"
            colored_rest+="${_BLE_RET}${w}${_b0} " ;;
        *)              colored_rest+="${_bA}${w}${_b0} " ;;
    esac
}

_ble_highlight() {
    local line="$1"
    _BLE_HL=""
    [[ -z "$line" ]] && return

    local first="${line%% *}"
    local rest=""
    [[ "$line" == *" "* ]] && rest="${line#* }"

    local cmd_color
    # </dev/null: type -t não consome stdin do terminal raw
    builtin type -t "$first" </dev/null &>/dev/null \
        && cmd_color="$_bG" || cmd_color="$_bR"

    if [[ -z "$rest" ]]; then
        _BLE_HL="${cmd_color}${first}${_b0}"
        return
    fi

    local colored_rest="" tok="" i char len=${#rest}
    local in_sq=0 in_dq=0

    for (( i=0; i<len; i++ )); do
        char="${rest:$i:1}"
        if (( in_sq )); then
            tok+="$char"; [[ "$char" == "'" ]] && in_sq=0; continue
        fi
        if (( in_dq )); then
            tok+="$char"; [[ "$char" == '"' ]] && in_dq=0; continue
        fi
        case "$char" in
            "'")      tok+="$char"; in_sq=1 ;;
            '"')      tok+="$char"; in_dq=1 ;;
            ' '|$'\t')
                if [[ -n "$tok" ]]; then _ble_append_arg "$tok"; tok=""; fi ;;
            '|'|';'|'&')
                [[ -n "$tok" ]] && { _ble_append_arg "$tok"; tok=""; }
                colored_rest+="${_bP}${char}${_b0} " ;;
            *) tok+="$char" ;;
        esac
    done
    [[ -n "$tok" ]] && _ble_append_arg "$tok"
    colored_rest="${colored_rest% }"

    _BLE_HL="${cmd_color}${first}${_b0} ${colored_rest}"
}

# ══════════════════════════════════════════════════════════════
# TERMINAL
# ══════════════════════════════════════════════════════════════
_BLE_TTY_SAVED=""

_ble_term_raw() {
    _BLE_TTY_SAVED=$(stty -g 2>/dev/null)
    stty -echo -icanon -icrnl min 1 time 0 2>/dev/null
}

_ble_term_restore() {
    [[ -n "$_BLE_TTY_SAVED" ]] && stty "$_BLE_TTY_SAVED" 2>/dev/null
}

_ble_term_cols() { tput cols 2>/dev/null || echo 80; }

# ══════════════════════════════════════════════════════════════
# LEITURA DE TECLA
# ══════════════════════════════════════════════════════════════
_BLE_KEY=""
_BLE_KTYPE=""

_ble_read_key() {
    local k s1 s2 s3
    IFS= read -rsn1 k
    _BLE_KEY="$k"
    if [[ "$k" == $'\x1b' ]]; then
        IFS= read -rsn1 -t 0.15 s1 2>/dev/null || { _BLE_KTYPE="esc"; return; }
        _BLE_KEY+="$s1"
        if [[ "$s1" == '[' ]]; then
            IFS= read -rsn1 -t 0.15 s2 2>/dev/null || { _BLE_KTYPE="unknown"; return; }
            _BLE_KEY+="$s2"
            case "$s2" in
                A) _BLE_KTYPE="up"    ;; B) _BLE_KTYPE="down"  ;;
                C) _BLE_KTYPE="right" ;; D) _BLE_KTYPE="left"  ;;
                H) _BLE_KTYPE="home"  ;; F) _BLE_KTYPE="end"   ;;
                3) IFS= read -rsn1 -t 0.15 s3 2>/dev/null
                   _BLE_KEY+="$s3"; _BLE_KTYPE="del"  ;;
                5) IFS= read -rsn1 -t 0.15 s3 2>/dev/null
                   _BLE_KEY+="$s3"; _BLE_KTYPE="pgup" ;;
                6) IFS= read -rsn1 -t 0.15 s3 2>/dev/null
                   _BLE_KEY+="$s3"; _BLE_KTYPE="pgdn" ;;
                1) IFS= read -rsn1 -t 0.15 s3 2>/dev/null; _BLE_KEY+="$s3"
                   case "$s3" in
                       A) _BLE_KTYPE="ctrl_up"   ;;
                       B) _BLE_KTYPE="ctrl_down" ;;
                       *) _BLE_KTYPE="unknown"   ;;
                   esac ;;
                *) _BLE_KTYPE="unknown" ;;
            esac
        elif [[ "$s1" == 'O' ]]; then
            IFS= read -rsn1 -t 0.15 s2 2>/dev/null || { _BLE_KTYPE="unknown"; return; }
            _BLE_KEY+="$s2"
            case "$s2" in
                H) _BLE_KTYPE="home"      ;; F) _BLE_KTYPE="end"       ;;
                A) _BLE_KTYPE="ctrl_up"   ;; B) _BLE_KTYPE="ctrl_down" ;;
                *) _BLE_KTYPE="unknown"   ;;
            esac
        else
            _BLE_KTYPE="unknown"
        fi
        return
    fi
    case "$k" in
        $'\x09') _BLE_KTYPE="tab"   ;;
        $'\x0a'|$'\x0d') _BLE_KTYPE="enter"  ;;
        $'\x7f'|$'\x08') _BLE_KTYPE="bs"     ;;
        $'\x03') _BLE_KTYPE="ctrlc" ;;
        $'\x04') _BLE_KTYPE="ctrld" ;;
        $'\x01') _BLE_KTYPE="home"  ;;
        $'\x05') _BLE_KTYPE="end"   ;;
        $'\x0b') _BLE_KTYPE="ctrlk" ;;
        $'\x15') _BLE_KTYPE="ctrlu" ;;
        $'\x17') _BLE_KTYPE="ctrlw" ;;
        $'\x0c') _BLE_KTYPE="ctrll" ;;
        $'\x12') _BLE_KTYPE="ctrlr" ;;
        $'\x06') _BLE_KTYPE="ctrlf" ;;
        *)
            local _code
            printf -v _code '%d' "'$k" 2>/dev/null || _code=0
            (( _code >= 32 )) && _BLE_KTYPE="char" || _BLE_KTYPE="unknown"
            ;;
    esac
}

# ══════════════════════════════════════════════════════════════
# HISTÓRICO
# ══════════════════════════════════════════════════════════════
declare -ga _BLE_HIST=()

_ble_load_hist() {
    local hfile="${HISTFILE:-$HOME/.bash_history}"
    _BLE_HIST=()
    [[ -f "$hfile" ]] || return
    mapfile -t _BLE_HIST < <(grep -v '^#[0-9]\+$' "$hfile" 2>/dev/null)
}

_ble_save_hist() {
    local cmd="$1"
    [[ -z "$cmd" ]] && return
    [[ "${_BLE_HIST[-1]:-}" == "$cmd" ]] && return
    _BLE_HIST+=("$cmd")
    local hfile="${HISTFILE:-$HOME/.bash_history}"
    if [[ -n "${HISTTIMEFORMAT:-}" ]]; then
        printf '#%s\n%s\n' "$(date +%s)" "$cmd" >> "$hfile" 2>/dev/null
    else
        printf '%s\n' "$cmd" >> "$hfile" 2>/dev/null
    fi
    history -r "$hfile" 2>/dev/null
}

# ══════════════════════════════════════════════════════════════
# GHOST TEXT
# ══════════════════════════════════════════════════════════════
_BLE_SUGGESTION=""

_ble_get_suggestion() {
    _BLE_SUGGESTION=""
    local cur="$1"
    [[ ${#cur} -lt 1 ]] && return
    local i
    for (( i=${#_BLE_HIST[@]}-1; i>=0; i-- )); do
        if [[ "${_BLE_HIST[$i]}" == "${cur}"* && \
              "${_BLE_HIST[$i]}" != "$cur" ]]; then
            _BLE_SUGGESTION="${_BLE_HIST[$i]}"; return
        fi
    done
    # Sugestão de comando: compgen roda em subshell mas só quando
    # não há sugestão do histórico e linha não tem espaço
    if [[ "$cur" != *" "* ]]; then
        local _cg
        _cg=$(compgen -c -- "$cur" 2>/dev/null | head -1)
        [[ -n "$_cg" && "$_cg" != "$cur" ]] && _BLE_SUGGESTION="$_cg"
    fi
}

# ══════════════════════════════════════════════════════════════
# PROMPT
# ══════════════════════════════════════════════════════════════
_BLE_PROMPT=""
_BLE_LAST_EXIT=0

_ble_build_prompt() {
    local dir="${PWD/$HOME/\~}" git_info=""
    if git rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
        local branch dirty=""
        branch=$(git symbolic-ref --short HEAD 2>/dev/null \
              || git rev-parse --short HEAD 2>/dev/null || echo "?")
        git diff --quiet 2>/dev/null          || dirty+="${_bAE}●${_b0}"
        git diff --cached --quiet 2>/dev/null || dirty+="${_bG}+${_b0}"
        git_info=" ${_bGT}⎇ ${branch}${_b0}${dirty}"
    fi
    local arrow
    (( _BLE_LAST_EXIT == 0 )) \
        && arrow="${_bAK}❯${_b0}" \
        || arrow="${_bAE}❯ [✗${_BLE_LAST_EXIT}]${_b0}"
    _BLE_PROMPT="${_bPR}${dir}${_b0}${git_info} ${arrow} "
}

# ══════════════════════════════════════════════════════════════
# REDRAW
# ══════════════════════════════════════════════════════════════
_ble_redraw() {
    local input="$1" cursor="$2" show_ghost="${3:-1}"

    _ble_highlight "$input"

    local ghost_str=""
    if (( show_ghost )); then
        _ble_get_suggestion "$input"
        if [[ -n "$_BLE_SUGGESTION" && \
              "$_BLE_SUGGESTION" == "${input}"* && \
              "$_BLE_SUGGESTION" != "$input" ]]; then
            ghost_str="${_bH}${_BLE_SUGGESTION:${#input}}${_b0}"
        fi
    fi

    printf '\r\e[K%s%s%s' "$_BLE_PROMPT" "$_BLE_HL" "$ghost_str"

    local after=$(( ${#input} - cursor ))
    local ghost_vis=0
    [[ -n "$ghost_str" ]] && ghost_vis=$(( ${#_BLE_SUGGESTION} - ${#input} ))
    local back=$(( after + ghost_vis ))
    (( back > 0 )) && printf '\e[%dD' "$back"
}

# ══════════════════════════════════════════════════════════════
# COMPLETAÇÃO
# ══════════════════════════════════════════════════════════════
declare -a _BLE_COMP_ITEMS=()

_ble_collect_completions() {
    local line="$1" word="$2"
    _BLE_COMP_ITEMS=()
    local is_first=0
    [[ "$line" == "$word" || -z "${line% "$word"}" ]] && is_first=1

    if (( is_first )) && [[ "$word" != */* ]]; then
        mapfile -t _BLE_COMP_ITEMS < <(
            compgen -abc -- "$word" 2>/dev/null | sort -u | head -300)
        return
    fi

    local cmd="${line%% *}"
    local comp_fn
    comp_fn=$(complete -p "$cmd" 2>/dev/null \
              | grep -oP '(?<=-F )\S+' | head -1)
    if [[ -n "$comp_fn" ]] && declare -F "$comp_fn" &>/dev/null; then
        local COMP_LINE="$line" COMP_POINT=${#line}
        local -a COMP_WORDS=(); read -ra COMP_WORDS <<< "$line"
        local COMP_CWORD=$(( ${#COMP_WORDS[@]}-1 ))
        local COMPREPLY=()
        "$comp_fn" "$cmd" "$word" \
            "${COMP_WORDS[$((COMP_CWORD>0?COMP_CWORD-1:0))]:-}" \
            2>/dev/null || true
        (( ${#COMPREPLY[@]} > 0 )) && {
            _BLE_COMP_ITEMS=("${COMPREPLY[@]}"); return; }
    fi
    mapfile -t _BLE_COMP_ITEMS < <(compgen -f -- "$word" 2>/dev/null | sort)
}

# ══════════════════════════════════════════════════════════════
# MENU
# ══════════════════════════════════════════════════════════════
_BLE_MENU_RES=""

_ble_menu() {
    local -a items=("$@")
    local total=${#items[@]}
    (( total == 0 )) && return 1

    local tw="${COLUMNS:-$(tput cols 2>/dev/null || echo 80)}"
    local max_len=4 it
    for it in "${items[@]}"; do
        (( ${#it}+1 > max_len )) && max_len=$(( ${#it}+1 ))
    done
    local cw=$(( max_len + 2 ))
    (( cw < 8  )) && cw=8; (( cw > 50 )) && cw=50
    local cols=$(( tw / cw ))
    (( cols < 1 )) && cols=1; (( cols > 16 )) && cols=16
    local total_rows=$(( (total + cols - 1) / cols ))
    local max_vis=12
    local vis=$(( total_rows < max_vis ? total_rows : max_vis ))
    local sel=0 scroll=0 _ML=0

    _mdraw() {
        local s=$1 sc=$2 n=0 r c idx it sf disp fc
        local hdr; printf -v hdr \
            ' 📂 %d itens   ↑↓←→ navegar   TAB/Enter confirma   Esc cancela' "$total"
        printf '%s%-*.*s%s\n' "$_bHD" "$tw" "$tw" "$hdr" "$_b0"; (( n++ ))
        for (( r=sc; r<sc+vis && r<total_rows; r++ )); do
            for (( c=0; c<cols; c++ )); do
                idx=$(( r*cols+c )); (( idx >= total )) && break
                it="${items[$idx]}"; _ble_file_suffix_r "$it"; disp="${it}${_BLE_RET}"
                if (( idx == s )); then
                    printf '%s %-*.*s%s' "$_bSL" "$cw" "$cw" "$disp" "$_b0"
                else
                    _ble_file_color_r "$it"
                    printf '%s %-*.*s%s' "$_BLE_RET" "$cw" "$cw" "$disp" "$_b0"
                fi
            done
            printf '\n'; (( n++ ))
        done
        if (( total_rows > max_vis )); then
            local pct=$(( (sc+vis)*100/total_rows )); (( pct > 100 )) && pct=100
            printf '%s ↕ %d%%  (%d total)%-*s%s\n' \
                "$_bHD" "$pct" "$total" "$(( tw-20 ))" "" "$_b0"; (( n++ ))
        fi
        _ML=$n
    }

    printf '\n'; _mdraw "$sel" "$scroll"

    local chosen=""
    while true; do
        _ble_read_key
        case "$_BLE_KTYPE" in
            up)    (( sel -= cols )); (( sel < 0 )) && sel=$(( total-1 )) ;;
            down)  (( sel += cols )); (( sel >= total )) && sel=0 ;;
            right) (( sel++ ));       (( sel >= total )) && sel=0 ;;
            left)  (( sel-- ));       (( sel < 0 )) && sel=$(( total-1 )) ;;
            tab|enter) chosen="${items[$sel]}" ;;
            esc|ctrlc) chosen="" ;;
        esac
        printf '\e[%dA\r\e[J' "$(( _ML + 1 ))"
        if [[ "$_BLE_KTYPE" == tab || "$_BLE_KTYPE" == enter || \
              "$_BLE_KTYPE" == esc || "$_BLE_KTYPE" == ctrlc ]]; then
            break
        fi
        local sr=$(( sel/cols ))
        (( sr < scroll )) && scroll=$sr
        (( sr >= scroll+vis )) && scroll=$(( sr-vis+1 ))
        printf '\n'; _mdraw "$sel" "$scroll"
    done

    unset -f _mdraw
    [[ -n "$chosen" ]] && { _BLE_MENU_RES="$chosen"; return 0; }
    _BLE_MENU_RES=""; return 1
}

# ══════════════════════════════════════════════════════════════
# BUSCA INCREMENTAL
# ══════════════════════════════════════════════════════════════
_BLE_SEARCH_RESULT=""

_ble_history_search() {
    _BLE_SEARCH_RESULT=""
    local query="" result=""

    _hsdraw() {
        printf '\r\e[K%sbck-i-search%s: %s%s%s' "$_bHD" "$_b0" "$_bG" "$query" "$_b0"
        [[ -n "$result" ]] \
            && printf '  %s→ %s%s' "$_bH" "$result" "$_b0" \
            || { [[ -n "$query" ]] && printf '  %s(não encontrado)%s' "$_bAE" "$_b0"; }
    }

    printf '\n'; _hsdraw
    while true; do
        _ble_read_key
        case "$_BLE_KTYPE" in
            char)      query+="$_BLE_KEY" ;;
            bs)        [[ -n "$query" ]] && query="${query:0:-1}" ;;
            tab|enter) _BLE_SEARCH_RESULT="$result"; break ;;
            esc|ctrlc) break ;;
        esac
        result=""
        if [[ -n "$query" ]]; then
            local i
            for (( i=${#_BLE_HIST[@]}-1; i>=0; i-- )); do
                [[ "${_BLE_HIST[$i]}" == *"$query"* ]] && {
                    result="${_BLE_HIST[$i]}"; break; }
            done
        fi
        printf '\r\e[K'; _hsdraw
    done
    printf '\r\e[K'
    unset -f _hsdraw
}

# ══════════════════════════════════════════════════════════════
# LOOP PRINCIPAL — chamado via PROMPT_COMMAND, não pelo source
# Todas as variáveis de estado são globais — zero subshells no
# caminho crítico de leitura de teclas.
# ══════════════════════════════════════════════════════════════
_BLE_INPUT=""
_BLE_CURSOR=0
_BLE_HIST_IDX=-1
_BLE_HIST_SAVED=""
_BLE_HIST_PREFIX=""

_ble_loop() {

    _ble_load_hist
    _ble_ensure_lscolors

    # Instala trap: restaura stty em qualquer saída anormal
    trap '_ble_term_restore; _BLE_LOADED=0; trap - INT TERM EXIT' INT TERM EXIT

    _ble_term_raw

    printf '%s╔══════════════════════════════════════════════╗%s\n' "${_bG}${_bb}" "$_b0"
    printf '%s║  🐚 ble.sh ativo                             ║%s\n' "${_bG}${_bb}" "$_b0"
    printf '%s║  Digitar       → highlight + ghost text      ║%s\n' "$_bH" "$_b0"
    printf '%s║  → / Ctrl+F    → aceitar sugestão            ║%s\n' "$_bH" "$_b0"
    printf '%s║  Tab / Enter   → confirmar no menu           ║%s\n' "$_bH" "$_b0"
    printf '%s║  ↑ ↓           → histórico filtrado          ║%s\n' "$_bH" "$_b0"
    printf '%s║  Ctrl+↑↓       → histórico livre             ║%s\n' "$_bH" "$_b0"
    printf '%s║  Ctrl+R        → busca incremental           ║%s\n' "$_bH" "$_b0"
    printf '%s║  Ctrl+C        → cancela linha               ║%s\n' "$_bH" "$_b0"
    printf '%s║  Ctrl+D        → sair do ble                 ║%s\n' "$_bH" "$_b0"
    printf '%s╚══════════════════════════════════════════════╝%s\n' "${_bG}${_bb}" "$_b0"

    # ── Loop externo: um prompt por iteração ──────────────────
    while true; do
        _ble_build_prompt
        _BLE_INPUT=""
        _BLE_CURSOR=0
        _BLE_HIST_IDX=-1
        _BLE_HIST_SAVED=""
        _BLE_HIST_PREFIX=""

        printf '%s' "$_BLE_PROMPT"

        # ── Loop interno: edição da linha ─────────────────────
        while true; do
            _ble_redraw "$_BLE_INPUT" "$_BLE_CURSOR"
            _ble_read_key

            case "$_BLE_KTYPE" in

                char)
                    _BLE_INPUT="${_BLE_INPUT:0:$_BLE_CURSOR}${_BLE_KEY}${_BLE_INPUT:$_BLE_CURSOR}"
                    (( _BLE_CURSOR++ ))
                    _BLE_HIST_IDX=-1; _BLE_HIST_PREFIX=""
                    ;;

                bs)
                    if (( _BLE_CURSOR > 0 )); then
                        _BLE_INPUT="${_BLE_INPUT:0:$((_BLE_CURSOR-1))}${_BLE_INPUT:$_BLE_CURSOR}"
                        (( _BLE_CURSOR-- ))
                    fi
                    _BLE_HIST_IDX=-1
                    ;;

                del)
                    (( _BLE_CURSOR < ${#_BLE_INPUT} )) && \
                        _BLE_INPUT="${_BLE_INPUT:0:$_BLE_CURSOR}${_BLE_INPUT:$((_BLE_CURSOR+1))}"
                    ;;

                left)  (( _BLE_CURSOR > 0 )) && (( _BLE_CURSOR-- )) ;;
                home)  _BLE_CURSOR=0 ;;
                end)   _BLE_CURSOR=${#_BLE_INPUT} ;;

                right)
                    if (( _BLE_CURSOR == ${#_BLE_INPUT} )); then
                        _ble_get_suggestion "$_BLE_INPUT"
                        if [[ -n "$_BLE_SUGGESTION" && \
                              "$_BLE_SUGGESTION" == "${_BLE_INPUT}"* ]]; then
                            local _rest="${_BLE_SUGGESTION:${#_BLE_INPUT}}"
                            [[ "$_rest" == *' '* ]] \
                                && _BLE_INPUT="${_BLE_INPUT}${_rest%% *} " \
                                || _BLE_INPUT="$_BLE_SUGGESTION"
                            _BLE_CURSOR=${#_BLE_INPUT}
                        fi
                    else
                        (( _BLE_CURSOR++ ))
                    fi
                    ;;

                ctrlf)
                    _ble_get_suggestion "$_BLE_INPUT"
                    if [[ -n "$_BLE_SUGGESTION" && \
                          "$_BLE_SUGGESTION" == "${_BLE_INPUT}"* ]]; then
                        _BLE_INPUT="$_BLE_SUGGESTION"
                        _BLE_CURSOR=${#_BLE_INPUT}
                    fi
                    ;;

                up)
                    local _hlen="${#_BLE_HIST[@]}"
                    (( _hlen == 0 )) && continue
                    if (( _BLE_HIST_IDX == -1 )); then
                        _BLE_HIST_SAVED="$_BLE_INPUT"
                        _BLE_HIST_PREFIX="$_BLE_INPUT"
                        _BLE_HIST_IDX=$_hlen
                    fi
                    local _i
                    for (( _i=_BLE_HIST_IDX-1; _i>=0; _i-- )); do
                        if [[ "${_BLE_HIST[$_i]}" == "${_BLE_HIST_PREFIX}"* && \
                              "${_BLE_HIST[$_i]}" != "$_BLE_INPUT" ]]; then
                            _BLE_HIST_IDX=$_i
                            _BLE_INPUT="${_BLE_HIST[$_i]}"
                            _BLE_CURSOR=${#_BLE_INPUT}
                            break
                        fi
                    done
                    ;;

                down)
                    (( _BLE_HIST_IDX == -1 )) && continue
                    local _hlen="${#_BLE_HIST[@]}" _i
                    for (( _i=_BLE_HIST_IDX+1; _i<_hlen; _i++ )); do
                        if [[ "${_BLE_HIST[$_i]}" == "${_BLE_HIST_PREFIX}"* ]]; then
                            _BLE_HIST_IDX=$_i
                            _BLE_INPUT="${_BLE_HIST[$_i]}"
                            _BLE_CURSOR=${#_BLE_INPUT}
                            break
                        fi
                    done
                    if (( _i >= _hlen )); then
                        _BLE_HIST_IDX=-1
                        _BLE_INPUT="$_BLE_HIST_SAVED"
                        _BLE_CURSOR=${#_BLE_INPUT}
                    fi
                    ;;

                ctrl_up)
                    local _hlen="${#_BLE_HIST[@]}"
                    (( _hlen == 0 )) && continue
                    if (( _BLE_HIST_IDX == -1 )); then
                        _BLE_HIST_SAVED="$_BLE_INPUT"; _BLE_HIST_IDX=$_hlen
                    fi
                    (( _BLE_HIST_IDX > 0 )) && {
                        (( _BLE_HIST_IDX-- ))
                        _BLE_INPUT="${_BLE_HIST[$_BLE_HIST_IDX]}"
                        _BLE_CURSOR=${#_BLE_INPUT}
                    }
                    ;;

                ctrl_down)
                    (( _BLE_HIST_IDX == -1 )) && continue
                    local _hlen="${#_BLE_HIST[@]}"
                    (( _BLE_HIST_IDX++ ))
                    if (( _BLE_HIST_IDX >= _hlen )); then
                        _BLE_HIST_IDX=-1; _BLE_INPUT="$_BLE_HIST_SAVED"
                    else
                        _BLE_INPUT="${_BLE_HIST[$_BLE_HIST_IDX]}"
                    fi
                    _BLE_CURSOR=${#_BLE_INPUT}
                    ;;

                ctrlk) _BLE_INPUT="${_BLE_INPUT:0:$_BLE_CURSOR}"; _BLE_HIST_IDX=-1 ;;

                ctrlu)
                    _BLE_INPUT="${_BLE_INPUT:$_BLE_CURSOR}"
                    _BLE_CURSOR=0; _BLE_HIST_IDX=-1
                    ;;

                ctrlw)
                    if (( _BLE_CURSOR > 0 )); then
                        local _b="${_BLE_INPUT:0:$_BLE_CURSOR}" _a="${_BLE_INPUT:$_BLE_CURSOR}"
                        _b="${_b% }"; _b="${_b% *}"
                        _BLE_INPUT="${_b:+${_b} }${_a}"
                        _BLE_CURSOR=${#_BLE_INPUT}; [[ -z "$_b" ]] && _BLE_CURSOR=0
                    fi
                    _BLE_HIST_IDX=-1
                    ;;

                ctrll) clear; printf '%s' "$_BLE_PROMPT" ;;

                ctrlr)
                    _ble_redraw "$_BLE_INPUT" "$_BLE_CURSOR" 0
                    _ble_history_search
                    if [[ -n "$_BLE_SEARCH_RESULT" ]]; then
                        _BLE_INPUT="$_BLE_SEARCH_RESULT"
                        _BLE_CURSOR=${#_BLE_INPUT}
                    fi
                    printf '\r\e[K%s' "$_BLE_PROMPT"
                    ;;

                tab)
                    local _before="${_BLE_INPUT:0:$_BLE_CURSOR}"
                    local _word="${_before##* }"
                    local _pfx="${_before%"$_word"}"
                    _ble_collect_completions "$_BLE_INPUT" "$_word"
                    if (( ${#_BLE_COMP_ITEMS[@]} == 0 )); then
                        printf '\a'
                    elif (( ${#_BLE_COMP_ITEMS[@]} == 1 )); then
                        local _ch="${_BLE_COMP_ITEMS[0]}"
                        _ble_file_suffix_r "$_ch"
                        local _after="${_BLE_INPUT:$_BLE_CURSOR}"
                        local _ins="${_pfx}${_ch}${_BLE_RET}"; [[ -z "$_BLE_RET" ]] && _ins+=" "
                        _BLE_INPUT="${_ins}${_after}"; _BLE_CURSOR=${#_ins}
                    else
                        _ble_redraw "$_BLE_INPUT" "$_BLE_CURSOR" 0
                        _BLE_MENU_RES=""
                        if _ble_menu "${_BLE_COMP_ITEMS[@]}"; then
                            local _ch="$_BLE_MENU_RES"
                            _ble_file_suffix_r "$_ch"
                            local _after="${_BLE_INPUT:$_BLE_CURSOR}"
                            local _ins="${_pfx}${_ch}${_BLE_RET}"; [[ -z "$_BLE_RET" ]] && _ins+=" "
                            _BLE_INPUT="${_ins}${_after}"; _BLE_CURSOR=${#_ins}
                        fi
                        printf '\r\e[K%s' "$_BLE_PROMPT"
                    fi
                    ;;

                enter)
                    _ble_redraw "$_BLE_INPUT" "${#_BLE_INPUT}" 0
                    printf '\n'
                    if [[ -n "$_BLE_INPUT" ]]; then
                        _ble_save_hist "$_BLE_INPUT"
                        _ble_term_restore
                        eval "$_BLE_INPUT"
                        _BLE_LAST_EXIT=$?
                        _ble_term_raw
                        printf '\n'
                    fi
                    break
                    ;;

                ctrlc)
                    _ble_redraw "$_BLE_INPUT" "${#_BLE_INPUT}" 0
                    printf '^C\n'
                    _BLE_LAST_EXIT=130
                    break
                    ;;

                ctrld)
                    if [[ -z "$_BLE_INPUT" ]]; then
                        _ble_redraw "" 0 0
                        printf '\n%sble.sh: Ctrl+D — saindo%s\n' "$_bH" "$_b0"
                        _ble_term_restore
                        trap - INT TERM EXIT
                        _BLE_LOADED=0
                        return 0
                    fi
                    ;;

            esac
        done
    done
}

# ══════════════════════════════════════════════════════════════
# _ble_start — chamado UMA VEZ pelo PROMPT_COMMAND
# Remove a si mesmo do PROMPT_COMMAND e inicia o loop.
# O source retorna imediatamente; o loop começa quando o bash
# está prestes a exibir o primeiro prompt interativo.
# ══════════════════════════════════════════════════════════════
_ble_start() {
    # Remove este hook — o loop assume o controle a partir daqui
    PROMPT_COMMAND="${PROMPT_COMMAND//_ble_start;/}"
    PROMPT_COMMAND="${PROMPT_COMMAND//_ble_start/}"
    _ble_loop
}

# ══════════════════════════════════════════════════════════════
# INSTALAÇÃO — source apenas configura, não bloqueia
# ══════════════════════════════════════════════════════════════

# bash-completion
if [[ -z "${BASH_COMPLETION_VERSINFO:-}" ]]; then
    for _ble_f in /usr/share/bash-completion/bash_completion \
                  /etc/bash_completion \
                  /usr/local/share/bash-completion/bash_completion; do
        [[ -f "$_ble_f" ]] && { source "$_ble_f" 2>/dev/null; break; }
    done
    unset _ble_f
fi

# Configura PROMPT_COMMAND para ativar o loop no primeiro prompt
if [[ -z "${PROMPT_COMMAND:-}" ]]; then
    PROMPT_COMMAND="_ble_start"
elif [[ "$PROMPT_COMMAND" != *"_ble_start"* ]]; then
    PROMPT_COMMAND="_ble_start; ${PROMPT_COMMAND}"
fi