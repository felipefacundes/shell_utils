#!/usr/bin/env bash
# License: GPLv3
# Credits: Felipe Facundes

: <<'DOCUMENTATION'
Script: resize-it
Description: Resize images maintaining aspect ratio or with exact dimensions
Usage: resize-it <image_or_directory> <size_specifier> [output_file]
DOCUMENTATION

# Function to display help
show_help() {
    cat << EOF
Usage: ${0##*/} <image_or_directory> <size_specifier> [output_file]

Resize images maintaining aspect ratio or with exact dimensions.

ARGUMENTS:
  <image_or_directory>    Target image file or directory containing images
  <size_specifier>        Size specification (see below)
  [output_file]           Optional output filename (only for single image input)
                          If omitted, saves as <original_name>-resized.<ext>

SIZE SPECIFIERS:
  [width]                 Resize proportionally to specified width
  [width]x[height]        Resize proportionally to fit within dimensions
  "[width]x[height]!"     Resize exactly to specified dimensions
  [factor]x               Multiply size proportionally (e.g., 2x, 0.5x, 1.5x, 0.9x)
  "[factor]x!"            Multiply size exactly (e.g., "2x!", "0.5x!")
  "[factor]/"             Divide size proportionally (e.g., "2/", "1.5/")
  "[factor]/!"            Divide size exactly (e.g., "2/!", "1.5/!")
  "[fraction]"            Fraction proportionally (e.g., "1/3", "2/3")
  "[fraction]!"           Fraction exactly (e.g., "1/3!", "2/3!")
  "[fraction]x"           Add fraction to size proportionally (e.g., "1/3x")
  "[fraction]x!"          Add fraction to size exactly (e.g., "1/3x!")
  "[fraction]/"           Subtract fraction proportionally (e.g., "1/3/")
  "[fraction]/!"          Subtract fraction exactly (e.g., "1/3/!")

PERCENTAGE SPECIFIERS:
  "[percentage]%"         Resize to percentage proportionally (e.g., "50%")
  "[percentage]%!"        Resize to percentage exactly (e.g., "50%!")
  "[percentage]%+"        Increase by percentage proportionally (e.g., "50%+")
  "[percentage]%+!"       Increase by percentage exactly (e.g., "50%+!")
  "[percentage]%-"        Decrease by percentage proportionally (e.g., "25%-")
  "[percentage]%-!"       Decrease by percentage exactly (e.g., "25%-!")

EXAMPLES:
  ${0##*/} image.jpg 640                        # Resize to width 640px, saves as image-resized.jpg
  ${0##*/} image.jpg 640 output.jpg             # Resize to width 640px, saves as output.jpg
  ${0##*/} directory 640                        # Resize all images in directory (saves to resized/)
  ${0##*/} image.jpg 640x480                    # Resize proportionally to fit
  ${0##*/} image.jpg "640x480!"                 # Resize exactly to 640x480
  ${0##*/} image.jpg 2x                         # Double size proportionally
  ${0##*/} image.jpg 0.5x                       # Half size proportionally
  ${0##*/} image.jpg 0.9x                       # Reduce to 90% proportionally
  ${0##*/} image.jpg 1.5x                       # Increase to 150% proportionally
  ${0##*/} image.jpg "1/2"                      # Resize to 50% proportionally
  ${0##*/} image.jpg "1/2!"                     # Resize to 50% exactly

SUPPORTED IMAGE FORMATS:
  jpg, jpeg, png, gif, bmp, tiff, webp

NOTES:
  - Use quotes around specifiers containing special characters (!, %, /, +, -)
  - For single image: output saved alongside original with -resized suffix (or custom name)
  - For directory: resized images saved in a 'resized' subfolder
  - Original images are always preserved
EOF
}

# Check if ImageMagick's magick command exists
if ! command -v magick &> /dev/null; then
    echo "Error: ImageMagick (magick command) is not installed." >&2
    exit 1
fi

# Check if correct number of arguments is provided
if [ $# -lt 2 ] || [ $# -gt 3 ]; then
    echo "Error: Invalid number of arguments." >&2
    show_help
    exit 1
fi

TARGET="${1%/}"
SIZE_SPEC="$2"
OUTPUT_FILE="${3:-}"   # optional third argument

echo "Debug: Target = $TARGET"
echo "Debug: Size specifier = $SIZE_SPEC"
[ -n "$OUTPUT_FILE" ] && echo "Debug: Output file = $OUTPUT_FILE"

# Progress bar
draw_progress() {
    local current="$1" total="$2" width="${3:-40}"
    local pct=$(( current * 100 / total ))
    local filled=$(( current * width / total ))
    local bar=""
    for ((i=0; i<filled; i++));  do bar+="█"; done
    for ((i=filled; i<width; i++)); do bar+="░"; done
    printf "\r  [%s] %3d%% (%d/%d)" "$bar" "$pct" "$current" "$total"
}

# Function to evaluate fraction and convert to percentage
evaluate_fraction() {
    local fraction="$1"
    local operation="$2"  # "multiply", "divide", or "normal"
    local is_exact="$3"   # "!" for exact, empty for proportional

    echo "Debug evaluate_fraction: fraction=$fraction, operation=$operation, is_exact=$is_exact" >&2

    local percentage

    # Check if it's a fraction (contains /)
    if [[ "$fraction" =~ ^([0-9]+)/([0-9]+)$ ]]; then
        local numerator="${BASH_REMATCH[1]}"
        local denominator="${BASH_REMATCH[2]}"

        if [ "$denominator" -eq 0 ]; then
            echo "Error: Division by zero in fraction: $fraction" >&2
            return 1
        fi

        case "$operation" in
            "multiply")
                percentage=$(echo "scale=6; (1 + ($numerator / $denominator)) * 100" | bc)
                ;;
            "divide")
                local value
                value=$(echo "scale=6; 1 - ($numerator / $denominator)" | bc)
                if (( $(echo "$value < 0" | bc -l) )); then
                    echo "Error: Result would be negative size" >&2
                    return 1
                fi
                percentage=$(echo "scale=6; $value * 100" | bc)
                ;;
            "normal")
                percentage=$(echo "scale=6; ($numerator / $denominator) * 100" | bc)
                ;;
        esac

    elif [[ "$fraction" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
        local num="$fraction"

        case "$operation" in
            "multiply")
                percentage=$(echo "scale=6; $num * 100" | bc)
                ;;
            "divide")
                if (( $(echo "$num == 0" | bc -l) )); then
                    echo "Error: Division by zero" >&2
                    return 1
                fi
                percentage=$(echo "scale=6; 100 / $num" | bc)
                ;;
            "normal")
                percentage=$(echo "scale=6; $num * 100" | bc)
                ;;
        esac
    else
        echo "Error: Invalid fraction format: $fraction" >&2
        return 1
    fi

    percentage=$(echo "$percentage" | sed 's/\.?0*$//; s/\.$//')

    echo "${percentage}%${is_exact}"
    return 0
}

# Function to run magick and report result
run_magick() {
    local input_file="$1"
    local resize_arg="$2"
    local output_file="$3"

    magick "$input_file" -resize "$resize_arg" "$output_file"
    local exit_code=$?

    if [ $exit_code -ne 0 ]; then
        echo "" >&2
        echo "✗ Error resizing: $input_file" >&2
    fi

    return $exit_code
}

# Build the output path for a single-image call
# $1 = input file path, $2 = optional custom output path
make_single_output_path() {
    local input_file="$1"
    local custom_output="$2"

    if [ -n "$custom_output" ]; then
        echo "$custom_output"
    else
        local dir filename base ext
        dir=$(dirname "$input_file")
        filename=$(basename "$input_file")
        ext="${filename##*.}"
        base="${filename%.*}"
        echo "${dir}/${base}-resized.${ext}"
    fi
}

# Function to resize a single image
resize_image() {
    local input_file="$1"
    local resize_param="$2"
    local output_file="$3"   # already resolved by the caller

    echo "Debug resize_image: input_file=$input_file, resize_param=$resize_param"

    echo "Processing: $input_file with specifier: $resize_param"

    if [[ "$resize_param" =~ ^[0-9]+$ ]]; then
        echo "Matched pattern: Simple width"
        run_magick "$input_file" "${resize_param}x" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]+x[0-9]+!$ ]]; then
        echo "Matched pattern: Exact dimensions with !"
        run_magick "$input_file" "$resize_param" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]+x[0-9]+$ ]]; then
        echo "Matched pattern: Proportional dimensions"
        run_magick "$input_file" "$resize_param" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]*\.?[0-9]+x$ ]]; then
        echo "Matched pattern: Decimal multiplication with x"
        local factor="${resize_param%x}"
        local percentage
        percentage=$(echo "scale=2; $factor * 100" | bc | sed 's/\.00$//')
        echo "Resizing to ${percentage}% proportionally"
        run_magick "$input_file" "${percentage}%" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]*\.?[0-9]+x!$ ]]; then
        echo "Matched pattern: Decimal multiplication exact with x!"
        local factor="${resize_param%x!}"
        local percentage
        percentage=$(echo "scale=2; $factor * 100" | bc | sed 's/\.00$//')
        echo "Resizing to ${percentage}% exactly"
        run_magick "$input_file" "${percentage}%!" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]+/[0-9]+x$ ]]; then
        echo "Matched pattern: Fraction multiplication"
        local fraction="${resize_param%x}"
        local percentage
        percentage=$(evaluate_fraction "$fraction" "multiply" "") || return 1
        echo "Resizing with fraction multiplication: $percentage"
        run_magick "$input_file" "$percentage" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]+/[0-9]+x!$ ]]; then
        echo "Matched pattern: Fraction multiplication exact"
        local fraction="${resize_param%x!}"
        local percentage
        percentage=$(evaluate_fraction "$fraction" "multiply" "!") || return 1
        echo "Resizing with exact fraction multiplication: $percentage"
        run_magick "$input_file" "$percentage" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]*\.?[0-9]+/$ ]]; then
        echo "Matched pattern: Decimal division with /"
        local factor="${resize_param%/}"
        if (( $(echo "$factor == 0" | bc -l) )); then
            echo "Error: Division by zero" >&2
            return 1
        fi
        local percentage
        percentage=$(echo "scale=2; 100 / $factor" | bc | sed 's/\.00$//')
        echo "Resizing to ${percentage}% proportionally (division)"
        run_magick "$input_file" "${percentage}%" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]*\.?[0-9]+/!$ ]]; then
        echo "Matched pattern: Decimal division exact with /!"
        local factor="${resize_param%/!}"
        if (( $(echo "$factor == 0" | bc -l) )); then
            echo "Error: Division by zero" >&2
            return 1
        fi
        local percentage
        percentage=$(echo "scale=2; 100 / $factor" | bc | sed 's/\.00$//')
        echo "Resizing to ${percentage}% exactly (division)"
        run_magick "$input_file" "${percentage}%!" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]+/[0-9]+$ ]]; then
        echo "Matched pattern: Simple fraction"
        local percentage
        percentage=$(evaluate_fraction "$resize_param" "normal" "") || return 1
        echo "Resizing with fraction: $percentage"
        run_magick "$input_file" "$percentage" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]+/[0-9]+!$ ]]; then
        echo "Matched pattern: Simple fraction exact"
        local fraction="${resize_param%!}"
        local percentage
        percentage=$(evaluate_fraction "$fraction" "normal" "!") || return 1
        echo "Resizing with exact fraction: $percentage"
        run_magick "$input_file" "$percentage" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]+/[0-9]+/$ ]]; then
        echo "Matched pattern: Fraction subtraction with /"
        local fraction="${resize_param%/}"
        local percentage
        percentage=$(evaluate_fraction "$fraction" "divide" "") || return 1
        echo "Resizing with fraction subtraction: $percentage"
        run_magick "$input_file" "$percentage" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]+/[0-9]+/!$ ]]; then
        echo "Matched pattern: Fraction subtraction exact with /!"
        local fraction="${resize_param%/!}"
        local percentage
        percentage=$(evaluate_fraction "$fraction" "divide" "!") || return 1
        echo "Resizing with exact fraction subtraction: $percentage"
        run_magick "$input_file" "$percentage" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]+(\.[0-9]+)?%!$ ]]; then
        echo "Matched pattern: Percentage with !"
        local percentage="${resize_param%!}"
        echo "Resizing to $percentage exactly"
        run_magick "$input_file" "$percentage" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]+(\.[0-9]+)?%$ ]]; then
        echo "Matched pattern: Simple percentage"
        echo "Resizing to $resize_param proportionally"
        run_magick "$input_file" "$resize_param" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]+%\+!$ ]]; then
        echo "Matched pattern: Increase by percentage with !"
        local base_percent="${resize_param%+!}"
        base_percent="${base_percent%\%}"
        local new_percent=$(( 100 + base_percent ))
        echo "Increasing by ${base_percent}% exactly (to ${new_percent}%)"
        run_magick "$input_file" "${new_percent}%!" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]+%\+$ ]]; then
        echo "Matched pattern: Increase by percentage"
        local base_percent="${resize_param%+}"
        base_percent="${base_percent%\%}"
        local new_percent=$(( 100 + base_percent ))
        echo "Increasing by ${base_percent}% proportionally (to ${new_percent}%)"
        run_magick "$input_file" "${new_percent}%" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]+%\-!$ ]]; then
        echo "Matched pattern: Decrease by percentage with !"
        local base_percent="${resize_param%-!}"
        base_percent="${base_percent%\%}"
        local new_percent=$(( 100 - base_percent ))
        echo "Decreasing by ${base_percent}% exactly (to ${new_percent}%)"
        run_magick "$input_file" "${new_percent}%!" "$output_file"

    elif [[ "$resize_param" =~ ^[0-9]+%\-$ ]]; then
        echo "Matched pattern: Decrease by percentage"
        local base_percent="${resize_param%-}"
        base_percent="${base_percent%\%}"
        local new_percent=$(( 100 - base_percent ))
        echo "Decreasing by ${base_percent}% proportionally (to ${new_percent}%)"
        run_magick "$input_file" "${new_percent}%" "$output_file"

    else
        echo "Error: No pattern matched for: $resize_param" >&2
        echo "Please check the size specifier format." >&2
        return 1
    fi

    return $?
}

# ---------------------------------------------------------------------------
# Main logic
# ---------------------------------------------------------------------------

if [ -f "$TARGET" ]; then
    # Reject the third argument when targeting a directory (guard for typos)
    if file "$TARGET" | grep -qi "image"; then
        output_path=$(make_single_output_path "$TARGET" "$OUTPUT_FILE")
        echo "Processing single image: $TARGET"
        resize_image "$TARGET" "$SIZE_SPEC" "$output_path"
        if [ $? -eq 0 ]; then
            draw_progress 1 1
            printf "\n"
            echo "✓ Resized image saved to: $output_path"
        fi
    else
        echo "Error: $TARGET is not a valid image file." >&2
        exit 1
    fi

elif [ -d "$TARGET" ]; then
    # Third argument is not meaningful for directories — warn and ignore
    if [ -n "$OUTPUT_FILE" ]; then
        echo "Warning: Output filename argument is ignored when targeting a directory." >&2
    fi

    echo "Processing directory: $TARGET"

    mapfile -d '' IMAGE_ARRAY < <(find "$TARGET" -maxdepth 1 -type f \( \
        -iname "*.jpg"  -o \
        -iname "*.jpeg" -o \
        -iname "*.png"  -o \
        -iname "*.gif"  -o \
        -iname "*.bmp"  -o \
        -iname "*.tiff" -o \
        -iname "*.tif"  -o \
        -iname "*.webp" \
    \) -print0)

    if [ ${#IMAGE_ARRAY[@]} -eq 0 ]; then
        echo "Error: No image files found in directory: $TARGET" >&2
        exit 1
    fi

    TOTAL=${#IMAGE_ARRAY[@]}
    echo "Found ${TOTAL} image(s) to resize."
    echo ""

    RESIZED_DIR="${TARGET}/resized"
    mkdir -p "$RESIZED_DIR"

    SUCCESS_COUNT=0
    FAIL_COUNT=0
    CURRENT=0

    for image in "${IMAGE_ARRAY[@]}"; do
        (( CURRENT++ ))
        # For directory mode, build the output path inside resized/
        dir_output="${RESIZED_DIR}/$(basename "$image")"
        if resize_image "$image" "$SIZE_SPEC" "$dir_output"; then
            (( SUCCESS_COUNT++ ))
        else
            (( FAIL_COUNT++ ))
        fi
        draw_progress "$CURRENT" "$TOTAL"
    done

    printf "\n"
    echo "================================="
    echo "Summary:"
    echo "  Successfully resized: $SUCCESS_COUNT"
    echo "  Failed: $FAIL_COUNT"
    echo "Resized images saved to: $RESIZED_DIR"

else
    echo "Error: $TARGET is not a valid file or directory." >&2
    exit 1
fi
