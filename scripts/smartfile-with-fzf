#!/usr/bin/env bash
# License: GPLv3
# Credits: Felipe Facundes

: <<'DOCUMENTATION'

SMARTFILE - Intelligent File Opening
===================================

OVERVIEW:
smartfile is a smart file opener that intercepts command-not-found errors
and tries to open files with xdg-open using fuzzy search.

FEATURES:
• Intercepts command-not-found and tries to open as file
• Fuzzy search through FILESYSTEM only (not database)
• Interactive selection with fzf + preview (shows files from current directory)
• Alt+f shows only files previously opened from current directory (regional database)
• Single database file stores all directories history
• Regional database: each directory shows only its own opened files
• Opens files with xdg-open
• Maintains history database with size limit
• All searches are restricted to the current working directory
• Handles filenames with spaces without requiring escaping

USAGE:
  Just type any filename as a command - smartfile will intercept it
  Or use explicitly: smartfile [FILE]
  Alt+f - Interactive mode (shows regional files from current directory)

EXAMPLES:
  documento.pdf      # Opens with xdg-open (if file exists or fuzzy match)
  relatorio         # Fuzzy finds and opens relatorio_final.pdf (only in current directory)
  Parallax 2.5D.txt # Opens file with spaces in name without escaping
  $LS_COLORS        # Variable expansion works normally
  smartfile --       # Interactive mode (shows regional database)

DATABASE BEHAVIOR:
  • Regional database: When pressing Alt+f, only files that were opened from
    the current working directory are displayed
  • Navigate to different directories to see their specific history
  • Single database file stores all paths with absolute references
  • History persists across sessions
  • All file searches are restricted to the current working directory

DOCUMENTATION

# Smartfile configuration
export SMARTFILE_LOG=~/.smartfile.log
export SMARTFILE_HIST_SIZE=${SMARTFILE_HIST_SIZE:-"100"}
export SMARTFILE_HIST_IGNORE=${SMARTFILE_HIST_IGNORE:-".git|*.tmp|*.log|*.swp"}
export SMARTFILE_CONFIG_FOLDER=${SMARTFILE_CONFIG_FOLDER:-"$HOME/.shell_utils_configs/smartfile"}
export SMARTFILE_CONFIG="$SMARTFILE_CONFIG_FOLDER/smartfile.conf"
export SMARTFILE_HIST_FILE=${SMARTFILE_HIST_FILE:-"file_history.db"}

[[ ! -d "$SMARTFILE_CONFIG_FOLDER" ]] && mkdir -p "$SMARTFILE_CONFIG_FOLDER" >/dev/null 2>&1

if [[ ! -f "$SMARTFILE_CONFIG" ]]; then
cat <<'EOF' | tee "$SMARTFILE_CONFIG" &>/dev/null
# 0 = disable smartfile, 1 = enable smartfile without fuzzy search, 2 = enable with fuzzy search
export SMARTFILE=2
EOF
fi

# shellcheck source=/dev/null
[[ -f "$SMARTFILE_CONFIG" ]] && source "$SMARTFILE_CONFIG"

# Check dependencies
if ! command -v fzf &> /dev/null; then
    echo "Can't use smartfile : missing fzf" | tee "$SMARTFILE_LOG" >/dev/null
    return 2>/dev/null
fi

# Smartfile functions
function __smartfile_open() {
    local lookUpPath="${*}"
    local selectedEntry=""

    [[ ! -f "${SMARTFILE_CONFIG_FOLDER}/${SMARTFILE_HIST_FILE}" ]] && __smartfile_database_reset

    # Remove surrounding quotes if present
    lookUpPath=$(echo "$lookUpPath" | sed -e 's/^"//' -e 's/"$//' -e "s/^'//" -e "s/'$//")

    # Try to open the exact input first (handles files with spaces)
    # Check if the file exists relative to current directory
    if [[ -f "${PWD}/${lookUpPath}" ]] && [[ -r "${PWD}/${lookUpPath}" ]]; then
        __smartfile_open_path "${PWD}/${lookUpPath}"
        return $?
    fi
    
    # Check if it's an absolute path
    if [[ -f "${lookUpPath}" ]] && [[ -r "${lookUpPath}" ]]; then
        __smartfile_open_path "${lookUpPath}"
        return $?
    fi

    # Fuzzy search mode (only for interactive mode with --)
    if [[ "${lookUpPath}" = "--" ]]; then
        # For interactive mode, show only files from current directory (regional database)
        local current_dir="${PWD}"
        selectedEntry=$(__smartfile_database_search_by_dir "${current_dir}" | __smartfile_choose_file)
    else
        # Only search filesystem in CURRENT DIRECTORY, NOT database
        local fs_results
        fs_results=$(__smartfile_filesystem_search "${lookUpPath}" 2>/dev/null)
        
        if [[ -n "$fs_results" ]]; then
            local line_count; line_count=$(echo "$fs_results" | wc -l)
            local fzfSelect1=""
            [[ $line_count -eq 1 ]] && fzfSelect1="--select-1"
            
            selectedEntry=$(echo "$fs_results" | __smartfile_choose_file "$fzfSelect1")
        fi
    fi
    
    if [[ -n "${selectedEntry}" ]]; then
        __smartfile_open_path "${selectedEntry}"
    fi
}

function __smartfile_choose_file() {
    local fzfSelect1="${1}"
    local fzfPreview=""
    local cmdPreview; cmdPreview=$(command -v bat batcat cat 2>/dev/null | awk 'NR==1 {print}')
    
    local errMessage="no such file [ {} ]'\n\n'hint: run '\033[1m'smartfile --cleanup'\033[22m'"
    
    case "${cmdPreview}" in
        */bat|*/batcat)
            fzfPreview='[ -f {} ] && '${cmdPreview}' --color=always --line-range :50 {} || echo -e '"${errMessage}"''
            ;;
        *)
            fzfPreview='[ -f {} ] && echo "=== File: {} ===" ; '${cmdPreview}' {} || echo -e '"${errMessage}"''
            ;;
    esac
    
    # Read all input lines
    local input_lines=()
    while IFS= read -r line; do
        input_lines+=("$line")
    done
    
    # Create display list with only basenames using ##*/ parameter expansion
    local display_list=()
    for fullpath in "${input_lines[@]}"; do
        display_list+=("${fullpath##*/}")
    done
    
    # Use fzf to select from display list
    local selected_display
    if [[ -n "$TERMUX_VERSION" ]]; then
        selected_display=$(printf '%s\n' "${display_list[@]}" | fzf ${fzfSelect1} --delimiter="\n" --layout="reverse" 2>/dev/tty)
    else
        selected_display=$(printf '%s\n' "${display_list[@]}" | fzf ${fzfSelect1} --delimiter="\n" --layout="reverse" --height="40%" \
            --preview="${fzfPreview}" 2>/dev/tty)
    fi
    
    # Find the corresponding full path
    if [[ -n "$selected_display" ]]; then
        for i in "${!display_list[@]}"; do
            if [[ "${display_list[$i]}" == "$selected_display" ]]; then
                echo "${input_lines[$i]}"
                return 0
            fi
        done
    fi
}

function __smartfile_open_path() {
    local file="${1}"

    # Resolve to absolute path if relative
    if [[ ! "$file" =~ ^/ ]]; then
        file="${PWD}/${file}"
    fi
    # Normalize path
    file=$(realpath "${file}" 2>/dev/null || echo "${file}")

    if [[ -f "${file}" ]] && [[ -r "${file}" ]]; then
        if { xdg-open "${file}" 2>/dev/null & disown; } &>/dev/null; then
            __smartfile_database_save_path "${file}"
            return 0
        else
            __smartfile_database_delete_path "${file}"
            return 1
        fi
    else
        echo "smartfile: file '${file}' does not exist or is not readable" >&2
        __smartfile_database_delete_path "${file}"
        return 1
    fi
}

function __smartfile_filesystem_search() {
    local searchString="${1}"
    local cmdFinder; cmdFinder=$(command -v fdfind fd find 2>/dev/null | awk 'NR==1 {print}')

    # Always search only in current directory (PWD)
    local searchPath="${PWD}"
    
    # Don't search if searchString is empty or just dots
    if [[ -z "${searchString}" || "${searchString}" =~ ^\.+$ ]]; then
        return 0
    fi
    
    # Remove leading path if user typed a path, we only want the filename part
    searchString=$(basename -- "${searchString}")
    
    case "${cmdFinder}" in
        */fd*)
            "${cmdFinder}" --hidden --no-ignore-vcs "${searchString}" --color=never --follow --max-depth=1 --type=file --exclude ".git/" "${searchPath}" --exec realpath --no-symlinks 2>/dev/null
            ;;
        *)
            find "${searchPath}" -maxdepth 1 -type f ! -path '*\.git/*' -iname '*'"${searchString}"'*' -exec realpath --no-symlinks {} + 2>/dev/null
            ;;
    esac
}

function __smartfile_database_search() {
    local searchString="${1}"
    
    # If search string is empty, return all history
    if [[ -z "${searchString}" ]]; then
        cat "${SMARTFILE_CONFIG_FOLDER}/${SMARTFILE_HIST_FILE}" 2>/dev/null
        return 0
    fi
    
    # Escape special regex characters
    local escaped_string
    escaped_string=$(echo "${searchString}" | sed -e 's/\./\\./g' -e 's/\//\\//g')
    
    # Only create pattern if escaped_string is not empty
    if [[ -n "${escaped_string}" ]]; then
        grep -i "${escaped_string}" "${SMARTFILE_CONFIG_FOLDER}/${SMARTFILE_HIST_FILE}" 2>/dev/null
    else
        cat "${SMARTFILE_CONFIG_FOLDER}/${SMARTFILE_HIST_FILE}" 2>/dev/null
    fi
}

function __smartfile_database_search_by_dir() {
    local target_dir="${1}"
    local escaped_dir
    
    # Escape special characters for grep
    escaped_dir=$(echo "${target_dir}" | sed 's/[.[\*^$()+?{|]/\\&/g')
    
    # Return files that are in the specified directory (regional database)
    grep "^${escaped_dir}/[^/]*$" "${SMARTFILE_CONFIG_FOLDER}/${SMARTFILE_HIST_FILE}" 2>/dev/null
}

function __smartfile_database_save_path() {
    local file="${1}"
    local iCounter=0
    local ignoreItem=""
    local ignoreItemFound=""

    [[ ! -f "${file}" ]] && return

    # Ensure we have absolute path
    if [[ ! "$file" =~ ^/ ]]; then
        file=$(realpath "${file}" 2>/dev/null || echo "${PWD}/${file}")
    fi

    # Check ignore list
    while true; do
        ((iCounter++))
        ignoreItem=$(echo "${SMARTFILE_HIST_IGNORE}|" | cut -d'|' -f${iCounter})
        [[ -z "${ignoreItem}" ]] && break

        ignoreItemFound=$(echo "${file}" | grep -E "${ignoreItem}" 2>/dev/null)
        if [[ -n "${ignoreItemFound}" ]]; then
            __smartfile_database_delete_path "${file}"
            return
        fi
    done

    __smartfile_database_delete_path "${file}"
    sed -i "1 s:^:${file}\n:" "${SMARTFILE_CONFIG_FOLDER}/${SMARTFILE_HIST_FILE}"
    sed -i $((SMARTFILE_HIST_SIZE + 1))',$ d' "${SMARTFILE_CONFIG_FOLDER}/${SMARTFILE_HIST_FILE}"
}

function __smartfile_database_delete_path() {
    local file="${1}"
    # Escape special characters for sed
    local escaped_file; escaped_file=$(echo "${file}" | sed 's/[.[\*^$()+?{|]/\\&/g')
    sed -i "\:^${escaped_file}$:d" "${SMARTFILE_CONFIG_FOLDER}/${SMARTFILE_HIST_FILE}" 2>/dev/null
}

function __smartfile_database_cleanup() {
    local fTmp; fTmp=$(mktemp 2>/dev/null)
    local line=""
    local iCounter=0
    local bIgnore="false"
    local ignoreItem=""
    local ignoreItemFound=""

    [[ ! -f "${SMARTFILE_CONFIG_FOLDER}/${SMARTFILE_HIST_FILE}" ]] && __smartfile_database_reset

    while IFS= read -r line || [[ -n "${line}" ]]; do
        if [[ -f "${line}" ]]; then
            iCounter=0
            bIgnore="false"

            while true; do
                ((iCounter++))
                ignoreItem=$(echo "${SMARTFILE_HIST_IGNORE}|" | cut -d'|' -f${iCounter})
                [[ -z "${ignoreItem}" ]] && break

                ignoreItemFound=$(echo "${line}" | grep -E "${ignoreItem}" 2>/dev/null)
                if [[ -n "${ignoreItemFound}" ]]; then
                    bIgnore="true"
                    break
                fi
            done

            [[ "${bIgnore}" = "false" ]] && echo "${line}" | tee -a "${fTmp}" &>/dev/null
        fi
    done < "${SMARTFILE_CONFIG_FOLDER}/${SMARTFILE_HIST_FILE}"

    awk '!seen[$0]++' "${fTmp}" | tee "${SMARTFILE_CONFIG_FOLDER}/${SMARTFILE_HIST_FILE}" &>/dev/null
    sed -i '/^[[:blank:]]*$/ d' "${SMARTFILE_CONFIG_FOLDER}/${SMARTFILE_HIST_FILE}"
    [[ $(wc -l < "${SMARTFILE_CONFIG_FOLDER}/${SMARTFILE_HIST_FILE}") -eq 0 ]] && __smartfile_database_reset
    rm -f "${fTmp}"
}

function __smartfile_database_reset() {
    mkdir -p "${SMARTFILE_CONFIG_FOLDER}" >/dev/null 2>&1
    echo "" | tee "${SMARTFILE_CONFIG_FOLDER}/${SMARTFILE_HIST_FILE}" &>/dev/null
}

# Main smartfile function
function smartfile() {
    case "$1" in
        --help|-h)
            echo "Usage: smartfile [FILE]"
            echo "       smartfile --         (interactive mode with regional database)"
            echo "       smartfile --cleanup  (cleanup database)"
            echo "       smartfile --reset    (reset database)"
            echo ""
            echo "Database is regional: Alt+f shows only files from current directory"
            echo "Each directory maintains its own history within a single database file"
            echo "All file searches are restricted to the current working directory"
            echo "Files with spaces in names are handled automatically"
            ;;
        --cleanup)
            __smartfile_database_cleanup
            ;;
        --reset)
            __smartfile_database_reset
            ;;
        --)
            __smartfile_open "--"
            ;;
        *)
            __smartfile_open "$@"
            ;;
    esac
}

# Command not found hook for bash
if [[ -n "$BASH_VERSION" ]]; then
    command_not_found_handle() {
        # If the input contains only alphanumeric, underscores, dots, slashes, spaces, or hyphens, it might be a file
        # If it contains special chars like =, :, etc., it's probably a variable expansion - show it
        if [[ "$*" =~ ^[a-zA-Z0-9._/\\\ -]+$ ]]; then
            smartfile "$@" 2>/dev/null || return 127
        else
            # For variable expansions and other special content, show it as text
            echo "$*"
            return 127
        fi
    }
    
    # Key binding for Alt+f
    bind -r '\ef' 2>/dev/null || true
    bind '"\ef":"smartfile --\n"' 2>/dev/null || true
fi

# Command not found hook for zsh
if [[ -n "$ZSH_VERSION" ]]; then
    command_not_found_handler() {
        # If the input contains only alphanumeric, underscores, dots, slashes, spaces, or hyphens, it might be a file
        # If it contains special chars like =, :, etc., it's probably a variable expansion - show it
        if [[ "$*" =~ ^[a-zA-Z0-9._/\\\ -]+$ ]]; then
            smartfile "$@" 2>/dev/null || return 127
        else
            # For variable expansions and other special content, show it as text
            echo "$*"
            return 127
        fi
    }
    
    # Key binding for Alt+f
    bindkey -s '^[f' 'smartfile --\n' 2>/dev/null || true
fi

# Bash completion
if [[ -n "$BASH_VERSION" ]]; then
    _smartfile_completion() {
        local cur="${COMP_WORDS[COMP_CWORD]}"
        COMPREPLY=( $(compgen -f -- "$cur") )
    }
    complete -o filenames -o nospace -F _smartfile_completion smartfile 2>/dev/null || true
fi

# Zsh completion
if [[ -n "$ZSH_VERSION" ]]; then
    compdef _files smartfile 2>/dev/null || true
fi