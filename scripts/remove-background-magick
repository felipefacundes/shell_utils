#!/usr/bin/env bash
# License: GPLv3
# Credits: Felipe Facundes
# Complete background removal script with multiple options

: <<'DOCUMENTATION'
Background Removal Bash Utility

A Bash script that uses ImageMagick to remove specific color backgrounds from images.
Supports multiple removal methods and adjustable fuzz tolerance.

Key Features:
1.  Batch image processing (PNG, JPG, JPEG, SVG, WEBP, BMP, AVIF)
2.  Output always saved as PNG (preserves transparency) in batch mode
3.  Single file mode: output name is optional; defaults to <name>-removed-background.png
4.  Single file mode: if output name is given without extension, a transparency-capable
    extension is required (png, webp, avif, svg)
5.  Multiple removal methods: simple, fuzz, mask, morph, or precise
6.  Adjustable fuzz tolerance via argument
7.  Clean edge handling
8.  Two new highly efficient methods for complex backgrounds
9.  Dependency check (ImageMagick) on startup
10. Hex color validation before processing
11. Dry-run mode: shows what would be done without executing
12. Recursive directory processing (-r / --recursive)
13. Skip existing files (--skip-existing) or force overwrite (--overwrite)
14. Progress bar / percentage in batch mode
15. Error log saved to file in batch mode
16. Multiple colors removal in one pass (--colors "hex1,hex2,...")
17. Auto-trim transparent borders after removal (--trim)
18. Parallel processing in batch mode (--jobs N)
19. Edge feathering / smoothing after removal (--feather N)
20. Batch preview: process first image and ask for confirmation before the rest
DOCUMENTATION

# ─────────────────────────────────────────────
# Dependency check
# ─────────────────────────────────────────────
if ! command -v magick &>/dev/null; then
    echo "Error: ImageMagick ('magick') not found."
    echo "Install it via your package manager, e.g.:"
    echo "  sudo apt install imagemagick   # Debian/Ubuntu"
    echo "  sudo dnf install imagemagick   # Fedora"
    echo "  brew install imagemagick       # macOS"
    exit 1
fi

# Global boolean: true = single-file mode, false = batch/directory mode
SINGLE_FILE_MODE=false

# Transparency-capable extensions (for single file output validation)
TRANSPARENCY_EXTS=("png" "webp" "avif" "svg")

# ─────────────────────────────────────────────
# Display help
# ─────────────────────────────────────────────
show_help() {
    cat <<EOF
Usage (batch):       ${0##*/} <input_dir> <output_dir> <color_hex> [options]
Usage (single file): ${0##*/} <input_file> [output_file] <color_hex> [options]

Required arguments:
  <input_dir>      Directory with input images  (batch mode)
  <input_file>     Single image file            (single-file mode)
  <output_dir>     Directory for processed images (batch mode)
  [output_file]    Output file path (optional in single-file mode).
                   If omitted: <input_name>-removed-background.png
                   If provided without extension: must end with png, webp, avif or svg
  <color_hex>      Color to remove (format: RRGGBB or #RRGGBB)
                   Use --colors for multiple colors.

Supported input formats: PNG, JPG, JPEG, SVG, WEBP, BMP, AVIF
Batch output format: always PNG (to preserve transparency)

Optional arguments:
  -m, --method METHOD      Removal method: simple, fuzz (default), mask, morph, precise
  -f, --fuzz PERCENT       Fuzz tolerance percentage (default: 15)
      --colors "h1,h2,..."  Remove multiple colors in one pass (comma-separated hex values)
      --trim               Auto-trim transparent borders after removal
      --feather N          Feather/smooth edges by N pixels after removal (default: 0)
  -r, --recursive          Process subdirectories recursively (batch mode only)
      --skip-existing      Skip output files that already exist
      --overwrite          Overwrite existing output files (default behavior)
      --dry-run            Show what would be done without executing
      --preview            Process first image only and ask for confirmation (batch mode)
  -j, --jobs N             Number of parallel jobs in batch mode (default: 1)
      --log FILE           Save error log to FILE (batch mode; default: no log file)
  -h, --help               Show this help message

Examples (batch):
  ${0##*/} input output d0d0d0                           # Default method, 15% fuzz
  ${0##*/} input output #FF0000 -m simple                # Simple transparent method
  ${0##*/} input output 00FF00 -m fuzz -f 20             # Fuzz with 20% tolerance
  ${0##*/} input output 0000FF -m mask                   # Mask method
  ${0##*/} input output d0d0d0 -m morph                  # Morphological method
  ${0##*/} input output d0d0d0 -m precise                # Precise method
  ${0##*/} input output d0d0d0 --colors "d0d0d0,ffffff"  # Remove two colors
  ${0##*/} input output d0d0d0 --trim --feather 2        # Trim + smooth edges
  ${0##*/} input output d0d0d0 -j 4                      # 4 parallel jobs
  ${0##*/} input output d0d0d0 --skip-existing           # Skip already processed
  ${0##*/} input output d0d0d0 --dry-run                 # Preview without running
  ${0##*/} input output d0d0d0 --preview                 # Confirm after first image
  ${0##*/} input output d0d0d0 -r                        # Recurse subdirectories

Examples (single file):
  ${0##*/} photo.jpg d0d0d0                              # Output: photo-removed-background.png
  ${0##*/} photo.jpg result.png d0d0d0                   # Output: result.png
  ${0##*/} photo.jpg result.webp d0d0d0 -m morph         # morph method
  ${0##*/} photo.jpg result.png d0d0d0 --feather 3       # smooth edges

Method descriptions:
  simple:   magick input -transparent COLOR output (fast, basic)
  fuzz:     magick input -fuzz X% -transparent COLOR output (recommended)
  mask:     Creates a proper alpha mask for cleaner edges
  morph:    Uses morphological operations for better edge handling
  precise:  Multi-step method with blur and threshold for complex backgrounds
EOF
}

# Check minimum arguments
if [ "$#" -lt 2 ]; then
    show_help
    exit 1
fi

# ─────────────────────────────────────────────
# Detect mode: single-file or batch/directory
# ─────────────────────────────────────────────
if [[ -f "$1" ]]; then
    SINGLE_FILE_MODE=true
elif [[ -d "$1" ]]; then
    SINGLE_FILE_MODE=false
else
    ext_check="${1##*.}"
    if [[ "$ext_check" =~ ^(png|jpg|jpeg|svg|webp|bmp|avif|PNG|JPG|JPEG|SVG|WEBP|BMP|AVIF)$ ]]; then
        echo "Error: Input file '$1' not found."
        exit 1
    else
        echo "Error: Input path '$1' is neither an existing file nor a directory."
        exit 1
    fi
fi

# ─────────────────────────────────────────────
# Helper: check if a file is a supported image
# ─────────────────────────────────────────────
is_supported_image() {
    local file="$1"
    local mime
    mime=$(file --brief --mime-type "$file" 2>/dev/null)
    case "$mime" in
        image/png|image/jpeg|image/svg+xml|image/webp|image/bmp|image/avif|image/gif)
            return 0 ;;
    esac
    local ext="${file##*.}"
    ext="${ext,,}"
    case "$ext" in
        png|jpg|jpeg|svg|webp|bmp|avif)
            return 0 ;;
    esac
    return 1
}

# ─────────────────────────────────────────────
# Helper: check if extension supports transparency
# ─────────────────────────────────────────────
is_transparency_ext() {
    local ext="${1,,}"
    for e in "${TRANSPARENCY_EXTS[@]}"; do
        [[ "$ext" == "$e" ]] && return 0
    done
    return 1
}

# ─────────────────────────────────────────────
# Helper: validate a hex color string
# ─────────────────────────────────────────────
validate_hex_color() {
    local color="${1/#\#/}"   # strip leading #
    if [[ ! "$color" =~ ^([0-9A-Fa-f]{3}|[0-9A-Fa-f]{6})$ ]]; then
        echo "Error: '$1' is not a valid hex color. Use format RRGGBB or #RRGGBB."
        exit 1
    fi
}

# ─────────────────────────────────────────────
# Default option values
# ─────────────────────────────────────────────
METHOD="fuzz"
FUZZ_PERCENT="15%"
EXTRA_COLORS=()       # additional colors beyond the primary one
DO_TRIM=false
FEATHER=0
RECURSIVE=false
SKIP_EXISTING=false
DRY_RUN=false
PREVIEW=false
JOBS=1
LOG_FILE=""

# ─────────────────────────────────────────────
# Parse positional arguments per mode
# ─────────────────────────────────────────────
if $SINGLE_FILE_MODE; then
    input_file="$1"
    shift

    if ! is_supported_image "$input_file"; then
        echo "Error: '$input_file' does not appear to be a supported image file."
        echo "Supported formats: PNG, JPG, JPEG, SVG, WEBP, BMP, AVIF"
        exit 1
    fi

    output_file=""
    color_input=""

    if [[ -n "$1" ]] && ! [[ "$1" =~ ^-{1,2} ]]; then
        if [[ "$1" =~ ^#?([0-9A-Fa-f]{3}|[0-9A-Fa-f]{6})$ ]]; then
            color_input="$1"
            shift
        else
            output_file="$1"
            shift
            if [[ -z "$1" ]] || [[ "$1" =~ ^-{1,2} ]]; then
                echo "Error: Color hex is required."
                show_help
                exit 1
            fi
            color_input="$1"
            shift
        fi
    else
        echo "Error: Color hex is required."
        show_help
        exit 1
    fi

    if [[ -z "$output_file" ]]; then
        input_basename=$(basename -- "$input_file")
        input_noext="${input_basename%.*}"
        input_dir_part=$(dirname -- "$input_file")
        output_file="${input_dir_part}/${input_noext}-removed-background.png"
    else
        out_ext="${output_file##*.}"
        if [[ "$output_file" == "$out_ext" ]] || [[ -z "$out_ext" ]]; then
            echo "Error: Output file '$output_file' has no extension."
            echo "Please provide one of: png, webp, avif, svg"
            exit 1
        fi
        if ! is_transparency_ext "$out_ext"; then
            echo "Error: Output extension '.$out_ext' does not support transparency."
            echo "Please use one of: png, webp, avif, svg"
            exit 1
        fi
    fi

    out_dir=$(dirname -- "$output_file")

else
    if [ "$#" -lt 3 ]; then
        show_help
        exit 1
    fi
    input_directory="$1"
    output_directory="$2"
    color_input="$3"
    shift 3
fi

# ─────────────────────────────────────────────
# Parse optional arguments (shared)
# ─────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
    case $1 in
        -m|--method)
            METHOD="$2"; shift 2 ;;
        -f|--fuzz)
            FUZZ_PERCENT="${2//%/}%"; shift 2 ;;
        --colors)
            IFS=',' read -ra EXTRA_COLORS <<< "$2"; shift 2 ;;
        --trim)
            DO_TRIM=true; shift ;;
        --feather)
            FEATHER="$2"; shift 2 ;;
        -r|--recursive)
            RECURSIVE=true; shift ;;
        --skip-existing)
            SKIP_EXISTING=true; shift ;;
        --overwrite)
            SKIP_EXISTING=false; shift ;;
        --dry-run)
            DRY_RUN=true; shift ;;
        --preview)
            PREVIEW=true; shift ;;
        -j|--jobs)
            JOBS="$2"; shift 2 ;;
        --log)
            LOG_FILE="$2"; shift 2 ;;
        -h|--help)
            show_help; exit 0 ;;
        *)
            echo "Unknown option: $1"
            show_help; exit 1 ;;
    esac
done

# ─────────────────────────────────────────────
# Validate shared options
# ─────────────────────────────────────────────
if [[ ! "$METHOD" =~ ^(simple|fuzz|mask|morph|precise)$ ]]; then
    echo "Error: Method must be 'simple', 'fuzz', 'mask', 'morph', or 'precise'"
    exit 1
fi

if ! [[ "$JOBS" =~ ^[1-9][0-9]*$ ]]; then
    echo "Error: --jobs must be a positive integer."
    exit 1
fi

if ! [[ "$FEATHER" =~ ^[0-9]+$ ]]; then
    echo "Error: --feather must be a non-negative integer."
    exit 1
fi

# Normalize and validate primary color
if [[ $color_input != \#* ]]; then
    color_hex="#$color_input"
else
    color_hex="$color_input"
fi
validate_hex_color "$color_hex"

# Normalize and validate extra colors
normalized_extra_colors=()
for c in "${EXTRA_COLORS[@]}"; do
    [[ $c != \#* ]] && c="#$c"
    validate_hex_color "$c"
    normalized_extra_colors+=("$c")
done

# ─────────────────────────────────────────────
# Cleanup on interrupt
# ─────────────────────────────────────────────
cleanup_temp() {
    if $SINGLE_FILE_MODE; then
        [[ -d "${out_dir}/temp_$$" ]] && rm -rf "${out_dir}/temp_$$" 2>/dev/null
    else
        [[ -d "$output_directory/temp_$$" ]] && rm -rf "$output_directory/temp_$$" 2>/dev/null
    fi
}
trap 'echo -e "\n\nInterrupted! Cleaning up..."; cleanup_temp; exit 1' SIGINT

# ─────────────────────────────────────────────
# Progress bar helper (batch mode)
# ─────────────────────────────────────────────
# Usage: draw_progress <current> <total>
draw_progress() {
    local current="$1" total="$2"
    local width=40
    local pct=$(( current * 100 / total ))
    local filled=$(( current * width / total ))
    local bar=""
    for ((i=0; i<filled; i++));  do bar+="█"; done
    for ((i=filled; i<width; i++)); do bar+="░"; done
    printf "\r  [%s] %3d%% (%d/%d)" "$bar" "$pct" "$current" "$total"
}

# ─────────────────────────────────────────────
# Core processing function
#   $1 = input image path
#   $2 = output image path  (full path to file, NOT a directory)
#   $3 = temp directory
# ─────────────────────────────────────────────
process_image() {
    local input_image="$1"
    local output_path="$2"
    local temp_dir="$3"

    # Build the list of all colors to remove (primary + extras)
    local all_colors=("$color_hex" "${normalized_extra_colors[@]}")

    # Internal helper: remove one color from a given file, write to another
    # Usage: _remove_color <src> <dst> <color> <temp_dir>
    _remove_color() {
        local src="$1" dst="$2" col="$3" td="$4"

        case $METHOD in
            simple)
                magick "$src" \
                    -transparent "$col" \
                    "$dst" 2>/dev/null
                ;;
            fuzz)
                magick "$src" \
                    -fuzz "$FUZZ_PERCENT" \
                    -transparent "$col" \
                    -channel A -threshold 10% +channel \
                    "$dst" 2>/dev/null
                ;;
            mask)
                magick "$src" \
                    -fuzz "$FUZZ_PERCENT" \
                    -fill "rgba(255,255,255,0)" -opaque "$col" \
                    -alpha extract \
                    -negate \
                    "$td/mask.png" 2>/dev/null || return 1
                magick "$src" \
                    \( -clone 0 -alpha off \) \
                    \( -clone 0 "$td/mask.png" -compose Copy_Opacity -composite \) \
                    -delete 0 \
                    "$dst" 2>/dev/null
                ;;
            morph)
                magick "$src" \
                    -fuzz "$FUZZ_PERCENT" \
                    \( +clone -fill "$col" -colorize 100 \) \
                    -compose Difference -composite \
                    -evaluate Pow 2 -negate \
                    -alpha off -threshold 0 \
                    -morphology Erode Diamond:1 \
                    -morphology Dilate Diamond:1 \
                    -blur 0x1 \
                    -alpha extract \
                    "$td/mask.png" 2>/dev/null || return 1
                magick "$src" \
                    \( "$td/mask.png" -alpha extract \) \
                    -alpha off -compose Copy_Opacity -composite \
                    "$dst" 2>/dev/null
                ;;
            precise)
                magick "$src" \
                    \( +clone -fill "$col" -colorize 100 \) \
                    -compose Difference -composite \
                    -separate -evaluate-sequence Max \
                    -auto-level \
                    -fuzz "$FUZZ_PERCENT" -transparent white \
                    -blur 0x2 \
                    -threshold 50% \
                    -morphology Erode Diamond:1 \
                    -alpha extract \
                    "$td/mask.png" 2>/dev/null || return 1
                magick "$td/mask.png" \
                    -morphology Dilate Diamond:1 \
                    -blur 0x0.7 \
                    "$td/mask_blur.png" 2>/dev/null
                magick "$src" \
                    \( "$td/mask_blur.png" \) \
                    -alpha off -compose Copy_Opacity -composite \
                    "$dst" 2>/dev/null
                ;;
        esac
    }

    # Process each color sequentially (chain: first color on original, then on result)
    local current_src="$input_image"
    local step_dst=""
    local step=0

    for col in "${all_colors[@]}"; do
        step=$(( step + 1 ))
        if [[ $step -lt ${#all_colors[@]} ]]; then
            step_dst="$temp_dir/step_${step}.png"
        else
            step_dst="$temp_dir/final_step.png"
        fi

        _remove_color "$current_src" "$step_dst" "$col" "$temp_dir" || return 1
        current_src="$step_dst"
    done

    # Post-processing: feather
    local post_src="$current_src"
    if [[ "$FEATHER" -gt 0 ]]; then
        magick "$post_src" \
            -channel A \
            -blur "0x${FEATHER}" \
            +channel \
            "$temp_dir/feathered.png" 2>/dev/null || return 1
        post_src="$temp_dir/feathered.png"
    fi

    # Post-processing: trim
    if $DO_TRIM; then
        magick "$post_src" -trim +repage "$output_path" 2>/dev/null || return 1
    else
        cp "$post_src" "$output_path" 2>/dev/null || return 1
    fi
}

# ─────────────────────────────────────────────
# Collect image files (supports recursive mode)
# ─────────────────────────────────────────────
collect_images() {
    local base_dir="$1"
    local -n _result=$2   # nameref to caller's array

    if $RECURSIVE; then
        while IFS= read -r -d '' f; do
            is_supported_image "$f" && _result+=("$f")
        done < <(find "$base_dir" -type f \( \
            -iname "*.png" -o -iname "*.jpg" -o -iname "*.jpeg" \
            -o -iname "*.svg" -o -iname "*.webp" -o -iname "*.bmp" \
            -o -iname "*.avif" \) -print0 | sort -z)
    else
        shopt -s nullglob nocaseglob
        local candidates=(
            "$base_dir"/*.png "$base_dir"/*.jpg "$base_dir"/*.jpeg
            "$base_dir"/*.svg "$base_dir"/*.webp "$base_dir"/*.bmp
            "$base_dir"/*.avif
        )
        shopt -u nullglob nocaseglob
        for f in "${candidates[@]}"; do
            [ -f "$f" ] && _result+=("$f")
        done
    fi
}

# ─────────────────────────────────────────────
# SINGLE-FILE MODE execution
# ─────────────────────────────────────────────
if $SINGLE_FILE_MODE; then
    echo "========================================"
    echo "Image Background Removal Tool"
    echo "========================================"
    echo "Mode:             single file"
    echo "Input file:       $input_file"
    echo "Output file:      $output_file"
    echo "Color to remove:  $color_hex"
    [[ ${#normalized_extra_colors[@]} -gt 0 ]] && \
        echo "Extra colors:     ${normalized_extra_colors[*]}"
    echo "Method:           $METHOD"
    [[ "$METHOD" != "simple" ]] && echo "Fuzz tolerance:   $FUZZ_PERCENT"
    $DO_TRIM   && echo "Trim borders:     yes"
    [[ "$FEATHER" -gt 0 ]] && echo "Edge feather:     ${FEATHER}px"
    $DRY_RUN   && echo "Dry-run:          yes (no files will be written)"
    echo "========================================"

    if $DRY_RUN; then
        echo "DRY-RUN: would process '$input_file' → '$output_file'"
        exit 0
    fi

    if $SKIP_EXISTING && [[ -f "$output_file" ]]; then
        echo "Skipping (output already exists): $output_file"
        exit 0
    fi

    [[ ! -d "$out_dir" ]] && mkdir -p "$out_dir"

    filename=$(basename -- "$input_file")
    echo -n "Processing $filename... "

    temp_dir="${out_dir}/temp_$$"
    mkdir -p "$temp_dir"

    if process_image "$input_file" "$output_file" "$temp_dir"; then
        echo "✓"
        echo "========================================"
        echo "Processing complete!"
        echo "Output saved to: $output_file"
        echo "========================================"
    else
        echo "✗"
        echo "========================================"
        echo "Processing failed."
        echo "========================================"
        rm -rf "$temp_dir"
        exit 1
    fi

    rm -rf "$temp_dir"
    exit 0
fi

# ─────────────────────────────────────────────
# BATCH / DIRECTORY MODE execution
# ─────────────────────────────────────────────

if [ ! -d "$input_directory" ]; then
    echo "Error: Input directory '$input_directory' not found"
    exit 1
fi

image_files=()
collect_images "$input_directory" image_files

if [ ${#image_files[@]} -eq 0 ]; then
    echo "Error: No supported image files found in '$input_directory'"
    echo "Supported formats: PNG, JPG, JPEG, SVG, WEBP, BMP, AVIF"
    echo ""
    echo "Contents of '$input_directory':"
    ls -la "$input_directory"
    exit 1
fi

[[ ! -d "$output_directory" ]] && mkdir -p "$output_directory"

# Initialize log file
if [[ -n "$LOG_FILE" ]]; then
    : > "$LOG_FILE"
fi

echo "========================================"
echo "Image Background Removal Tool"
echo "========================================"
echo "Mode:             batch"
echo "Input directory:  $input_directory"
echo "Output directory: $output_directory"
$RECURSIVE && echo "Recursive:        yes"
echo "Color to remove:  $color_hex"
[[ ${#normalized_extra_colors[@]} -gt 0 ]] && \
    echo "Extra colors:     ${normalized_extra_colors[*]}"
echo "Method:           $METHOD"
[[ "$METHOD" != "simple" ]] && echo "Fuzz tolerance:   $FUZZ_PERCENT"
$DO_TRIM   && echo "Trim borders:     yes"
[[ "$FEATHER" -gt 0 ]] && echo "Edge feather:     ${FEATHER}px"
$SKIP_EXISTING && echo "Skip existing:    yes"
$DRY_RUN   && echo "Dry-run:          yes (no files will be written)"
$PREVIEW   && echo "Preview mode:     yes (will pause after first image)"
echo "Parallel jobs:    $JOBS"
[[ -n "$LOG_FILE" ]] && echo "Error log:        $LOG_FILE"
echo "Images found:     ${#image_files[@]}"
echo "========================================"

# ─────────────────────────────────────────────
# Worker function called per image (used by both
# sequential and parallel execution paths)
# ─────────────────────────────────────────────
# Exported variables needed by worker in subshell:
export METHOD FUZZ_PERCENT DO_TRIM FEATHER color_hex
export -a normalized_extra_colors TRANSPARENCY_EXTS

process_one() {
    local input_image="$1"
    local output_directory="$2"
    local log_flag="$3"   # path to log file or ""
    local skip="$4"       # "true" or "false"
    local dry="$5"        # "true" or "false"

    local filename
    filename=$(basename -- "$input_image")
    local outname="${filename%.*}.png"

    # Preserve subdirectory structure in recursive mode
    local rel_path=""
    if [[ "$input_image" == "$input_directory/"* ]]; then
        rel_path="${input_image#"$input_directory/"}"
        rel_path=$(dirname "$rel_path")
        [[ "$rel_path" == "." ]] && rel_path=""
    fi

    local out_subdir="$output_directory"
    [[ -n "$rel_path" ]] && out_subdir="$output_directory/$rel_path"
    local output_path="$out_subdir/$outname"

    if [[ "$skip" == "true" ]] && [[ -f "$output_path" ]]; then
        echo "SKIP:$filename"
        return 0
    fi

    if [[ "$dry" == "true" ]]; then
        echo "DRY:$input_image -> $output_path"
        return 0
    fi

    [[ ! -d "$out_subdir" ]] && mkdir -p "$out_subdir"

    local temp_dir="$out_subdir/temp_$$_${BASHPID}"
    mkdir -p "$temp_dir"

    # Call process_image (defined in parent shell; available because we source or inline)
    if process_image "$input_image" "$output_path" "$temp_dir"; then
        rm -rf "$temp_dir"
        echo "OK:$filename"
    else
        rm -rf "$temp_dir"
        echo "FAIL:$filename:$output_path"
        [[ -n "$log_flag" ]] && echo "FAILED: $input_image -> $output_path" >> "$log_flag"
        return 1
    fi
}
export -f process_image process_one

# ─────────────────────────────────────────────
# Preview mode: process first image, then confirm
# ─────────────────────────────────────────────
if $PREVIEW && ! $DRY_RUN; then
    first_image="${image_files[0]}"
    first_filename=$(basename -- "$first_image")
    first_outname="${first_filename%.*}.png"
    first_output="$output_directory/$first_outname"

    echo "PREVIEW: Processing first image: $first_filename"
    temp_dir_preview="$output_directory/temp_$$"
    mkdir -p "$temp_dir_preview"

    if process_image "$first_image" "$first_output" "$temp_dir_preview"; then
        echo "✓ Preview saved to: $first_output"
    else
        echo "✗ Preview failed."
        rm -rf "$temp_dir_preview"
        exit 1
    fi
    rm -rf "$temp_dir_preview"

    echo ""
    read -r -p "Continue processing the remaining ${#image_files[@]} image(s)? [y/N] " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo "Aborted by user."
        exit 0
    fi
    echo ""
fi

# ─────────────────────────────────────────────
# Batch execution (sequential or parallel)
# ─────────────────────────────────────────────
total=${#image_files[@]}
processed=0
failed=0
skipped=0
idx=0

run_sequential() {
    for input_image in "${image_files[@]}"; do
        [ -f "$input_image" ] || continue
        idx=$(( idx + 1 ))

        local result
        result=$(process_one "$input_image" "$output_directory" "$LOG_FILE" \
                             "$SKIP_EXISTING" "$DRY_RUN")
        local status=$?

        local filename
        filename=$(basename -- "$input_image")

        if [[ "$result" == SKIP:* ]]; then
            echo "  Skipping (exists): $filename"
            skipped=$(( skipped + 1 ))
        elif [[ "$result" == DRY:* ]]; then
            echo "  DRY-RUN: ${result#DRY:}"
            processed=$(( processed + 1 ))
        elif [[ $status -eq 0 ]]; then
            processed=$(( processed + 1 ))
        else
            failed=$(( failed + 1 ))
        fi

        draw_progress "$idx" "$total"
    done
    echo   # newline after progress bar
}

run_parallel() {
    # Export needed vars for xargs subshells
    export input_directory output_directory LOG_FILE SKIP_EXISTING DRY_RUN RECURSIVE

    local tmplog
    tmplog=$(mktemp)

    printf '%s\0' "${image_files[@]}" | \
        xargs -0 -P "$JOBS" -I{} bash -c \
            'process_one "$1" "$output_directory" "$LOG_FILE" "$SKIP_EXISTING" "$DRY_RUN"' \
            _ {} >> "$tmplog" 2>&1

    # Parse results
    while IFS= read -r line; do
        case "$line" in
            OK:*)    processed=$(( processed + 1 )) ;;
            SKIP:*)  skipped=$(( skipped + 1 ))
                     echo "  Skipping (exists): ${line#SKIP:}" ;;
            DRY:*)   processed=$(( processed + 1 ))
                     echo "  DRY-RUN: ${line#DRY:}" ;;
            FAIL:*)  failed=$(( failed + 1 ))
                     echo "  ✗ Failed: ${line#FAIL:}" ;;
        esac
        idx=$(( idx + 1 ))
        draw_progress "$idx" "$total"
    done < "$tmplog"
    echo   # newline after progress bar
    rm -f "$tmplog"
}

if [[ "$JOBS" -gt 1 ]]; then
    run_parallel
else
    run_sequential
fi

# ─────────────────────────────────────────────
# Summary
# ─────────────────────────────────────────────
echo "========================================"
echo "Processing complete!"
$DRY_RUN && echo "(Dry-run — no files were written)"
echo "Successfully processed: $processed image(s)"
[[ $skipped -gt 0 ]] && echo "Skipped (existing):   $skipped image(s)"
[[ $failed  -gt 0 ]] && echo "Failed:               $failed image(s)"
[[ -n "$LOG_FILE" && $failed -gt 0 ]] && echo "Error log saved to:   $LOG_FILE"
echo "========================================"