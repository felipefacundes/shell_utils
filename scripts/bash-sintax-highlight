#!/usr/bin/env bash
# License: GPLv3
# Credits: Felipe Facundes

# bash-sintax-highlight — Syntax highlight em tempo real no texto digitado
#
# INSTALAÇÃO: última linha do ~/.bashrc:
#   source ~/.shell_utils/scripts/bash-sintax-highlight

[[ "${_CS_LOADED:-}" == "1" ]] && return 0
_CS_LOADED=1

(( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 3) )) && {
    printf 'bash-sintax-highlight: requer Bash 4.3+\n' >&2
    return 1
}

# ── Cores ──────────────────────────────────────────────────────
_cs_green=$'\e[32m'
_cs_red=$'\e[31m'
_cs_reset=$'\e[0m'

# ── Estado ─────────────────────────────────────────────────────
_CS_BUFFER=""
_CS_POS=0
_CS_HIST_POS=-1
_CS_HIST_SAVED=""
_CS_HIST_PREFIX=""
_CS_HIST_CACHE=()
_CS_HIST_MAX=0
_CS_HIST_PAGE_POS=-1      # Posição para Page-Up/Down
_CS_HIST_SAVED_PAGE=""    # Buffer salvo para Page-Up/Down
_CS_ENTER_HANDLED=0

# Estado do Tab
_CS_TAB_STATE=-1
_CS_TAB_COMPLETIONS=()
_CS_TAB_WORD_START=0
_CS_TAB_ORIG_BUFFER=""
_CS_TAB_ORIG_POS=0

# PS1 original guardado; PS1 real será impresso manualmente
_CS_PS1_ORIG=""
_CS_PS1_EXPANDED=""
_CS_PS1_LEN=0

# ── Captura PS1 original e zera PS1 ───────────────────────────
# Precisa acontecer ANTES do primeiro PROMPT_COMMAND rodar.
# O bash já imprimiu o PS1 original para o prompt atual —
# zeramos agora para que o próximo prompt seja controlado por nós.
_CS_PS1_ORIG="${PS1}"
PS1=""

# ── Atualiza PS1 expandido e comprimento visível ───────────────
# Chamado no PROMPT_COMMAND. Expande _CS_PS1_ORIG com ${var@P}.
_cs_ps1_update() {
    if (( BASH_VERSINFO[0] > 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] >= 4) )); then
        local _save_ps1="$PS1"
        PS1="$_CS_PS1_ORIG"
        _CS_PS1_EXPANDED="${PS1@P}"
        PS1="$_save_ps1"
    else
        local e="$_CS_PS1_ORIG"
        e="${e//\\u/$USER}"
        e="${e//\\h/${HOSTNAME%%.*}}"
        e="${e//\\w/$PWD}"
        e="${e//\\W/${PWD##*/}}"
        e="${e//\\$/$(( EUID == 0 ? '#' : '$' ))}"
        _CS_PS1_EXPANDED="$e"
    fi
    local plain
    plain=$(printf '%s' "$_CS_PS1_EXPANDED" \
        | sed 's/\x1b\[[0-9;]*[A-Za-z]//g;
               s/\x1b(B//g;
               s/\x1b][^\x07]*\x07//g;
               s/\x1b][^\x1b]*\x1b\\//g')
    local last="${plain##*$'\n'}"
    _CS_PS1_LEN=${#last}
}

# ── Validação ──────────────────────────────────────────────────
_cs_cmd_valid() {
    local cmd="${1%% *}"
    [[ -z "$cmd" ]] && return 1
    command -v "$cmd" &>/dev/null
}

# ── Imprime prompt ─────────────────────────────────────────────
_cs_show_prompt() {
    printf '%s' "$_CS_PS1_EXPANDED" >&2
}

# ── Buffer colorido ────────────────────────────────────────────
_cs_buffer_colored() {
    local buf="$_CS_BUFFER"
    [[ -z "$buf" ]] && { printf '%s' "$buf"; return; }
    local cmd="${buf%% *}"
    if _cs_cmd_valid "$cmd"; then
        printf '%s%s%s' "$_cs_green" "$buf" "$_cs_reset"
    else
        printf '%s%s%s' "$_cs_red" "$buf" "$_cs_reset"
    fi
}

# ── Redesenho ──────────────────────────────────────────────────
_cs_redraw() {
    # Garante que PS1 expandido está disponível
    [[ -z "$_CS_PS1_EXPANDED" ]] && _cs_ps1_update
    local colored
    colored=$(_cs_buffer_colored)
    printf '\r\e[2K%s%s' "$_CS_PS1_EXPANDED" "$colored" >&2
    printf '\r\e[%dG' "$(( _CS_PS1_LEN + _CS_POS + 1 ))" >&2
    READLINE_LINE=""
    READLINE_POINT=0
}

# ── Reset do ciclo Tab ─────────────────────────────────────────
_cs_tab_reset() {
    _CS_TAB_STATE=-1
    _CS_TAB_COMPLETIONS=()
    _CS_TAB_WORD_START=0
    _CS_TAB_ORIG_BUFFER=""
    _CS_TAB_ORIG_POS=0
}

# ── Prefixo comum ──────────────────────────────────────────────
_cs_common_prefix() {
    local prefix="${1}"; shift
    local s
    for s in "$@"; do
        while [[ "${s:0:${#prefix}}" != "$prefix" ]]; do
            prefix="${prefix:0:$(( ${#prefix}-1 ))}"
            [[ -z "$prefix" ]] && { printf ''; return; }
        done
    done
    printf '%s' "$prefix"
}

# ── Tab ────────────────────────────────────────────────────────
_cs_do_tab() {
    if (( _CS_TAB_STATE >= 0 )); then
        local n=${#_CS_TAB_COMPLETIONS[@]}
        _CS_TAB_STATE=$(( (_CS_TAB_STATE + 1) % (n + 1) ))
        if (( _CS_TAB_STATE == n )); then
            _CS_BUFFER="$_CS_TAB_ORIG_BUFFER"
            _CS_POS=$_CS_TAB_ORIG_POS
        else
            local completion="${_CS_TAB_COMPLETIONS[$_CS_TAB_STATE]}"
            local after="${_CS_TAB_ORIG_BUFFER:$_CS_TAB_ORIG_POS}"
            _CS_BUFFER="${_CS_TAB_ORIG_BUFFER:0:$_CS_TAB_WORD_START}${completion}${after}"
            _CS_POS=$(( _CS_TAB_WORD_START + ${#completion} ))
        fi
        _cs_redraw
        return
    fi

    local line="$_CS_BUFFER"
    local point=$_CS_POS
    local after="${line:$point}"

    local word_start=$point
    while (( word_start > 0 )) && [[ "${line:$((word_start-1)):1}" != " " ]]; do
        (( word_start-- ))
    done
    local cur="${line:$word_start:$((point - word_start))}"
    local before_word="${line:0:$word_start}"
    local is_cmd=0
    [[ -z "${before_word// /}" ]] && is_cmd=1

    local -a completions=()
    local cmd="${_CS_BUFFER%% *}"

    if (( ! is_cmd )) && declare -f _completion_loader &>/dev/null; then
        _completion_loader "$cmd" 2>/dev/null
        local comp_spec comp_func
        comp_spec=$(complete -p "$cmd" 2>/dev/null)
        comp_func=$(awk 'NF>=2{print $(NF-1)}' <<< "$comp_spec")
        if [[ -n "$comp_func" ]] && declare -f "$comp_func" &>/dev/null; then
            local -a all_words
            eval "all_words=( $line )" 2>/dev/null || read -ra all_words <<< "$line"
            local cword=${#all_words[@]}
            [[ "$line" =~ [[:space:]]$ ]] || (( cword-- ))
            (( cword < 0 )) && cword=0
            COMP_LINE="$line"; COMP_POINT=$point
            COMP_WORDS=("${all_words[@]}"); COMP_CWORD=$cword
            COMPREPLY=()
            "$comp_func" "$cmd" "$cur" "${all_words[$((cword-1))]:-}" 2>/dev/null
            completions=("${COMPREPLY[@]}")
        fi
    fi

    if (( ${#completions[@]} == 0 )); then
        if (( is_cmd )); then
            mapfile -t completions < <(compgen -c -- "$cur" 2>/dev/null | sort -u)
        else
            mapfile -t completions < <(compgen -f -- "$cur" 2>/dev/null | sort -u)
            local i
            for (( i=0; i < ${#completions[@]}; i++ )); do
                [[ -d "${completions[$i]}" && "${completions[$i]}" != */ ]] \
                    && completions[$i]+="/"
            done
        fi
    fi

    local n=${#completions[@]}

    if (( n == 0 )); then
        printf '\a' >&2; _cs_redraw; return
    fi

    if (( n == 1 )); then
        local completion="${completions[0]}"
        local suffix=""; [[ "${completion}" != */ ]] && suffix=" "
        _CS_BUFFER="${line:0:$word_start}${completion}${suffix}${after}"
        _CS_POS=$(( word_start + ${#completion} + ${#suffix} ))
        _cs_tab_reset; _cs_redraw; return
    fi

    local common
    common=$(_cs_common_prefix "${completions[@]}")

    if [[ "${#common}" -gt "${#cur}" ]]; then
        _CS_BUFFER="${line:0:$word_start}${common}${after}"
        _CS_POS=$(( word_start + ${#common} ))
        if (( is_cmd )); then
            mapfile -t completions < <(compgen -c -- "$common" 2>/dev/null | sort -u)
        else
            mapfile -t completions < <(compgen -f -- "$common" 2>/dev/null | sort -u)
            local i
            for (( i=0; i < ${#completions[@]}; i++ )); do
                [[ -d "${completions[$i]}" && "${completions[$i]}" != */ ]] \
                    && completions[$i]+="/"
            done
        fi
        if (( ${#completions[@]} == 1 )); then
            local suffix=""; [[ "${completions[0]}" != */ ]] && suffix=" "
            _CS_BUFFER="${line:0:$word_start}${completions[0]}${suffix}${after}"
            _CS_POS=$(( word_start + ${#completions[0]} + ${#suffix} ))
            _cs_tab_reset; _cs_redraw; return
        fi
        _CS_TAB_COMPLETIONS=("${completions[@]}")
        _CS_TAB_STATE=-1
        _CS_TAB_WORD_START=$word_start
        _CS_TAB_ORIG_BUFFER="$_CS_BUFFER"
        _CS_TAB_ORIG_POS=$_CS_POS
        _cs_list_completions "$common" "${completions[@]}"
        _cs_redraw; return
    fi

    _CS_TAB_COMPLETIONS=("${completions[@]}")
    _CS_TAB_STATE=-1
    _CS_TAB_WORD_START=$word_start
    _CS_TAB_ORIG_BUFFER="$line"
    _CS_TAB_ORIG_POS=$point

    if (( n > 50 )); then
        printf '\nExibir todos %d possíveis? (s/n) ' "$n" >&2
        local ans; read -r -n1 ans </dev/tty; printf '\n' >&2
        if [[ "$ans" != [sySY] ]]; then
            _CS_TAB_STATE=0
            local first="${_CS_TAB_COMPLETIONS[0]}"
            _CS_BUFFER="${line:0:$word_start}${first}${after}"
            _CS_POS=$(( word_start + ${#first} ))
            _cs_redraw; return
        fi
    fi

    _cs_list_completions "$cur" "${completions[@]}"
    _CS_TAB_STATE=0
    local first="${_CS_TAB_COMPLETIONS[0]}"
    _CS_BUFFER="${line:0:$word_start}${first}${after}"
    _CS_POS=$(( word_start + ${#first} ))
    _cs_redraw
}

# ── Listagem com cores ─────────────────────────────────────────
_cs_list_completions() {
    local prefix="$1"; shift
    local -a items=("$@")
    printf '\n' >&2
    local max_len=0 item
    for item in "${items[@]}"; do
        (( ${#item} > max_len )) && max_len=${#item}
    done
    local term_cols; term_cols=$(tput cols 2>/dev/null || printf '80')
    local col_width=$(( max_len + 2 ))
    local num_cols=$(( term_cols / col_width ))
    (( num_cols < 1 )) && num_cols=1
    local idx=0
    for item in "${items[@]}"; do
        local colored_item
        colored_item=$(_cs_colorize "$item" "$prefix")
        local pad=$(( col_width - ${#item} ))
        printf '%s%*s' "$colored_item" "$pad" '' >&2
        (( ++idx % num_cols == 0 )) && printf '\n' >&2
    done
    (( idx % num_cols != 0 )) && printf '\n' >&2
}

# ── Colorize itens do menu de completions ──────────────────────
_cs_colorize() {
    local item="$1" prefix="$2"
    local rest="${item:${#prefix}}"
    local item_color=""
    if [[ "$item" == */ ]]; then item_color="01;34"
    elif [[ -x "$item" && -f "$item" ]] 2>/dev/null; then item_color="01;32"
    elif [[ -L "$item" ]] 2>/dev/null; then item_color="01;36"
    elif [[ -d "$item" ]] 2>/dev/null; then item_color="01;34"
    fi
    local reset="\e[0m"
    if [[ -n "$item_color" ]]; then
        if [[ -n "$prefix" ]]; then
            printf "\e[${item_color};04m%s${reset}\e[${item_color}m%s${reset}" "$prefix" "$rest"
        else
            printf "\e[${item_color}m%s${reset}" "$item"
        fi
    else
        if [[ -n "$prefix" ]]; then
            printf "\e[01;04m%s${reset}%s" "$prefix" "$rest"
        else
            printf '%s' "$item"
        fi
    fi
}

# ── Inserção ───────────────────────────────────────────────────
_cs_insert() {
    _cs_tab_reset
    _CS_BUFFER="${_CS_BUFFER:0:$_CS_POS}${1}${_CS_BUFFER:$_CS_POS}"
    (( _CS_POS++ ))
    _cs_redraw
}

# ── Backspace / Delete ─────────────────────────────────────────
_cs_backspace() {
    if (( _CS_POS == 0 )); then
        _cs_redraw  # restaura PS1 caso o readline tenha apagado algo
        return
    fi
    _cs_tab_reset
    _CS_BUFFER="${_CS_BUFFER:0:$((_CS_POS-1))}${_CS_BUFFER:$_CS_POS}"
    (( _CS_POS-- ))
    _cs_redraw
}

_cs_delete() {
    (( _CS_POS < ${#_CS_BUFFER} )) || return
    _cs_tab_reset
    _CS_BUFFER="${_CS_BUFFER:0:$_CS_POS}${_CS_BUFFER:$((_CS_POS+1))}"
    _cs_redraw
}

# ── Movimentação ───────────────────────────────────────────────
_cs_left() {
    _cs_tab_reset
    
    # Se já está no início, apenas redesenha para garantir que o texto está visível
    if (( _CS_POS == 0 )); then
        # Redesenha completamente a linha para garantir que o texto não sumiu
        local colored
        colored=$(_cs_buffer_colored)
        printf '\r\e[2K%s%s' "$_CS_PS1_EXPANDED" "$colored" >&2
        printf '\r\e[%dG' "$(( _CS_PS1_LEN + 1 ))" >&2
        READLINE_LINE=""
        READLINE_POINT=0
        return
    fi
    
    # Movimento normal
    (( _CS_POS-- ))
    
    # Redesenha a linha para garantir consistência
    local colored
    colored=$(_cs_buffer_colored)
    printf '\r\e[2K%s%s' "$_CS_PS1_EXPANDED" "$colored" >&2
    printf '\r\e[%dG' "$(( _CS_PS1_LEN + _CS_POS + 1 ))" >&2
    READLINE_LINE=""
    READLINE_POINT=0
}
_cs_right() {
    _cs_tab_reset
    
    # Só permite movimento se não estiver no final
    if (( _CS_POS < ${#_CS_BUFFER} )); then
        (( _CS_POS++ ))
    fi
    
    # SEMPRE redesenha a linha completa, independente do movimento
    local colored
    colored=$(_cs_buffer_colored)
    printf '\r\e[2K%s%s' "$_CS_PS1_EXPANDED" "$colored" >&2
    printf '\r\e[%dG' "$(( _CS_PS1_LEN + _CS_POS + 1 ))" >&2
    READLINE_LINE=""
    READLINE_POINT=0
}
_cs_home() {
    _cs_tab_reset
    _CS_POS=0
    
    # Redesenha a linha completa na posição inicial
    local colored
    colored=$(_cs_buffer_colored)
    printf '\r\e[2K%s%s' "$_CS_PS1_EXPANDED" "$colored" >&2
    printf '\r\e[%dG' "$(( _CS_PS1_LEN + 1 ))" >&2
    READLINE_LINE=""
    READLINE_POINT=0
}

_cs_end() {
    _cs_tab_reset
    _CS_POS=${#_CS_BUFFER}
    
    # Redesenha a linha completa na posição final
    local colored
    colored=$(_cs_buffer_colored)
    printf '\r\e[2K%s%s' "$_CS_PS1_EXPANDED" "$colored" >&2
    printf '\r\e[%dG' "$(( _CS_PS1_LEN + _CS_POS + 1 ))" >&2
    READLINE_LINE=""
    READLINE_POINT=0
}

# ── Kill ───────────────────────────────────────────────────────
_cs_kill_to_start() {
    _cs_tab_reset; _CS_BUFFER="${_CS_BUFFER:$_CS_POS}"; _CS_POS=0; _cs_redraw
}
_cs_kill_to_end() {
    _cs_tab_reset; _CS_BUFFER="${_CS_BUFFER:0:$_CS_POS}"; _cs_redraw
}
_cs_kill_word() {
    _cs_tab_reset
    (( _CS_POS > 0 )) || return
    local before after
    before=$(printf '%s' "${_CS_BUFFER:0:$_CS_POS}" | sed 's/[^ ]*[[:space:]]*$//')
    after="${_CS_BUFFER:$_CS_POS}"
    _CS_POS=${#before}; _CS_BUFFER="${before}${after}"; _cs_redraw
}

# ── Histórico ──────────────────────────────────────────────────
_cs_hist_load() {
    _CS_HIST_CACHE=(); _CS_HIST_MAX=0
    local num cmd
    while read -r num cmd; do
        _CS_HIST_CACHE[$num]="$cmd"; _CS_HIST_MAX=$num
    done < <(HISTTIMEFORMAT='' history)
}

_cs_hist_up() {
    _cs_tab_reset
    if (( _CS_HIST_POS == -1 )); then
        _cs_hist_load
        (( _CS_HIST_MAX == 0 )) && return
        _CS_HIST_SAVED="$_CS_BUFFER"; _CS_HIST_PREFIX="$_CS_BUFFER"
        _CS_HIST_POS=$(( _CS_HIST_MAX + 1 ))
    fi
    local i entry prefix="$_CS_HIST_PREFIX"
    for (( i = _CS_HIST_POS - 1; i >= 1; i-- )); do
        entry="${_CS_HIST_CACHE[$i]:-}"
        [[ -z "$entry" ]] && continue
        if [[ "$entry" == "$prefix"* && "$entry" != "$_CS_BUFFER" ]]; then
            _CS_HIST_POS=$i; _CS_BUFFER="$entry"; _CS_POS=${#_CS_BUFFER}
            _cs_redraw; return
        fi
    done
}

_cs_hist_down() {
    _cs_tab_reset
    
    # Se não está no modo histórico, não faz nada
    if (( _CS_HIST_POS == -1 )); then
        # Garante que o PS1 está visível
        printf '\r\e[2K%s' "$_CS_PS1_EXPANDED" >&2
        printf '\r\e[%dG' "$(( _CS_PS1_LEN + 1 ))" >&2
        READLINE_LINE=""
        READLINE_POINT=0
        return
    fi
    
    local i entry prefix="$_CS_HIST_PREFIX"
    for (( i = _CS_HIST_POS + 1; i <= _CS_HIST_MAX; i++ )); do
        entry="${_CS_HIST_CACHE[$i]:-}"
        [[ -z "$entry" ]] && continue
        if [[ "$entry" == "$prefix"* && "$entry" != "$_CS_BUFFER" ]]; then
            _CS_HIST_POS=$i; _CS_BUFFER="$entry"; _CS_POS=${#_CS_BUFFER}
            _cs_redraw; return
        fi
    done
    _CS_HIST_POS=-1; _CS_BUFFER="$_CS_HIST_SAVED"; _CS_POS=${#_CS_BUFFER}
    _cs_redraw
}

# ── Page-Up / Page-Down ────────────────────────────────────────
_cs_page_up() {
    _cs_tab_reset
    
    # Carrega histórico se necessário
    if (( _CS_HIST_MAX == 0 )); then
        _cs_hist_load
        (( _CS_HIST_MAX == 0 )) && return
    fi
    
    # Vai para o primeiro comando do histórico (o mais antigo, índice 1)
    local first_entry="${_CS_HIST_CACHE[1]:-}"
    
    if [[ -n "$first_entry" ]]; then
        _CS_BUFFER="$first_entry"
        _CS_POS=${#_CS_BUFFER}
        
        # Redesenha
        local colored
        colored=$(_cs_buffer_colored)
        printf '\r\e[2K%s%s' "$_CS_PS1_EXPANDED" "$colored" >&2
        printf '\r\e[%dG' "$(( _CS_PS1_LEN + _CS_POS + 1 ))" >&2
        READLINE_LINE=""
        READLINE_POINT=0
    else
        printf '\a' >&2
    fi
}

_cs_page_down() {
    _cs_tab_reset
    
    # Limpa a linha completamente
    _CS_BUFFER=""
    _CS_POS=0
    
    # Redesenha apenas o PS1
    printf '\r\e[2K%s' "$_CS_PS1_EXPANDED" >&2
    printf '\r\e[%dG' "$(( _CS_PS1_LEN + 1 ))" >&2
    READLINE_LINE=""
    READLINE_POINT=0
}

# ── Enter ──────────────────────────────────────────────────────
_cs_enter() {
    _cs_tab_reset
    printf '\r\e[2K' >&2
    _cs_show_prompt
    printf '%s\n' "$_CS_BUFFER" >&2
    
    _CS_HIST_POS=-1
    _CS_HIST_SAVED=""
    _CS_HIST_PREFIX=""
    
    local cmd="$_CS_BUFFER"
    _CS_BUFFER=""
    _CS_POS=0
    
    if [[ -n "$cmd" ]]; then
        history -s -- "$cmd"
        eval -- "$cmd"
    fi
    
    # Mostra o prompt novamente após o comando
    _cs_show_prompt
    READLINE_LINE=""
    READLINE_POINT=0
}

_cs_clear_screen() { _cs_tab_reset; clear; _cs_redraw; }

# ── Ctrl+C ─────────────────────────────────────────────────────
_cs_sigint() {
    _cs_tab_reset
    _CS_BUFFER=""; _CS_POS=0
    _CS_HIST_POS=-1; _CS_HIST_SAVED=""; _CS_HIST_PREFIX=""
    READLINE_LINE=""; READLINE_POINT=0
}

# ── PROMPT_COMMAND ─────────────────────────────────────────────
_cs_prompt_cmd() {
    # Se o Enter já mostrou o prompt, não faz nada
    if (( _CS_ENTER_HANDLED )); then
        _CS_ENTER_HANDLED=0
        return 0
    fi
    
    # Caso contrário (Ctrl+C ou outra situação), mostra o prompt
    _cs_ps1_update
    _cs_show_prompt
    _CS_BUFFER=""
    _CS_POS=0
    READLINE_LINE=""
    READLINE_POINT=0
}

# ── Instala binds ──────────────────────────────────────────────
_cs_install_binds() {
    bind 'set echo-control-characters off' 2>/dev/null
    bind 'set enable-bracketed-paste off'  2>/dev/null

    local c
    for c in {a..z}; do
        eval "_cs_k_${c}() { _cs_insert '${c}'; }"
        bind -x "\"${c}\": _cs_k_${c}" 2>/dev/null
    done
    for c in {A..Z}; do
        eval "_cs_k_${c}() { _cs_insert '${c}'; }"
        bind -x "\"${c}\": _cs_k_${c}" 2>/dev/null
    done
    for c in {0..9}; do
        eval "_cs_k_n${c}() { _cs_insert '${c}'; }"
        bind -x "\"${c}\": _cs_k_n${c}" 2>/dev/null
    done

    _cs_k_space()    { _cs_insert ' ';  }; bind -x '" ":  _cs_k_space'    2>/dev/null
    _cs_k_tilde()    { _cs_insert '~';  }; bind -x '"~":  _cs_k_tilde'    2>/dev/null
    _cs_k_bang()     { _cs_insert '!';  }; bind -x '"!":  _cs_k_bang'     2>/dev/null
    _cs_k_at()       { _cs_insert '@';  }; bind -x '"@":  _cs_k_at'       2>/dev/null
    _cs_k_hash()     { _cs_insert '#';  }; bind -x '"#":  _cs_k_hash'     2>/dev/null
    _cs_k_dollar()   { _cs_insert '$';  }; bind -x '"$":  _cs_k_dollar'   2>/dev/null
    _cs_k_percent()  { _cs_insert '%';  }; bind -x '"%":  _cs_k_percent'  2>/dev/null
    _cs_k_caret()    { _cs_insert '^';  }; bind -x '"^":  _cs_k_caret'    2>/dev/null
    _cs_k_amp()      { _cs_insert '&';  }; bind -x '"&":  _cs_k_amp'      2>/dev/null
    _cs_k_star()     { _cs_insert '*';  }; bind -x '"*":  _cs_k_star'     2>/dev/null
    _cs_k_lparen()   { _cs_insert '(';  }; bind -x '"(":  _cs_k_lparen'   2>/dev/null
    _cs_k_rparen()   { _cs_insert ')';  }; bind -x '")":  _cs_k_rparen'   2>/dev/null
    _cs_k_minus()    { _cs_insert '-';  }; bind -x '"-":  _cs_k_minus'    2>/dev/null
    _cs_k_under()    { _cs_insert '_';  }; bind -x '"_":  _cs_k_under'    2>/dev/null
    _cs_k_equal()    { _cs_insert '=';  }; bind -x '"=":  _cs_k_equal'    2>/dev/null
    _cs_k_plus()     { _cs_insert '+';  }; bind -x '"+":  _cs_k_plus'     2>/dev/null
    _cs_k_lbrack()   { _cs_insert '[';  }; bind -x '"[":  _cs_k_lbrack'   2>/dev/null
    _cs_k_rbrack()   { _cs_insert ']';  }; bind -x '"]":  _cs_k_rbrack'   2>/dev/null
    _cs_k_lbrace()   { _cs_insert '{';  }; bind -x '"{":  _cs_k_lbrace'   2>/dev/null
    _cs_k_rbrace()   { _cs_insert '}';  }; bind -x '"}":  _cs_k_rbrace'   2>/dev/null
    _cs_k_pipe()     { _cs_insert '|';  }; bind -x '"|":  _cs_k_pipe'     2>/dev/null
    _cs_k_semi()     { _cs_insert ';';  }; bind -x '";":  _cs_k_semi'     2>/dev/null
    _cs_k_colon()    { _cs_insert ':';  }; bind -x '":":  _cs_k_colon'    2>/dev/null
    _cs_k_squote()   { _cs_insert "'";  }; bind -x "\"'\": _cs_k_squote"  2>/dev/null
    _cs_k_dquote()   { _cs_insert '"';  }; bind -x '"\"": _cs_k_dquote'   2>/dev/null
    _cs_k_comma()    { _cs_insert ',';  }; bind -x '",":  _cs_k_comma'    2>/dev/null
    _cs_k_dot()      { _cs_insert '.';  }; bind -x '".":  _cs_k_dot'      2>/dev/null
    _cs_k_slash()    { _cs_insert '/';  }; bind -x '"/":  _cs_k_slash'    2>/dev/null
    _cs_k_lt()       { _cs_insert '<';  }; bind -x '"<":  _cs_k_lt'       2>/dev/null
    _cs_k_gt()       { _cs_insert '>';  }; bind -x '">":  _cs_k_gt'       2>/dev/null
    _cs_k_question() { _cs_insert '?';  }; bind -x '"?":  _cs_k_question' 2>/dev/null
    _cs_k_bslash()   { _cs_insert '\'; }; bind -x '"\\": _cs_k_bslash'   2>/dev/null
    _cs_k_backtick() { _cs_insert '`';  }; bind -x '"`":  _cs_k_backtick' 2>/dev/null

    local _cs_rc _cs_old_inputrc
    _cs_old_inputrc="${INPUTRC:-}"
    _cs_rc=$(mktemp /tmp/cs-inputrc.XXXXXX 2>/dev/null)
    {
        local _cs_user_rc="${INPUTRC:-$HOME/.inputrc}"
        [[ -f "$_cs_user_rc" ]] && printf '$include %s\n' "$_cs_user_rc"
        printf '"\C-?": "\C-x\C-b"\n'
        printf '"\C-h": "\C-x\C-b"\n'
    } > "$_cs_rc" 2>/dev/null
    INPUTRC="$_cs_rc" bind -f "$_cs_rc" 2>/dev/null
    rm -f "$_cs_rc" 2>/dev/null
    if [[ -z "$_cs_old_inputrc" ]]; then unset INPUTRC
    else INPUTRC="$_cs_old_inputrc"; fi

    bind -x '"\C-x\C-b": _cs_backspace'  2>/dev/null
    bind -x '"\t":        _cs_do_tab'     2>/dev/null
    bind -x '"\e[3~": _cs_delete'        2>/dev/null
    bind -x '"\e[D":  _cs_left'          2>/dev/null
    bind -x '"\eOD":  _cs_left'          2>/dev/null
    bind -x '"\e[C":  _cs_right'         2>/dev/null
    bind -x '"\eOC":  _cs_right'         2>/dev/null
    bind -x '"\C-a":  _cs_home'          2>/dev/null
    bind -x '"\e[H":  _cs_home'          2>/dev/null
    bind -x '"\eOH":  _cs_home'          2>/dev/null
    bind -x '"\C-e":  _cs_end'           2>/dev/null
    bind -x '"\e[F":  _cs_end'           2>/dev/null
    bind -x '"\eOF":  _cs_end'           2>/dev/null
    bind -x '"\C-u":  _cs_kill_to_start' 2>/dev/null
    bind -x '"\C-k":  _cs_kill_to_end'   2>/dev/null
    bind -x '"\C-w":  _cs_kill_word'     2>/dev/null
    bind -x '"\C-l":  _cs_clear_screen'  2>/dev/null
    bind -x '"\C-m":  _cs_enter'         2>/dev/null
    bind -x '"\e[A":  _cs_hist_up'       2>/dev/null
    bind -x '"\eOA":  _cs_hist_up'       2>/dev/null
    bind -x '"\e[B":  _cs_hist_down'     2>/dev/null
    bind -x '"\eOB":  _cs_hist_down'     2>/dev/null

    # Na função _cs_install_binds:
    bind -x '"\e[5~": _cs_page_up'   2>/dev/null  # Page-Up
    bind -x '"\e[6~": _cs_page_down' 2>/dev/null  # Page-Down

    trap '_cs_sigint' INT
}

# ── Desinstalar ────────────────────────────────────────────────
custom-shell-detach() {
    local c
    for c in {a..z} {A..Z} {0..9}; do bind -r "\"$c\"" 2>/dev/null; done
    local s
    for s in ' ' '~' '!' '@' '#' '$' '%' '^' '&' '*' '(' ')' \
             '-' '_' '=' '+' '[' ']' '{' '}' '|' ';' ':' \
             ',' '.' '/' '<' '>' '?' '`'; do
        bind -r "\"$s\"" 2>/dev/null
    done
    bind -r "\"'\"" 2>/dev/null; bind -r '"\""' 2>/dev/null; bind -r '"\\"' 2>/dev/null
    bind -r '"\t"' '"\C-x\C-b"' '"\e[3~"' \
         '"\e[D"' '"\eOD"' '"\e[C"' '"\eOC"' \
         '"\C-a"' '"\e[H"' '"\eOH"' \
         '"\C-e"' '"\e[F"' '"\eOF"' \
         '"\C-u"' '"\C-k"' '"\C-w"' '"\C-l"' '"\C-m"' \
         '"\e[A"' '"\eOA"' '"\e[B"' '"\eOB"' 2>/dev/null
    trap - INT
    PS1="$_CS_PS1_ORIG"
    _CS_LOADED=0
    printf 'custom-shell desanexado.\n'
}

# ── Ativa ──────────────────────────────────────────────────────
_cs_install_binds
_cs_ps1_update

if [[ -z "${PROMPT_COMMAND:-}" ]]; then
    PROMPT_COMMAND="_cs_prompt_cmd"
else
    PROMPT_COMMAND="${PROMPT_COMMAND}; _cs_prompt_cmd"
fi