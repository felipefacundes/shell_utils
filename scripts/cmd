#!/usr/bin/env bash
# License: GPLv3
# Credits: Felipe Facundes
#
# cmd - Fuzzy command finder (based on fff architecture)

DEBUG_LOG="/tmp/cmd_debug.log"
echo "=== Debug: $(date) ===" > "$DEBUG_LOG"

# Colors
BOLD=$'\033[1m' CYAN=$'\033[0;36m' GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m' BLUE=$'\033[0;34m' MAGENTA=$'\033[0;35m'
RED=$'\033[0;31m' NC=$'\033[0m'

declare -A MESSAGES
if [[ "${LANG,,}" =~ pt_ ]]; then
    MESSAGES=(
        [title]="=== Buscador Fuzzy de Comandos ==="
        [search]="Busca: "
        [found]="comandos"
        [help]="↑↓:navegar | Enter:executar | q:sair | Ctrl+C:sair"
        [executing]="Executando: "
        [none]="Nenhum comando encontrado."
    )
else
    MESSAGES=(
        [title]="=== Command Fuzzy Finder ==="
        [search]="Search: "
        [found]="commands"
        [help]="↑↓:navigate | Enter:execute | q:quit | Ctrl+C:quit"
        [executing]="Executing: "
        [none]="No commands found."
    )
fi

# === fff-style global variables ===
declare -a commands filtered_commands
scroll=0          # current position in list
list_total=0      # total items - 1
max_items=0       # max visible items
y=0               # cursor y position
search_term=""
LINES=0 COLUMNS=0

# === fff-style terminal functions ===
get_term_size() {
    read -r LINES COLUMNS < <(stty size)
    ((max_items=LINES-4))  # 4 lines for header
}

setup_terminal() {
    printf '\e[?1049h\e[?7l\e[?25l\e[2J\e[1;%sr' "$max_items"
    stty -echo -icanon time 0 min 0 </dev/tty >/dev/null 2>/dev/null
}

reset_terminal() {
    printf '\e[?7h\e[?25h\e[2J\e[;r\e[?1049l'
    stty echo icanon </dev/tty >/dev/null 2>/dev/null
}

clear_screen() {
    printf '\e[%sH\e[9999C\e[1J%b\e[1;%sr' \
           "$((LINES-2))" "${TMUX:+\e[2J}" "$max_items"
}

# === fff-style draw functions ===
print_line() {
    local i="$1"
    local cmd="${filtered_commands[$i]}"
    
    # Highlight matching part
    local display="$cmd"
    if [[ -n "$search_term" ]]; then
        local pl="${search_term,,}" cl="${cmd,,}"
        local pos="${cl%%$pl*}" plen=${#pos}
        if [[ "$cl" == *"$pl"* ]]; then
            local before="${cmd:0:$plen}"
            local match="${cmd:$plen:${#search_term}}"
            local after="${cmd:$((plen + ${#search_term}))}"
            display="${before}${BOLD}${GREEN}${match}${NC}${after}"
        fi
    fi
    
    # Highlight if selected
    if ((i == scroll)); then
        printf '\r\e[7m\e[1m❯ %s\e[m\r' "$display"
    else
        printf '\r  %s\e[m\r' "$display"
    fi
}

draw_dir() {
    local scroll_start=$scroll
    local scroll_new_pos
    local scroll_end
    
    # Calculate visible range (same logic as fff)
    if ((list_total < max_items || scroll < max_items/2)); then
        ((scroll_start=0))
        ((scroll_end=max_items))
        ((scroll_new_pos=scroll+1))
    elif ((list_total - scroll < max_items/2)); then
        ((scroll_start=list_total-max_items+1))
        ((scroll_new_pos=max_items-(list_total-scroll)))
        ((scroll_end=list_total+1))
    else
        ((scroll_start=scroll-max_items/2))
        ((scroll_end=scroll_start+max_items))
        ((scroll_new_pos=max_items/2+1))
    fi
    
    printf '\e[H'
    
    for ((i=scroll_start; i<scroll_end; i++)); do
        ((i > scroll_start)) && printf '\n'
        if ((i <= list_total)); then
            print_line "$i"
        fi
    done
    
    printf '\e[%sH' "$scroll_new_pos"
    ((y=scroll_new_pos))
}

status_line() {
    printf '\e7\e[%sH\e[30;46m%*s\r %s %s/%s \e[m\e[%sH\e[K\e8' \
           "$((LINES-1))" "$COLUMNS" "" \
           "${search_term:+${BOLD}${YELLOW}${MESSAGES[search]}${search_term}${NC} | }" \
           "$((scroll+1))" "$((list_total+1))" "$LINES"
}

redraw() {
    clear_screen
    draw_dir
    status_line
}

# === fff-style scroll functions ===
scroll_down() {
    ((scroll < list_total)) && {
        ((scroll++))
        
        if ((y < max_items)); then
            # Cursor still in visible area - just redraw 2 lines
            ((y++))
            printf '\e[%sH' "$y"
            print_line "$((scroll-1))"
            printf '\n'
            print_line "$scroll"
        else
            # Need to scroll - redraw entire list
            redraw
        fi
        status_line
    }
}

scroll_up() {
    ((scroll > 0)) && {
        ((scroll--))
        
        if ((y < 2)); then
            # At top of visible area - insert line above (fff-style)
            print_line "$((scroll+1))"
            printf '\e[L'  # Insert line
            printf '\e[H'
            print_line "$scroll"
        else
            # Just move cursor up
            print_line "$((scroll+1))"
            printf '\e[A'
            ((y--))
            print_line "$scroll"
        fi
        status_line
    }
}

# === Command functions ===
get_all_commands() {
    local -A seen
    local dir file cmd_name
    local path_dirs
    IFS=':' read -ra path_dirs <<< "$PATH"
    
    commands=()
    for dir in "${path_dirs[@]}"; do
        [[ -d "$dir" ]] || continue
        for file in "$dir"/*; do
            [[ -x "$file" && -f "$file" ]] || continue
            cmd_name="${file##*/}"
            [[ ${seen["$cmd_name"]} ]] && continue
            commands+=("$cmd_name")
            seen["$cmd_name"]=1
        done
    done
    
    # Sort
    mapfile -t commands < <(printf "%s\n" "${commands[@]}" | sort)
    filtered_commands=("${commands[@]}")
    ((list_total=${#filtered_commands[@]}-1))
}

filter_commands() {
    if [[ -z "$search_term" ]]; then
        filtered_commands=("${commands[@]}")
    else
        filtered_commands=()
        local cmd pl="${search_term,,}" cl
        for cmd in "${commands[@]}"; do
            cl="${cmd,,}"
            [[ "$cl" == *"$pl"* ]] && filtered_commands+=("$cmd")
        done
    fi
    ((list_total=${#filtered_commands[@]}-1))
    scroll=0
}

# === Main ===
main() {
    [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && {
        echo "Usage: cmd [search_term]"
        echo "  cmd              - Interactive fuzzy finder"
        echo "  cmd [term]       - Start with search term"
        echo "  cmd --list [term] - List mode (non-interactive)"
        exit 0
    }
    
    [[ "${1:-}" == "--list" || "${1:-}" == "-l" ]] && {
        get_all_commands
        search_term="${2:-}"
        filter_commands
        printf "%s\n" "${filtered_commands[@]}" | head -35
        exit 0
    }
    
    # Interactive mode
    get_all_commands
    search_term="${1:-}"
    [[ -n "$search_term" ]] && filter_commands
    
    get_term_size
    setup_terminal
    
    # Draw header (outside scroll region)
    printf '\e[H'
    printf "${BOLD}${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}\n"
    printf "${BOLD}${CYAN}║  %-60s║${NC}\n" "${MESSAGES[title]}"
    printf "${BOLD}${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}\n"
    printf "${GREEN}%s${NC}\n" "${MESSAGES[help]}"
    
    redraw
    
    # Main loop (same as fff)
    for ((;;)); do
        local key=""
        read -r -n 1 key 2>/dev/null
        
        if [[ "$key" == $'\x1b' ]]; then
            local k2 k3
            read -r -n 1 -t 0.001 k2 2>/dev/null
            read -r -n 1 -t 0.001 k3 2>/dev/null
            
            if [[ "$k2" == '[' ]]; then
                case "$k3" in
                    'A') scroll_up ;;
                    'B') scroll_down ;;
                esac
            fi
        elif [[ "$key" == $'\x7f' || "$key" == $'\b' ]]; then
            [[ -n "$search_term" ]] && {
                search_term="${search_term%?}"
                filter_commands
                redraw
            }
        elif [[ "$key" == '' ]]; then
            # Enter
            if ((list_total >= 0)); then
                local cmd="${filtered_commands[$scroll]}"
                reset_terminal
                clear
                echo -e "${GREEN}${MESSAGES[executing]}${BOLD}$cmd${NC}"
                exec "$cmd"
            fi
        elif [[ "$key" == 'q' || "$key" == 'Q' ]]; then
            break
        elif [[ "$key" == $'\x03' ]]; then
            # Ctrl+C
            break
        elif [[ "$key" =~ [[:print:]] ]]; then
            search_term+="$key"
            filter_commands
            redraw
        fi
        
        [[ -t 1 ]] || break
    done
    
    reset_terminal
}

main "$@"