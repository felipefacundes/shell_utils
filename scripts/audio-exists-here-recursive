#!/usr/bin/env bash
# License: GPLv3
# Credits: Felipe Facundes

: <<'DOCUMENTATION'
This Bash script processes audio files in the current directory and subdirectories.
DOCUMENTATION

# Colors
C_RESET='\033[0m'
C_BOLD='\033[1m'
C_YELLOW='\033[1;33m'
C_GREEN='\033[1;32m'
C_CYAN='\033[1;36m'
C_BLUE='\033[1;34m'
C_MAGENTA='\033[1;35m'

trap 'echo -e "\n${C_YELLOW}Terminating...${C_RESET}"; exit 1' INT TERM

# Help
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    echo -e "${C_BOLD}Usage:${C_RESET} ${0##*/} [search_term]"
    echo -e "${C_BOLD}Example:${C_RESET} app=mpv ${0##*/} foot"
    echo -e "\n${C_CYAN}If search term is provided, only audio files containing the term (case-insensitive) will be processed.${C_RESET}"
    echo -e "${C_CYAN}Searches recursively in current directory and subdirectories.${C_RESET}"
    exit 0 
fi

app="${app:-}"
search_term="${1:-}"
audios=()
declare -A ext_counts

if [[ -n "$search_term" ]]; then
    echo -e "${C_CYAN}Searching recursively for audio files containing: ${C_BOLD}${search_term}${C_RESET}\n"
fi

# Audio extensions
audio_extensions="3gp|aa|aac|aax|act|aiff|alac|amr|ape|au|awb|cda|dct|dss|dvf|flac|gsm|iklax|ivs|m4a|m4b|m4p|mmf|mp3|mpc|msv|nmf|nsf|ogg|oga|mogg|opus|ra|rm|raw|rf64|sln|tta|voc|vox|wav|webm|wma|wv|8svx"

# Build find command - search recursively
if [[ -n "$search_term" ]]; then
    find_args=(-type f -iname "*${search_term}*")
else
    find_args=(-type f)
fi

# Process files using find (recursive)
while IFS= read -r -d '' file; do
    filename=$(basename "$file")
    filepath="$file"
    
    # Check if it's an audio file by extension
    ext="${filename##*.}"
    ext_lower=$(echo "$ext" | tr '[:upper:]' '[:lower:]')
    
    if [[ "$ext_lower" =~ ^($audio_extensions)$ ]] || \
       ( file -b --mime-type "$file" 2>/dev/null | grep -q "^audio/" ); then
        
        ((ext_counts[$ext_lower]++))

        if [[ -n "$app" ]]; then
            echo -e "\n    ▶  \"${C_YELLOW}${filepath}${C_RESET}\"\n"
            read -r -a cmd <<< "$app"
            "${cmd[@]}" "$filepath"
            echo
        else
            # Show relative path for clarity
            audios+=("'${filepath#./}'")
        fi
    fi
done < <(find . "${find_args[@]}" -print0 2>/dev/null)

# Display results
if [[ -z "$app" ]]; then
    echo -e "${C_BOLD}${C_GREEN}Audios: ${#audios[@]}${C_RESET}\n"
    
    for item in "${audios[@]}"; do
        echo -e "${C_CYAN}${item}${C_RESET}"
    done
    
    if [[ ${#ext_counts[@]} -gt 0 ]]; then
        echo -e "\n${C_BOLD}${C_MAGENTA}Audio formats found:${C_RESET}"
        for ext in "${!ext_counts[@]}"; do
            echo -e "  ${C_BLUE}.${ext}${C_RESET}: ${C_GREEN}${ext_counts[$ext]}${C_RESET} file(s)"
        done | sort
    fi
fi