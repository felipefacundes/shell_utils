#!/usr/bin/env bash
# License: GPLv3
# Credits: Felipe Facundes
#
# bash-sintax-highlight-ghost — Syntax highlight em tempo real + Ghost text do histórico
#
# INSTALAÇÃO: última linha do ~/.bashrc:
#   source ~/.shell_utils/scripts/bash-sintax-highlight-ghost
#
# Modos de ghost text (variável BASH_GHOST_TEXT):
#   0 - Ghost text desativado
#   1 - Completa com um toque (seta direita ou Ctrl+F)  [padrão]
#   2 - Completa por palavras (cada seta adiciona uma palavra)
#   3 - Completa por caracteres (cada seta adiciona um caractere)
#
# Atalhos do ghost text:
#   →  ou Ctrl+F  : aceita sugestão (comportamento depende do modo)
#   Ctrl+G        : aceita sugestão completa (todos os modos)
#
# Desativar: custom-shell-detach

[[ "${_CS_LOADED:-}" == "1" ]] && return 0
_CS_LOADED=1

(( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 3) )) && {
    printf 'bash-sintax-highlight-ghost: requer Bash 4.3+\n' >&2
    return 1
}

# ── Modo ghost text ────────────────────────────────────────────

# ══════════════════════════════════════════════════════════════
# SEÇÃO 1 — CORES E ESTADO (sintax highlight)
# ══════════════════════════════════════════════════════════════

_cs_green=$'\e[32m'
_cs_red=$'\e[31m'
_cs_reset=$'\e[0m'

TMPDIR="${TMPDIR:-/tmp}"  # Compatibilidade com Termux
_CS_BUFFER=""
_CS_POS=0
_CS_ML_BUFFER=""    # buffer acumulado para comandos multiline
_CS_ML_LINES=0      # quantas linhas multiline estão desenhadas na tela
_CS_PASTING=0       # 1 durante bracketed paste
_CS_PASTE_BUF=""    # acumula texto durante bracketed paste
_CS_HIST_POS=-1
_CS_HIST_SAVED=""
_CS_HIST_PREFIX=""
_CS_HIST_CACHE=()
_CS_HIST_MAX=0
_CS_HIST_PAGE_POS=-1
_CS_HIST_SAVED_PAGE=""
_CS_ENTER_HANDLED=0

_CS_TAB_STATE=-1
_CS_TAB_COMPLETIONS=()
_CS_TAB_WORD_START=0
_CS_TAB_ORIG_BUFFER=""
_CS_TAB_ORIG_POS=0

_CS_PS1_ORIG=""
_CS_PS1_EXPANDED=""
_CS_PS1_UPPER=""
_CS_PS1_LAST=""
_CS_PS1_LEN=0

_CS_PS1_ORIG="${PS1}"
PS1=""
echo
printf '\e[1A\e[2K' >&2

# ══════════════════════════════════════════════════════════════
# SEÇÃO 2 — ESTADO DO GHOST TEXT
# ══════════════════════════════════════════════════════════════

_gt_gh=$'\e[38;5;240m'   # cinza — ghost text
_gt_b0=$'\e[0m'

_GT_SUGGESTION=""
_GT_SUG_LOCKED=""
# Arquivo de configuração persistente
_GT_CONF_DIR="${HOME}/.shell_utils_configs"
_GT_CONF_FILE="${_GT_CONF_DIR}/bash-modes.conf"
[[ ! -d "${_GT_CONF_DIR}" ]] && mkdir -p "${_GT_CONF_DIR}" 2>/dev/null

# Lê o modo salvo; se não existir, usa BASH_GHOST_TEXT ou padrão 1
_gt_conf_read() {
    local key="$1" default="$2"
    if [[ -f "$_GT_CONF_FILE" ]]; then
        local val
        val=$(grep -m1 "^${key}=" "$_GT_CONF_FILE" 2>/dev/null | cut -d= -f2-)
        [[ -n "$val" ]] && { printf '%s' "$val"; return; }
    fi
    printf '%s' "$default"
}

_gt_conf_write() {
    local key="$1" val="$2"
    if [[ -f "$_GT_CONF_FILE" ]] && grep -q "^${key}=" "$_GT_CONF_FILE" 2>/dev/null; then
        sed -i "s|^${key}=.*|${key}=${val}|" "$_GT_CONF_FILE"
    else
        printf '%s=%s\n' "$key" "$val" >> "$_GT_CONF_FILE"
    fi
}

# Arquivo de estado por PID (compartilhado com subshells do bind -x)
_GT_STATE_FILE="${TMPDIR}/.bash_ghost_mode_$$"

# Inicializa: prioridade → variável de ambiente → conf salva → padrão 1
BASH_GHOST_TEXT="${BASH_GHOST_TEXT:-$(_gt_conf_read BASH_GHOST_TEXT 1)}"
printf "%s" "$BASH_GHOST_TEXT" > "$_GT_STATE_FILE"

# Arquivo de estado para sintax highlight
_CS_SINTAX_FILE="${TMPDIR}/.bash_sintax_mode_$$"

# Inicializa sintax: conf salva → padrão 1 (ativo)
BASH_SINTAX="${BASH_SINTAX:-$(_gt_conf_read BASH_SINTAX 1)}"
printf "%s" "$BASH_SINTAX" > "$_CS_SINTAX_FILE"

# Função unificada para alterar modos em tempo real e persistir
bash-mode() {
    local sub="${1:-}" val="${2:-}"
    case "$sub" in
        ghost)
            if [[ -z "$val" ]]; then
                printf 'uso: bash-mode ghost <0|1|2|3>\n' >&2; return 1
            fi
            printf "%s" "$val" > "$_GT_STATE_FILE"
            BASH_GHOST_TEXT="$val"
            _gt_conf_write BASH_GHOST_TEXT "$val"
            printf "ghost-text: modo %s\n" "$val"
            ;;
        sintax)
            if [[ -z "$val" ]]; then
                printf 'uso: bash-mode sintax <0|1>\n' >&2; return 1
            fi
            printf "%s" "$val" > "$_CS_SINTAX_FILE"
            BASH_SINTAX="$val"
            _gt_conf_write BASH_SINTAX "$val"
            printf "sintax-highlight: modo %s\n" "$val"
            ;;
        *)
            printf 'uso:\n'
            printf '  bash-mode ghost <0|1|2|3>  — ghost text (0=off, 1=completo, 2=por token, 3=por char)\n'
            printf '  bash-mode sintax <0|1>     — syntax highlight (0=off, 1=on)\n'
            ;;
    esac
}
declare -ga _GT_HIST=()

# ══════════════════════════════════════════════════════════════
# SEÇÃO 3 — PS1 (sintax highlight)
# ══════════════════════════════════════════════════════════════

_cs_ps1_update() {
    if (( BASH_VERSINFO[0] > 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] >= 4) )); then
        local _save_ps1="$PS1"
        PS1="$_CS_PS1_ORIG"
        _CS_PS1_EXPANDED="${PS1@P}"
        PS1="$_save_ps1"
    else
        local e="$_CS_PS1_ORIG"
        e="${e//\\u/$USER}"
        e="${e//\\h/${HOSTNAME%%.*}}"
        e="${e//\\w/$PWD}"
        e="${e//\\W/${PWD##*/}}"
        e="${e//\\$/$(( EUID == 0 ? '#' : '$' ))}"
        _CS_PS1_EXPANDED="$e"
    fi
    local plain
    plain=$(printf '%s' "$_CS_PS1_EXPANDED" \
        | sed 's/\x1b\[[0-9;]*[A-Za-z]//g;
               s/\x1b(B//g;
               s/\x1b][^\x07]*\x07//g;
               s/\x1b][^\x1b]*\x1b\\//g')

    # Separa em linha(s) superiores e última linha (onde o usuário digita)
    if [[ "$_CS_PS1_EXPANDED" == *$'\n'* ]]; then
        _CS_PS1_UPPER="${_CS_PS1_EXPANDED%$'\n'*}"$'\n'
        _CS_PS1_LAST="${_CS_PS1_EXPANDED##*$'\n'}"
    else
        _CS_PS1_UPPER=""
        _CS_PS1_LAST="$_CS_PS1_EXPANDED"
    fi

    local last="${plain##*$'\n'}"
    # Remove \[ e \] usados pelo bash para delimitar sequências não-imprimíveis
    last="${last//\\[/}"
    last="${last//\\]/}"
    _CS_PS1_LEN=${#last}
    printf 'PS1UPDATE expanded="%s" last="%s" len=%s\n' \
    "$_CS_PS1_EXPANDED" "$_CS_PS1_LAST" "$_CS_PS1_LEN" >> "${TMPDIR}/cs_debug.log"
}

# ══════════════════════════════════════════════════════════════
# SEÇÃO 4 — VALIDAÇÃO E COLORIZAÇÃO (sintax highlight)
# ══════════════════════════════════════════════════════════════

_cs_cmd_valid() {
    local full_cmd="$1"
    local cmd="${full_cmd%% *}"
    [[ -z "$cmd" ]] && return 1
    if [[ "$cmd" =~ ^~ ]]; then
        cmd="${cmd/#\~/$HOME}"
    fi
    if [[ "$cmd" == */* ]]; then
        local test_cmd="$cmd"
        [[ "$cmd" != /* ]] && test_cmd="$PWD/$cmd"
        [[ -x "$test_cmd" ]] && return 0
        return 1
    fi
    command -v "$cmd" &>/dev/null && return 0
    alias "$cmd" &>/dev/null && return 0
    return 1
}

_cs_colorize_token() {
    local token="$1"
    local is_first="${2:-0}"
    local blue_light=$'\e[38;2;3;173;252m'  # folders
    local purple=$'\e[38;5;135m'            # functions
    local yellow=$'\e[33m'                  # aliases
    local green=$'\e[32m'
    local cyan=$'\e[36m'
    local red=$'\e[31m'
    local reset=$'\e[0m'

    if [[ "$token" == */* ]]; then
        local expanded="$token"
        [[ "$expanded" =~ ^~ ]] && expanded="${expanded/#\~/$HOME}"
        local dir_part="${expanded%/*}"
        local original_dir="${token%/*}"
        local original_file="${token##*/}"
        [[ -z "$dir_part" ]] && dir_part="/"

        if [[ -d "$dir_part" ]] || [[ -d "$expanded" ]]; then
            printf '%s%s%s' "$blue_light" "$original_dir/" "$reset"
        else
            printf '%s%s%s' "$red" "$original_dir/" "$reset"
        fi

        if [[ -x "$expanded" && ! -d "$expanded" ]]; then
            printf '%s%s%s' "$green" "$original_file" "$reset"
        else
            printf '%s' "$original_file"
        fi
        return
    fi

    if (( is_first )); then
        if declare -f "$token" &>/dev/null; then
            printf '%s%s%s' "$purple" "$token" "$reset"
        elif alias "$token" &>/dev/null 2>&1; then
            printf '%s%s%s' "$yellow" "$token" "$reset"
        elif _cs_cmd_valid "$token"; then
            printf '%s%s%s' "$green" "$token" "$reset"
        else
            printf '%s%s%s' "$red" "$token" "$reset"
        fi
    else
        if [[ -x "$token" && -f "$token" ]]; then
            printf '%s%s%s' "$green" "$token" "$reset"
        else
            printf '%s' "$token"
        fi
    fi
}

_cs_buffer_colored() {
    local buf="$_CS_BUFFER"
    [[ -z "$buf" ]] && { printf '%s' "$buf"; return; }

    # Cores
    local green=$'\e[32m'
    local red=$'\e[31m'
    local blue=$'\e[34m'
    local yellow=$'\e[33m'    # operadores: | && || ; & 
    local cyan=$'\e[36m'      # redireções: > >> < 2> e operador =~
    local magenta=$'\e[35m'   # strings: "..." '...'
    local reset=$'\e[0m'

    local result=""
    local token=""
    local is_first=1          # 1 = próximo token de palavra é comando
    local i=0
    local c c2

    while (( i < ${#buf} )); do
        c="${buf:$i:1}"
        c2="${buf:$i:2}"

        # ── Strings entre aspas duplas ────────────────────────
        if [[ "$c" == '"' ]]; then
            # Flush token pendente
            if [[ -n "$token" ]]; then
                result+="$(_cs_colorize_token "$token" "$is_first")"
                token=""; is_first=0
            fi
            local str="" sc; (( i++ ))
            while (( i < ${#buf} )); do
                sc="${buf:$i:1}"
                (( i++ ))
                [[ "$sc" == '\\' ]] && (( i < ${#buf} )) && {
                    str+="$sc${buf:$i:1}"; (( i++ )); continue
                }
                [[ "$sc" == '"' ]] && break
                str+="$sc"
            done
            # Se o conteúdo parece caminho ou arquivo, coloriza como token
            if [[ "$str" == */* || "$str" == ~* ]]; then
                result+="\"$(_cs_colorize_token "$str" 0)\""
            else
                result+="${magenta}\"${str}\"${reset}"
            fi
            continue
        fi

        # ── Strings entre aspas simples ───────────────────────
        if [[ "$c" == "'" ]]; then
            if [[ -n "$token" ]]; then
                result+="$(_cs_colorize_token "$token" "$is_first")"
                token=""; is_first=0
            fi
            local str="" sc; (( i++ ))
            while (( i < ${#buf} )); do
                sc="${buf:$i:1}"
                (( i++ ))
                [[ "$sc" == "'" ]] && break
                str+="$sc"
            done
            # Se o conteúdo parece caminho ou arquivo, coloriza como token
            if [[ "$str" == */* || "$str" == ~* ]]; then
                result+="'$(_cs_colorize_token "$str" 0)'"
            else
                result+="${magenta}'${str}'${reset}"
            fi
            continue
        fi

        # ── Operadores duplos: && || >> =~ ───────────────────────────────
        if [[ "$c2" == '&&' || "$c2" == '||' || "$c2" == '>>' || "$c2" == '=~' ]]; then
            if [[ -n "$token" ]]; then
                result+="$(_cs_colorize_token "$token" "$is_first")"
                token=""
            fi
            if [[ "$c2" == '>>' || "$c2" == '=~' ]]; then
                result+="${cyan}${c2}${reset}"
            else
                result+="${yellow}${c2}${reset}"
            fi
            is_first=0   # após =~ o próximo token é o padrão (argumento)
            (( i += 2 )); continue
        fi

        # ── Operadores simples: | ; & > < ────────────────────
        if [[ "$c" == '|' || "$c" == ';' || "$c" == '&' ]]; then
            if [[ -n "$token" ]]; then
                result+="$(_cs_colorize_token "$token" "$is_first")"
                token=""
            fi
            result+="${yellow}${c}${reset}"
            is_first=1   # após operador, próxima palavra é comando
            (( i++ )); continue
        fi

        if [[ "$c" == '>' || "$c" == '<' ]]; then
            if [[ -n "$token" ]]; then
                result+="$(_cs_colorize_token "$token" "$is_first")"
                token=""
                # após redireção, próxima palavra é argumento (arquivo)
                is_first=0
            fi
            result+="${cyan}${c}${reset}"
            (( i++ )); continue
        fi

        # ── Espaço: flush token ───────────────────────────────
        if [[ "$c" == ' ' ]]; then
            if [[ -n "$token" ]]; then
                # Verifica se o token + espaço + próximas palavras formam um caminho
                # com espaços (ex: ~/Meus Projetos de Jogos)
                local rest="${buf:$i}"
                local candidate="${token}${rest}"
                local expanded_candidate="${candidate/#\~/$HOME}"
                # Tenta acumular até encontrar um caminho válido
                if [[ ! "$token" == */* ]] && (( ! is_first )); then
                    # Argumento: pode ser caminho com espaços — tenta lookahead
                    local lookahead="${token} "
                    local j=$(( i + 1 ))
                    local found_path=0
                    while (( j < ${#buf} )); do
                        local nc="${buf:$j:1}"
                        if [[ "$nc" == ' ' || "$nc" == $'\n' ]]; then
                            local exp="${lookahead/#\~/$HOME}"
                            if [[ -e "$exp" || -d "$exp" ]]; then
                                found_path=1; break
                            fi
                            lookahead+="$nc"
                        else
                            lookahead+="$nc"
                        fi
                        (( j++ ))
                    done
                    # Verifica o candidato final também
                    local exp_final="${lookahead/#\~/$HOME}"
                    [[ -e "$exp_final" || -d "$exp_final" ]] && found_path=1

                    if (( found_path )); then
                        token+="$c"; (( i++ )); continue
                    fi
                elif [[ "$token" == */* ]] || (( is_first == 0 )); then
                    local try="${token} "
                    local j=$(( i + 1 ))
                    while (( j < ${#buf} )); do
                        local ch="${buf:$j:1}"
                        try+="$ch"
                        local exp_try="${try/#\~/$HOME}"
                        if [[ -e "$exp_try" ]]; then
                            token+="$c"; (( i++ )); continue 2
                        fi
                        [[ "$ch" == ' ' ]] && {
                            exp_try="${try% }"
                            exp_try="${exp_try/#\~/$HOME}"
                            [[ -d "$exp_try" ]] && { token+="$c"; (( i++ )); continue 2; }
                        }
                        (( j++ ))
                    done
                fi
                result+="$(_cs_colorize_token "$token" "$is_first")"
                token=""; is_first=0
            fi
            result+="$c"; (( i++ )); continue
        fi

        token+="$c"; (( i++ ))
    done

    # Flush token final
    [[ -n "$token" ]] && result+="$(_cs_colorize_token "$token" "$is_first")"

    printf '%s' "$result"
}

# ══════════════════════════════════════════════════════════════
# SEÇÃO 5 — GHOST TEXT: HISTÓRICO E SUGESTÃO
# ══════════════════════════════════════════════════════════════

_gt_load_hist() {
    history -a 2>/dev/null; history -n 2>/dev/null
    local hfile="${HISTFILE:-$HOME/.bash_history}"
    _GT_HIST=()
    [[ -f "$hfile" ]] && \
        mapfile -t _GT_HIST < <(grep -v '^#[0-9]\+$' "$hfile" 2>/dev/null)
}

_gt_sync_hist() {
    history -a 2>/dev/null; history -n 2>/dev/null
    local hfile="${HISTFILE:-$HOME/.bash_history}"
    [[ -f "$hfile" ]] && \
        mapfile -t _GT_HIST < <(grep -v '^#[0-9]\+$' "$hfile" 2>/dev/null)
}

_gt_find_suggestion() {
    _GT_SUGGESTION=""
    local cur="$1"
    [[ ${#cur} -lt 1 ]] && return

    local i
    for (( i=${#_GT_HIST[@]}-1; i>=0; i-- )); do
        [[ "${_GT_HIST[$i]}" == "${cur}"* && "${_GT_HIST[$i]}" != "$cur" ]] \
            && { _GT_SUGGESTION="${_GT_HIST[$i]}"; return; }
    done

    local last_word="${cur##* }"
    if [[ -n "$last_word" ]]; then
        local match
        match=$(compgen -f -- "$last_word" 2>/dev/null | head -1)
        if [[ -n "$match" && "$match" != "$last_word" ]]; then
            _GT_SUGGESTION="${cur%"$last_word"}${match}"
            [[ -d "$match" ]] && _GT_SUGGESTION+="/"
        fi
    fi
}

_gt_get_suggestion() {
    local cur="$1"
    if [[ -z "$cur" ]]; then
        _GT_SUGGESTION=""; _GT_SUG_LOCKED=""; return
    fi
    if [[ -n "$_GT_SUG_LOCKED" && \
          "$_GT_SUG_LOCKED" == "${cur}"* && \
          "$_GT_SUG_LOCKED" != "$cur" ]]; then
        _GT_SUGGESTION="$_GT_SUG_LOCKED"
        return
    fi
    _gt_find_suggestion "$cur"
    _GT_SUG_LOCKED="$_GT_SUGGESTION"
}

_gt_get_suggestion_fresh() {
    _GT_SUG_LOCKED=""
    _gt_get_suggestion "$1"
}

# ══════════════════════════════════════════════════════════════
# SEÇÃO 6 — GHOST TEXT: OVERLAY
# Lê _CS_BUFFER e _CS_PS1_LEN (não READLINE_LINE)
# ══════════════════════════════════════════════════════════════

_gt_overlay() {
    local _gt_mode; _gt_mode=$(cat "$_GT_STATE_FILE" 2>/dev/null || printf "1")
    [[ "$_gt_mode" == "0" ]] && return

    local line="$_CS_BUFFER"
    local ghost=""

    if [[ -n "$_GT_SUGGESTION" && \
          "$_GT_SUGGESTION" == "${line}"* && \
          "$_GT_SUGGESTION" != "$line" ]]; then
        ghost="${_gt_gh}${_GT_SUGGESTION:${#line}}${_gt_b0}"
    fi

    # Posição: após o prompt + toda a linha (não apenas até o cursor),
    # pois o texto colorido já foi desenhado pelo _cs_redraw até o fim.
    # O ghost vai colado ao final do conteúdo atual do buffer.
    local col=$(( _CS_PS1_LEN + ${#line} + 1 ))

    if [[ -z "$ghost" ]]; then
        printf '\e7\e[%dG\e[K\e8' "$col" >&2
    else
        printf '\e7\e[%dG\e[K%s\e8' "$col" "$ghost" >&2
    fi
}

# ══════════════════════════════════════════════════════════════
# SEÇÃO 7 — REDESENHO COMBINADO
# Redesenha highlight + ghost em uma única chamada
# ══════════════════════════════════════════════════════════════

_cs_redraw() {
    printf 'REDRAW POS=%s BUF="%s" PS1LEN=%s\n' "$_CS_POS" "$_CS_BUFFER" "$_CS_PS1_LEN" >> "${TMPDIR}/cs_debug.log"
    [[ -z "$_CS_PS1_EXPANDED" ]] && _cs_ps1_update
    local _sintax_mode; _sintax_mode=$(cat "$_CS_SINTAX_FILE" 2>/dev/null || printf "1")

    # Verifica se o buffer tem múltiplas linhas
    if [[ "$_CS_BUFFER" == *$'\n'* ]]; then
        local -a lines=()
        mapfile -t lines <<< "$_CS_BUFFER"
        local nlines=${#lines[@]}

        # Sobe até a linha onde está o prompt ($) e limpa dali para baixo
        # _CS_ML_LINES guarda quantas linhas foram desenhadas (incluindo a do prompt)
        if (( _CS_ML_LINES > 1 )); then
            printf '\e[%dA' "$(( _CS_ML_LINES - 1 ))" >&2
        fi
        printf '\r\e[J' >&2

        # Desenha todas as linhas
        local li colored_line _save_buf
        for (( li=0; li < nlines; li++ )); do
            _save_buf="$_CS_BUFFER"
            _CS_BUFFER="${lines[$li]}"
            if [[ "$_sintax_mode" == "1" ]]; then
                colored_line=$(_cs_buffer_colored)
            else
                colored_line="${lines[$li]}"
            fi
            _CS_BUFFER="$_save_buf"

            if (( li == 0 )); then
                printf '%s%s' "$_CS_PS1_LAST" "$colored_line" >&2
            else
                printf '\n> %s' "$colored_line" >&2
            fi
        done

        _CS_ML_LINES=$nlines

        # Calcula linha e coluna do cursor
        local pos_remaining=$_CS_POS cur_line=0 cur_col=0
        for (( li=0; li < nlines; li++ )); do
            if (( pos_remaining <= ${#lines[$li]} )); then
                cur_line=$li; cur_col=$pos_remaining; break
            fi
            (( pos_remaining -= ${#lines[$li]} + 1 ))
        done

        local lines_from_bottom=$(( nlines - 1 - cur_line ))
        (( lines_from_bottom > 0 )) && printf '\e[%dA' "$lines_from_bottom" >&2

        local col
        if (( cur_line == 0 )); then
            col=$(( _CS_PS1_LEN + cur_col + 1 ))
        else
            col=$(( 3 + cur_col ))
        fi
        printf '\r\e[%dG' "$col" >&2

    else
        # Buffer de linha única
        _CS_ML_LINES=0
        local colored
        if [[ "$_sintax_mode" == "1" ]]; then
            colored=$(_cs_buffer_colored)
        else
            colored="$_CS_BUFFER"
        fi
        printf '\r\e[2K%s%s' "$_CS_PS1_LAST" "$colored" >&2
        # Calcula quantas linhas o conteúdo anterior pode ter ocupado
        local _term_cols; _term_cols=$(tput cols 2>/dev/null || printf '80')
        local _prev_len=$(( _CS_PS1_LEN + ${#_CS_BUFFER} ))
        local _prev_lines=$(( _prev_len / _term_cols ))
        # Sobe e limpa todas as linhas do wrap anterior
        if (( _prev_lines > 0 )); then
            printf '\e[%dA' "$_prev_lines" >&2
        fi
        printf '\r\e[J%s%s' "$_CS_PS1_LAST" "$colored" >&2
        printf '\r\e[%dG' "$(( ( _CS_PS1_LEN + _CS_POS ) % _term_cols + 1 ))" >&2
        _gt_overlay
    fi

    READLINE_LINE=""
    READLINE_POINT=0
}

_cs_show_prompt() {
    printf '\e[0m' >&2
    # Imprime o PS1 completo (com linha superior se houver)
    printf '%s' "$_CS_PS1_EXPANDED" >&2
}

# ══════════════════════════════════════════════════════════════
# SEÇÃO 8 — TAB COMPLETION (sintax highlight, inalterado)
# ══════════════════════════════════════════════════════════════

_cs_tab_reset() {
    _CS_TAB_STATE=-1
    _CS_TAB_COMPLETIONS=()
    _CS_TAB_WORD_START=0
    _CS_TAB_ORIG_BUFFER=""
    _CS_TAB_ORIG_POS=0
}

_cs_common_prefix() {
    local prefix="${1}"; shift
    local s
    for s in "$@"; do
        while [[ "${s:0:${#prefix}}" != "$prefix" ]]; do
            prefix="${prefix:0:$(( ${#prefix}-1 ))}"
            [[ -z "$prefix" ]] && { printf ''; return; }
        done
    done
    printf '%s' "$prefix"
}

_cs_do_shift_tab() {
    if (( _CS_TAB_STATE < 0 )); then
        _cs_redraw; return
    fi

    local n=${#_CS_TAB_COMPLETIONS[@]}
    _CS_TAB_STATE=$(( (_CS_TAB_STATE - 1 + n + 1) % (n + 1) ))

    if (( _CS_TAB_STATE == n )); then
        _CS_BUFFER="$_CS_TAB_ORIG_BUFFER"
        _CS_POS=$_CS_TAB_ORIG_POS
    else
        local completion="${_CS_TAB_COMPLETIONS[$_CS_TAB_STATE]}"
        local after="${_CS_TAB_ORIG_BUFFER:$_CS_TAB_ORIG_POS}"
        _CS_BUFFER="${_CS_TAB_ORIG_BUFFER:0:$_CS_TAB_WORD_START}${completion}${after}"
        _CS_POS=$(( _CS_TAB_WORD_START + ${#completion} ))
    fi
    _cs_redraw
}

_cs_quote_completion() {
    local completion="$1"
    if [[ "$completion" == *' '* ]]; then
        completion="${completion/#\~/$HOME}"
        completion="${completion//\"/}"
        # Trailing slash será preservada dentro das aspas
        completion="\"${completion}\""
    fi
    printf '%s' "$completion"
}

_cs_do_tab() {
    if (( _CS_TAB_STATE >= 0 )); then
        local n=${#_CS_TAB_COMPLETIONS[@]}
        _CS_TAB_STATE=$(( (_CS_TAB_STATE + 1) % (n + 1) ))
        if (( _CS_TAB_STATE == n )); then
            _CS_BUFFER="$_CS_TAB_ORIG_BUFFER"
            _CS_POS=$_CS_TAB_ORIG_POS
        else
            # local completion="${_CS_TAB_COMPLETIONS[$_CS_TAB_STATE]}"
            # local after="${_CS_TAB_ORIG_BUFFER:$_CS_TAB_ORIG_POS}"
            # _CS_BUFFER="${_CS_TAB_ORIG_BUFFER:0:$_CS_TAB_WORD_START}${completion}${after}"
            # _CS_POS=$(( _CS_TAB_WORD_START + ${#completion} ))
            local completion="${_CS_TAB_COMPLETIONS[$_CS_TAB_STATE]}"
            completion="$(_cs_quote_completion "$completion")"
            local after="${_CS_TAB_ORIG_BUFFER:$_CS_TAB_ORIG_POS}"
            _CS_BUFFER="${_CS_TAB_ORIG_BUFFER:0:$_CS_TAB_WORD_START}${completion}${after}"
            _CS_POS=$(( _CS_TAB_WORD_START + ${#completion} ))
        fi
        _cs_redraw; return
    fi

    local line="$_CS_BUFFER" point=$_CS_POS
    local after="${line:$point}"
    local word_start=$point
    while (( word_start > 0 )); do
        local prev_char="${line:$((word_start-1)):1}"
        if [[ "$prev_char" == " " ]]; then
            break
        fi
        (( word_start-- ))
    done

    local cur="${line:$word_start:$((point - word_start))}"
    local before_word="${line:0:$word_start}"
    local is_cmd=0
    # Remove tokens VAR=valor do início para detectar corretamente se é comando
    local before_stripped="${before_word}"
    while [[ "$before_stripped" =~ ^[[:space:]]*[A-Za-z_][A-Za-z_0-9]*=[^[:space:]]*[[:space:]]+ ]]; do
        before_stripped="${before_stripped#"${BASH_REMATCH[0]}"}"
    done
    if [[ -z "${before_stripped// /}" ]]; then
        local cur_check="${line:$word_start:$((point - word_start))}"
        cur_check="${cur_check//\"/}"
        local cur_expanded="${cur_check/#\~/$HOME}"
        if [[ "$cur_check" == ~* || "$cur_check" == /* || "$cur_check" == ./* || -d "$cur_expanded" ]]; then
            is_cmd=0
        else
            is_cmd=1
        fi
    fi

    local -a completions=()
    local cmd="${_CS_BUFFER%% *}"

    if (( ! is_cmd )) && declare -f _completion_loader &>/dev/null; then
        _completion_loader "$cmd" 2>/dev/null
        local comp_spec comp_func
        comp_spec=$(complete -p "$cmd" 2>/dev/null)
        comp_func=$(awk 'NF>=2{print $(NF-1)}' <<< "$comp_spec")
        if [[ -n "$comp_func" ]] && declare -f "$comp_func" &>/dev/null; then
            local -a all_words=()
            # Faz o split da linha em array sem usar eval:
            # read -ra respeita quoting simples mas não composto;
            # para completions isso é suficiente na maioria dos casos.
            read -ra all_words <<< "$line"
            local cword=${#all_words[@]}
            [[ "$line" =~ [[:space:]]$ ]] || (( cword-- ))
            (( cword < 0 )) && cword=0
            COMP_LINE="$line"; COMP_POINT=$point
            COMP_WORDS=("${all_words[@]}"); COMP_CWORD=$cword
            COMPREPLY=()
            "$comp_func" "$cmd" "$cur" "${all_words[$((cword-1))]:-}" 2>/dev/null
            completions=("${COMPREPLY[@]}")
        fi
    fi

    if (( ${#completions[@]} == 0 )); then
        # ── Variáveis: $PREFIXO<TAB> ─────────────────────────
        if [[ "$cur" == \$* ]]; then
            local var_prefix="${cur#\$}"
            local -a var_matches=()
            mapfile -t var_matches < <(compgen -v -- "$var_prefix" 2>/dev/null | sort -u)
            if (( ${#var_matches[@]} > 0 )); then
                local i
                for (( i=0; i < ${#var_matches[@]}; i++ )); do
                    completions+=( "\$${var_matches[$i]}" )
                done
            fi
        fi

        if (( ${#completions[@]} == 0 )); then
            if (( is_cmd )); then
                local -a cmd_matches=() dir_matches=()
                mapfile -t cmd_matches < <(compgen -c -- "$cur" 2>/dev/null | sort -u)
                mapfile -t dir_matches < <(compgen -d -- "$cur" 2>/dev/null | sort -u)
                local _di
                for _di in "${dir_matches[@]}"; do
                    [[ "$_di" != */ ]] && _di+="/"
                    cmd_matches+=( "$_di" )
                done
                mapfile -t completions < <(printf '%s\n' "${cmd_matches[@]}" | sort -u)
            else
                mapfile -t completions < <(compgen -f -- "$cur" 2>/dev/null | sort -u)
                local i
                for (( i=0; i < ${#completions[@]}; i++ )); do
                    [[ -d "${completions[$i]}" && "${completions[$i]}" != */ ]] \
                        && completions[$i]+="/"
                done

                # ── Fallback: glob por sufixo/substring ──────────────
                # Ativado quando compgen não encontra nada E o cur parece
                # um padrão parcial (começa com . ou contém * ? [ ou é só extensão)
                if (( ${#completions[@]} == 0 )) && [[ -n "$cur" ]]; then
                    local -a glob_matches=()
                    local glob_pat
                    if [[ "$cur" == *'*'* || "$cur" == *'?'* || "$cur" == *'['* ]]; then
                        glob_pat="$cur"       # wildcard explícito: passa direto
                    elif [[ "$cur" == .* ]]; then
                        glob_pat="*${cur}"    # .tar → *.tar  (sufixo)
                    else
                        glob_pat="*${cur}*"   # 47   → *47*   (substring)
                    fi
                    local _shopt_save
                    _shopt_save=$(shopt -p nullglob dotglob 2>/dev/null)
                    shopt -s nullglob dotglob
                    local dir_prefix="" base_pat="$glob_pat"
                    if [[ "$cur" == */* ]]; then
                        dir_prefix="${cur%/*}/"
                        base_pat="${glob_pat##*/}"
                    fi
                    local f
                    for f in ${dir_prefix}${base_pat}; do
                        [[ -d "$f" && "$f" != */ ]] && f+="/"
                        glob_matches+=( "$f" )
                    done
                    eval "$_shopt_save"
                    if (( ${#glob_matches[@]} > 0 )); then
                        mapfile -t completions < <(printf '%s\n' "${glob_matches[@]}" | sort -u)
                    fi
                fi
            fi
        fi
    fi

    # Filtra elementos vazios do array
    # Sem esse filtro, o glob fallback insere elementos vazios em completions,
    # fazendo ${#completions[@]} retornar 1 com array vazio e corrompendo o buffer.
    # Resultado: TAB em comando inexistente apagava a linha inteira.
    local -a _filtered=()
    local _ci
    for _ci in "${completions[@]}"; do
        [[ -n "$_ci" ]] && _filtered+=("$_ci")
    done
    completions=("${_filtered[@]}")

    local n=${#completions[@]}
    if (( n == 0 )); then
        printf '\a' >&2; _cs_redraw; return
    fi

    # if (( n == 1 )); then
    #     local completion="${completions[0]}"
    #     # Preserva ~ se o token original começava com ~
    #     if [[ "${cur}" == ~* ]]; then
    #         completion="${completion/#$HOME/\~}"
    #     fi
    #     local suffix=""
    #     if [[ -d "${completion/#\~/$HOME}" ]]; then
    #         suffix="/"
    #     elif [[ "${completion}" != */ ]]; then
    #         suffix=" "
    #     fi
    #     _CS_BUFFER="${line:0:$word_start}${completion}${suffix}${after}"
    #     _CS_POS=$(( word_start + ${#completion} + ${#suffix} ))
    #     _cs_tab_reset; _cs_redraw; return
    # fi

    if (( n == 1 )); then
        local completion="${completions[0]}"
        if [[ "${cur}" == ~* || "${line:0:$word_start}" == *~* ]]; then
            completion="${completion/#$HOME/\~}"
        fi
        completion="$(_cs_quote_completion "$completion")"
        local _clean="${completion//\"/}"
        local suffix=""
        if [[ -d "${_clean/#\~/$HOME}" ]]; then
            [[ "$_clean" != */ ]] && suffix="/"
        elif [[ "$_clean" != */ ]]; then
            suffix=" "
        fi
        _CS_BUFFER="${line:0:$word_start}${completion}${suffix}${after}"
        _CS_POS=$(( word_start + ${#completion} + ${#suffix} ))
        _cs_tab_reset; _cs_redraw; return
    fi
    
    local common
    common=$(_cs_common_prefix "${completions[@]}")

    if [[ "${#common}" -gt "${#cur}" ]]; then
        _CS_BUFFER="${line:0:$word_start}${common}${after}"
        _CS_POS=$(( word_start + ${#common} ))
        if (( is_cmd )); then
            local -a cmd_matches2=() dir_matches2=()
            mapfile -t cmd_matches2 < <(compgen -c -- "$common" 2>/dev/null | sort -u)
            mapfile -t dir_matches2 < <(compgen -d -- "$common" 2>/dev/null | sort -u)
            local _di2
            for _di2 in "${dir_matches2[@]}"; do
                [[ "$_di2" != */ ]] && _di2+="/"
                cmd_matches2+=( "$_di2" )
            done
            mapfile -t completions < <(printf '%s\n' "${cmd_matches2[@]}" | sort -u)
        else
            mapfile -t completions < <(compgen -f -- "$common" 2>/dev/null | sort -u)
            local i
            for (( i=0; i < ${#completions[@]}; i++ )); do
                [[ -d "${completions[$i]}" && "${completions[$i]}" != */ ]] \
                    && completions[$i]+="/"
            done
        fi
        # if (( ${#completions[@]} == 1 )); then
        #     local suffix=""; [[ "${completions[0]}" != */ ]] && suffix="/"
        #     _CS_BUFFER="${line:0:$word_start}${completions[0]}${suffix}${after}"
        #     _CS_POS=$(( word_start + ${#completions[0]} + ${#suffix} ))
        #     _cs_tab_reset; _cs_redraw; return
        # fi
        if (( ${#completions[@]} == 1 )); then
            local completion="${completions[0]}"
            if [[ "${cur}" == ~* || "${line:0:$word_start}" == *~* ]]; then
                completion="${completion/#$HOME/\~}"
            fi
            completion="$(_cs_quote_completion "$completion")"
            local suffix=""
            if [[ -d "${completion/#\~/$HOME}" || -d "${completion//\"/}" ]]; then
                suffix="/"
            elif [[ "${completion[0]}" != */ ]]; then
                suffix=" "
            fi
            _CS_BUFFER="${line:0:$word_start}${completion}${suffix}${after}"
            _CS_POS=$(( word_start + ${#completion} + ${#suffix} ))
            _cs_tab_reset; _cs_redraw; return
        fi
        _CS_TAB_COMPLETIONS=("${completions[@]}")
        _CS_TAB_STATE=-1
        _CS_TAB_WORD_START=$word_start
        _CS_TAB_ORIG_BUFFER="$_CS_BUFFER"
        _CS_TAB_ORIG_POS=$_CS_POS

        # Monta display sem prefixo de diretório duplicado
        local -a _disp2=()
        local _dc2
        local _typed2="${line:$word_start:$((point - word_start))}"
        _typed2="${_typed2//\"/}"
        local _typed_dir2=""
        [[ "$_typed2" == */* ]] && _typed_dir2="${_typed2%/*}/"
        for _dc2 in "${completions[@]}"; do
            _dc2="${_dc2//\"/}"
            [[ -n "$_typed_dir2" && "$_dc2" == "$_typed_dir2"* ]] \
                && _dc2="${_dc2#"$_typed_dir2"}"
            _disp2+=( "$_dc2" )
        done
        local _cur_prefix2="${_typed2##*/}"
        _cs_list_completions "$_cur_prefix2" "${_disp2[@]}"

        _CS_TAB_STATE=0
        local _first_c="${_CS_TAB_COMPLETIONS[0]}"
        _first_c="$(_cs_quote_completion "$_first_c")"
        _CS_BUFFER="${_CS_TAB_ORIG_BUFFER:0:$_CS_TAB_WORD_START}${_first_c}${after}"
        _CS_POS=$(( _CS_TAB_WORD_START + ${#_first_c} ))
        _cs_redraw; return
    fi

    _CS_TAB_COMPLETIONS=("${completions[@]}")
    _CS_TAB_STATE=-1
    _CS_TAB_WORD_START=$word_start
    _CS_TAB_ORIG_BUFFER="$line"
    _CS_TAB_ORIG_POS=$point

    if (( n > 50 )); then
        printf '\nExibir todos %d possíveis? (s/n) ' "$n" >&2
        local ans; read -r -n1 ans </dev/tty; printf '\n' >&2
        if [[ "$ans" != [sySY] ]]; then
            _CS_TAB_STATE=0
            local first="${_CS_TAB_COMPLETIONS[0]}"
            first="$(_cs_quote_completion "$first")"
            _CS_BUFFER="${line:0:$word_start}${first}${after}"
            _CS_POS=$(( word_start + ${#first} ))
            _cs_redraw; return
        fi
    fi

    # Antes de chamar _cs_list_completions, cria array sem aspas para exibição
    local -a _display_completions=()
    local _dc
    for _dc in "${completions[@]}"; do
        _display_completions+=( "${_dc//\"/}" )
    done
    # cur para highlight na lista: sem aspas e sem o caminho base já completado
    local cur_display="${line:$word_start:$((point - word_start))}"
    cur_display="${cur_display//\"/}"
    # Extrai só o último componente após a última / para usar como prefixo de highlight
    local cur_prefix="${cur_display##*/}"
    _cs_list_completions "$cur_prefix" "${_display_completions[@]}"
    _CS_TAB_STATE=0
    local first="${_CS_TAB_COMPLETIONS[0]}"
    first="$(_cs_quote_completion "$first")"
    _CS_BUFFER="${line:0:$word_start}${first}${after}"
    _CS_POS=$(( word_start + ${#first} ))
    _cs_redraw
}

_cs_colorize() {
    local item="$1" prefix="$2"
    local item_color=""
    if [[ "$item" == */ ]]; then item_color="01;34"
    elif [[ -x "$item" && -f "$item" ]] 2>/dev/null; then item_color="01;32"
    elif [[ -L "$item" ]] 2>/dev/null; then item_color="01;36"
    elif [[ -d "$item" ]] 2>/dev/null; then item_color="01;38;5;69"
    fi
    local esc=$'\e'
    local reset="${esc}[0m"

    if [[ -n "$prefix" && "$item" == */* ]]; then
        local trailing_slash=""
        local work="$item"
        [[ "$work" == */ ]] && trailing_slash="/" && work="${work%/}"
        local base="${work%/*}"
        local last="${work##*/}"

        # Se não há subdiretório real (ex: "Godot4/" sem path interno),
        # base == work — cai no comportamento simples para evitar duplicação
        if [[ "$base" == "$work" || -z "$last" ]]; then
            local rest="${item:${#prefix}}"
            if [[ -n "$item_color" ]]; then
                printf '%s%s' \
                    "${esc}[${item_color};04m${item:0:${#prefix}}${reset}${esc}[${item_color}m" \
                    "${rest}${reset}"
            else
                printf '%s%s' "${esc}[01;35;04m${item:0:${#prefix}}${reset}" "$rest"
            fi
            return
        fi
        base+="/"

        local highlighted_last
        if [[ "$last" == "$prefix"* ]]; then
            local rest_last="${last:${#prefix}}"
            if [[ -n "$item_color" ]]; then
                highlighted_last="${esc}[${item_color};04m${prefix}${reset}${esc}[${item_color}m${rest_last}${reset}"
            else
                highlighted_last="${esc}[01;35;04m${prefix}${reset}${rest_last}"
            fi
        else
            if [[ -n "$item_color" ]]; then
                highlighted_last="${esc}[${item_color}m${last}${reset}"
            else
                highlighted_last="${last}"
            fi
        fi

        if [[ -n "$item_color" ]]; then
            printf '%s%s%s' "${esc}[${item_color}m${base}${reset}" "$highlighted_last" "$trailing_slash"
        else
            printf '%s%s%s' "$base" "$highlighted_last" "$trailing_slash"
        fi
        return
    fi

    # Item sem '/' — comportamento original
    local rest="${item:${#prefix}}"
    if [[ -n "$item_color" ]]; then
        if [[ -n "$prefix" ]]; then
            printf '%s%s' "${esc}[${item_color};04m${prefix}${reset}${esc}[${item_color}m" "${rest}${reset}"
        else
            printf '%s' "${esc}[${item_color}m${item}${reset}"
        fi
    else
        if [[ -n "$prefix" ]]; then
            printf '%s%s' "${esc}[01;35;04m${prefix}${reset}" "$rest"
        else
            printf '%s' "$item"
        fi
    fi
}

_cs_list_completions() {
    local prefix="$1"; shift
    local -a items=("$@")
    printf '\n' >&2
    local max_len=0 item
    for item in "${items[@]}"; do
        (( ${#item} > max_len )) && max_len=${#item}
    done
    local term_cols; term_cols=$(tput cols 2>/dev/null || printf '80')
    local col_width=$(( max_len + 2 ))
    local num_cols=$(( term_cols / col_width ))
    (( num_cols < 1 )) && num_cols=1
    local idx=0
    for item in "${items[@]}"; do
        local colored_item
        colored_item=$(_cs_colorize "$item" "$prefix")
        local pad=$(( col_width - ${#item} ))
        printf '%s%*s' "$colored_item" "$pad" '' >&2
        (( ++idx % num_cols == 0 )) && printf '\n' >&2
    done
    (( idx % num_cols != 0 )) && printf '\n' >&2
}

# ══════════════════════════════════════════════════════════════
# SEÇÃO 9 — EDIÇÃO: inserção, backspace, delete, movimento
# Cada função de edição chama _cs_redraw (que inclui _gt_overlay)
# ══════════════════════════════════════════════════════════════

_cs_sync_from_readline() {
    # (( _CS_PASTING )) && return    # ← nunca sincroniza durante paste
    # if [[ -n "$READLINE_LINE" ]]; then
    #     local inserted="$READLINE_LINE"
    #     _CS_BUFFER="${_CS_BUFFER:0:$_CS_POS}${inserted}${_CS_BUFFER:$_CS_POS}"
    #     (( _CS_POS += ${#inserted} ))
    #     _GT_SUG_LOCKED=""
        READLINE_LINE=""
        READLINE_POINT=0
    # fi
}

_cs_insert() {
    printf 'INSERT char="%s" POS=%s BUF="%s"\n' "$1" "$_CS_POS" "$_CS_BUFFER" >> "${TMPDIR}/cs_debug.log"
    if (( _CS_PASTING )); then
        return
    fi
    _cs_sync_from_readline   # ← só chama quando NÃO está em paste
    _cs_tab_reset
    _GT_SUG_LOCKED=""
    _CS_BUFFER="${_CS_BUFFER:0:$_CS_POS}${1}${_CS_BUFFER:$_CS_POS}"
    (( _CS_POS++ ))
    _gt_get_suggestion_fresh "$_CS_BUFFER"
    _cs_redraw
}

_cs_backspace() {
    READLINE_LINE=""
    READLINE_POINT=0
    printf 'ANTES POS=%s BUF="%s" READLINE="%s"\n' "$_CS_POS" "$_CS_BUFFER" "$READLINE_LINE" >> "${TMPDIR}/cs_debug.log"
    _cs_sync_from_readline
    if (( _CS_POS == 0 )); then
        _cs_redraw; return
    fi
    _cs_tab_reset
    _CS_BUFFER="${_CS_BUFFER:0:$((_CS_POS-1))}${_CS_BUFFER:$_CS_POS}"
    (( _CS_POS-- ))
    _gt_get_suggestion "$_CS_BUFFER"           # com lock → revela progressivamente
    _cs_redraw
}

_cs_delete() {
    _cs_sync_from_readline
    _cs_tab_reset
    if (( _CS_POS < ${#_CS_BUFFER} )); then
        _CS_BUFFER="${_CS_BUFFER:0:$_CS_POS}${_CS_BUFFER:$((_CS_POS+1))}"
        _gt_get_suggestion "$_CS_BUFFER"
    fi
    _cs_redraw
}

_cs_left() {
    _cs_sync_from_readline
    if  (( _CS_ML_LINES > 0 )); then
        MULT_ON=1
    fi
    _cs_tab_reset
    (( _CS_POS > 0 )) && (( _CS_POS-- ))
    _cs_redraw
}

_cs_right() {
    _cs_sync_from_readline
    if  (( _CS_ML_LINES > 0 )); then
        MULT_ON=1
    fi
    _cs_tab_reset

    local _gt_mode; _gt_mode=$(cat "$_GT_STATE_FILE" 2>/dev/null || printf "1")
    if [[ "$_gt_mode" != "0" ]] && (( _CS_POS == ${#_CS_BUFFER} )); then
        # Busca sugestão sempre fresca (ignora lock para ter a sugestão completa)
        _gt_find_suggestion "$_CS_BUFFER"
        local sug="$_GT_SUGGESTION"

        if [[ -n "$sug" && "$sug" != "$_CS_BUFFER" ]]; then
            local mode="$_gt_mode"

            # Modo 1: aceita tudo de uma vez
            if [[ "$mode" == "1" ]]; then
                _CS_BUFFER="$sug"
                _CS_POS=${#_CS_BUFFER}
                _GT_SUGGESTION=""; _GT_SUG_LOCKED=""
                _cs_redraw; return

            # Modo 2: aceita próximo token (palavra)
            elif [[ "$mode" == "2" ]]; then
                local rest="${sug:${#_CS_BUFFER}}"
                if [[ "$rest" =~ ^([^[:space:]]+)([[:space:]]*) ]]; then
                    _CS_BUFFER+="${BASH_REMATCH[1]}${BASH_REMATCH[2]}"
                else
                    _CS_BUFFER="$sug"
                fi
                _CS_POS=${#_CS_BUFFER}
                if [[ "$_CS_BUFFER" == "$sug" ]]; then
                    _GT_SUGGESTION=""; _GT_SUG_LOCKED=""
                else
                    _GT_SUGGESTION="$sug"; _GT_SUG_LOCKED="$sug"
                fi
                _cs_redraw; return

            # Modo 3: aceita próximo caractere
            elif [[ "$mode" == "3" ]]; then
                _CS_BUFFER+="${sug:${#_CS_BUFFER}:1}"
                _CS_POS=${#_CS_BUFFER}
                if [[ "$_CS_BUFFER" == "$sug" ]]; then
                    _GT_SUGGESTION=""; _GT_SUG_LOCKED=""
                else
                    _GT_SUGGESTION="$sug"; _GT_SUG_LOCKED="$sug"
                fi
                _cs_redraw; return
            fi
        fi
    fi

    # Sem sugestão ou cursor não está no fim: move normalmente
    (( _CS_POS < ${#_CS_BUFFER} )) && (( _CS_POS++ ))
    _cs_redraw
}

# ── Ctrl+Left / Ctrl+Right: move por palavra ──────────────
_cs_word_left() {
    _cs_tab_reset
    # Recua sobre delimitadores
    while (( _CS_POS > 0 )) && [[ "${_CS_BUFFER:$((_CS_POS-1)):1}" == [' ''/''\''.|,;:~@!#$%^&*()=+\[\]{}<>?`-'] ]]; do
        (( _CS_POS-- ))
    done
    # Recua sobre a palavra
    while (( _CS_POS > 0 )) && [[ "${_CS_BUFFER:$((_CS_POS-1)):1}" != [' ''/''\''.|,;:~@!#$%^&*()=+\[\]{}<>?`-'] ]]; do
        (( _CS_POS-- ))
    done
    _cs_redraw
}

_cs_word_right() {
    _cs_tab_reset
    local len=${#_CS_BUFFER}
    # Avança sobre delimitadores
    while (( _CS_POS < len )) && [[ "${_CS_BUFFER:$_CS_POS:1}" == [' ''/''\''.|,;:~@!#$%^&*()=+\[\]{}<>?`-'] ]]; do
        (( _CS_POS++ ))
    done
    # Avança sobre a palavra
    while (( _CS_POS < len )) && [[ "${_CS_BUFFER:$_CS_POS:1}" != [' ''/''\''.|,;:~@!#$%^&*()=+\[\]{}<>?`-'] ]]; do
        (( _CS_POS++ ))
    done
    _cs_redraw
}

_cs_kill_word_delim() {
    _cs_tab_reset
    _GT_SUG_LOCKED=""
    (( _CS_POS > 0 )) || { _cs_redraw; return; }
    local before="${_CS_BUFFER:0:$_CS_POS}"
    local after="${_CS_BUFFER:$_CS_POS}"
    # Recua sobre delimitadores
    while (( ${#before} > 0 )) && [[ "${before: -1}" == [' ''/''\''.|,;:~@!#$%^&*()=+\[\]{}<>?`-'] ]]; do
        before="${before:0:${#before}-1}"
    done
    # Recua sobre a palavra
    while (( ${#before} > 0 )) && [[ "${before: -1}" != [' ''/''\''.|,;:~@!#$%^&*()=+\[\]{}<>?`-'] ]]; do
        before="${before:0:${#before}-1}"
    done
    _CS_POS=${#before}
    _CS_BUFFER="${before}${after}"
    _gt_get_suggestion "$_CS_BUFFER"
    _cs_redraw
}

_cs_kill_5() {
    _cs_tab_reset
    _GT_SUG_LOCKED=""
    (( _CS_POS > 0 )) || { _cs_redraw; return; }
    local del=$(( _CS_POS < 5 ? _CS_POS : 5 ))
    _CS_BUFFER="${_CS_BUFFER:0:$((_CS_POS-del))}${_CS_BUFFER:$_CS_POS}"
    (( _CS_POS -= del ))
    _gt_get_suggestion "$_CS_BUFFER"
    _cs_redraw
}

_cs_kill_5_right() {
    _cs_tab_reset
    _GT_SUG_LOCKED=""
    local len=${#_CS_BUFFER}
    (( _CS_POS < ${#_CS_BUFFER} )) || { _cs_redraw; return; }
    (( _CS_POS < len )) || return
    local del=$(( (len - _CS_POS) < 5 ? (len - _CS_POS) : 5 ))
    _CS_BUFFER="${_CS_BUFFER:0:$_CS_POS}${_CS_BUFFER:$((_CS_POS+del))}"
    _gt_get_suggestion "$_CS_BUFFER"
    _cs_redraw
}

_cs_kill_word_delim_right() {
    _cs_tab_reset
    _GT_SUG_LOCKED=""
    local len=${#_CS_BUFFER}
    (( _CS_POS < ${#_CS_BUFFER} )) || { _cs_redraw; return; }
    (( _CS_POS < len )) || return
    local after="${_CS_BUFFER:$_CS_POS}"
    local before="${_CS_BUFFER:0:$_CS_POS}"
    # Avança sobre delimitadores
    while (( ${#after} > 0 )) && [[ "${after:0:1}" == [' ''/''\''.|,;:~@!#$%^&*()=+\[\]{}<>?`-'] ]]; do
        after="${after:1}"
    done
    # Avança sobre a palavra
    while (( ${#after} > 0 )) && [[ "${after:0:1}" != [' ''/''\''.|,;:~@!#$%^&*()=+\[\]{}<>?`-'] ]]; do
        after="${after:1}"
    done
    _CS_BUFFER="${before}${after}"
    _gt_get_suggestion "$_CS_BUFFER"
    _cs_redraw
}

# Ctrl+G / Ctrl+F: aceita sugestão completa (todos os modos)
_cs_accept_ghost() {
    local _gt_mode; _gt_mode=$(cat "$_GT_STATE_FILE" 2>/dev/null || printf "1")
    [[ "$_gt_mode" == "0" ]] && return
    _gt_get_suggestion "$_CS_BUFFER"
    if [[ -n "$_GT_SUGGESTION" && "$_GT_SUGGESTION" == "${_CS_BUFFER}"* ]]; then
        _CS_BUFFER="$_GT_SUGGESTION"
        _CS_POS=${#_CS_BUFFER}
        _GT_SUG_LOCKED=""
    fi
    _cs_redraw
}

_cs_home() {
    _cs_sync_from_readline
    _cs_tab_reset
    _CS_POS=0
    _cs_redraw
}

_cs_end() {
    _cs_sync_from_readline
    _cs_tab_reset
    _CS_POS=${#_CS_BUFFER}
    _cs_redraw
}

_cs_kill_to_start() {
    _cs_tab_reset
    _GT_SUG_LOCKED=""
    _CS_BUFFER="${_CS_BUFFER:$_CS_POS}"
    _CS_POS=0
    _gt_get_suggestion "$_CS_BUFFER"
    _cs_redraw
}

_cs_kill_to_end() {
    _cs_tab_reset
    _GT_SUG_LOCKED=""
    _CS_BUFFER="${_CS_BUFFER:0:$_CS_POS}"
    _gt_get_suggestion "$_CS_BUFFER"
    _cs_redraw
}

_cs_kill_word() {
    _cs_tab_reset
    _GT_SUG_LOCKED=""
    (( _CS_POS > 0 )) || return
    local before after
    before=$(printf '%s' "${_CS_BUFFER:0:$_CS_POS}" | sed 's/[^ ]*[[:space:]]*$//')
    after="${_CS_BUFFER:$_CS_POS}"
    _CS_POS=${#before}
    _CS_BUFFER="${before}${after}"
    _gt_get_suggestion "$_CS_BUFFER"
    _cs_redraw
}

_cs_clear_screen() {
    _cs_tab_reset
    clear
    _cs_redraw
}

# ══════════════════════════════════════════════════════════════
# SEÇÃO 10 — HISTÓRICO (usa _CS_BUFFER; ghost atualizado junto)
# ══════════════════════════════════════════════════════════════

# !! NÃO ALTERAR ESTE BLOCO — LER ANTES DE QUALQUER MUDANÇA !!
#
# _cs_hist_load usa dois parsers distintos controlados pela flag MULT_ON:
#
# PROBLEMA:
#   Ao colar e executar uma função multiline no terminal, o bash registra
#   cada linha do corpo da função como uma entrada separada no histórico
#   em memória. O parser simples (read -r num cmd) interpreta essas linhas
#   corretamente como entradas de histórico, mas algumas contêm código bash
#   com substituições de parâmetro complexas, como:
#
#     expandido="${expandido//\\h/${HOSTNAME%%.*}}"
#
#   Quando essa string é armazenada em _CS_HIST_CACHE[$num] e posteriormente
#   recuperada pelo UP e passada para (( )) ou outro contexto aritmético,
#   o bash tenta avaliar o conteúdo e falha com:
#
#     bash: expandido="${expandido//\\h/${HOSTNAME%%.*}}": erro de sintaxe
#     aritmética: esperava operando (token de erro é
#     ""${expandido//\\h/${HOSTNAME%%.*}}"")
#
#   O parser simples não consegue distinguir essas entradas corrompidas
#   porque o `read -r num cmd` quebra em qualquer espaço, fazendo `num`
#   receber lixo quando a linha não tem o formato "  123  comando".
#
# SOLUÇÃO:
#   Após qualquer saída de modo multiline (_CS_ML_LINES > 0), a flag global
#   MULT_ON é setada e permanece ativa pelo resto da sessão do terminal.
#   Isso é intencional — uma vez que o histórico foi contaminado por linhas
#   de função multiline, ele permanece contaminado até o terminal ser fechado.
#   Não há como "descontaminar" o histórico em memória do bash sem reabrir
#   o terminal.
#
#   Com MULT_ON ativa, o parser robusto é usado: lê linha completa com
#   IFS= read -r, valida o número com regex, detecta entradas duplicadas
#   (mesmo número = linha de continuação multiline) e descarta entradas
#   com padrões de código interno (_CS_*, _GT_*, blocos de função, etc).
#
#   Sem MULT_ON (sessão limpa, sem multiline executado), o parser rápido
#   original é usado para máxima responsividade.
#
# CONSEQUÊNCIA DE REVERTER PARA PARSER ÚNICO:
#   Usar só o parser simples → bug aritmético após multiline.
#   Usar só o parser robusto → histórico antigo não é encontrado pelo UP
#   (entradas legítimas com substituições de parâmetro são descartadas
#   pelos filtros de segurança).
#
# ESTA DUALIDADE É A ÚNICA SOLUÇÃO VIÁVEL SEM REESCREVER O HISTFILE.
_cs_hist_load() {
    if  (( _CS_ML_LINES > 0 )); then
        MULT_ON=1
    fi
    if [[ -z "$MULT_ON" ]]; then
        if  (( _CS_ML_LINES > 0 )); then
            MULT_ON=1
            return
        fi
        _CS_HIST_CACHE=(); _CS_HIST_MAX=0
        local num cmd
        while read -r num cmd; do
            _CS_HIST_CACHE[$num]="$cmd"; _CS_HIST_MAX=$num
        done < <(HISTTIMEFORMAT='' history)
    else
        _CS_HIST_CACHE=(); _CS_HIST_MAX=0
        local num cmd last_num=-1
        while IFS= read -r line; do
            [[ "$line" =~ ^[[:space:]]*([0-9]+)[[:space:]]+(.*)$ ]] || continue
            num="${BASH_REMATCH[1]}"
            cmd="${BASH_REMATCH[2]}"
            [[ "$num" =~ ^[0-9]+$ ]]       || continue
            [[ "$num" == "$last_num" ]]     && { _CS_HIST_CACHE[$last_num]=""; continue; }
            last_num="$num"
            _CS_HIST_CACHE[$num]="$cmd"
            (( num > _CS_HIST_MAX )) && _CS_HIST_MAX=$num
        done < <(HISTTIMEFORMAT='' history)
    fi
}

_cs_hist_up() {
    if  (( _CS_ML_LINES > 0 )); then
        MULT_ON=1
    fi
    _cs_tab_reset
    if (( _CS_HIST_POS == -1 )); then
        _cs_hist_load
        (( _CS_HIST_MAX == 0 )) && return
        _CS_HIST_SAVED="$_CS_BUFFER"
        _CS_HIST_PREFIX="$_CS_BUFFER"
        _CS_HIST_POS=$(( _CS_HIST_MAX + 1 ))
    fi
    local i entry prefix="$_CS_HIST_PREFIX"
    for (( i = _CS_HIST_POS - 1; i >= 1; i-- )); do
        entry="${_CS_HIST_CACHE[$i]:-}"
        [[ -z "$entry" ]] && continue
        if [[ "$entry" == "$prefix"* && "$entry" != "$_CS_BUFFER" ]]; then
            _CS_HIST_POS=$i
            _CS_BUFFER="$entry"
            _CS_POS=${#_CS_BUFFER}
            _GT_SUG_LOCKED=""
            _gt_find_suggestion "$_CS_BUFFER"
            _cs_redraw; return
        fi
    done
    _cs_redraw  # topo do histórico: mantém linha atual visível
}

_cs_hist_down() {
    _cs_tab_reset
    if (( _CS_HIST_POS == -1 )); then
        _cs_redraw; return
    fi
    local i entry prefix="$_CS_HIST_PREFIX"
    for (( i = _CS_HIST_POS + 1; i <= _CS_HIST_MAX; i++ )); do
        entry="${_CS_HIST_CACHE[$i]:-}"
        [[ -z "$entry" ]] && continue
        if [[ "$entry" == "$prefix"* && "$entry" != "$_CS_BUFFER" ]]; then
            _CS_HIST_POS=$i
            _CS_BUFFER="$entry"
            _CS_POS=${#_CS_BUFFER}
            _GT_SUG_LOCKED=""
            _gt_find_suggestion "$_CS_BUFFER"
            _cs_redraw; return
        fi
    done
    _CS_HIST_POS=-1
    _CS_BUFFER="$_CS_HIST_SAVED"
    _CS_POS=${#_CS_BUFFER}
    _GT_SUG_LOCKED=""
    _gt_find_suggestion "$_CS_BUFFER"
    _cs_redraw
}

_cs_page_up() {
    _cs_tab_reset
    if (( _CS_HIST_MAX == 0 )); then
        _cs_hist_load
        (( _CS_HIST_MAX == 0 )) && return
    fi
    local first_entry="${_CS_HIST_CACHE[1]:-}"
    if [[ -n "$first_entry" ]]; then
        _CS_BUFFER="$first_entry"
        _CS_POS=${#_CS_BUFFER}
        _GT_SUG_LOCKED=""
        _gt_find_suggestion "$_CS_BUFFER"
        _cs_redraw
    else
        printf '\a' >&2
    fi
}

_cs_page_down() {
    _cs_tab_reset
    _CS_BUFFER=""
    _CS_POS=0
    _GT_SUGGESTION=""
    _GT_SUG_LOCKED=""
    _cs_redraw
}

# ══════════════════════════════════════════════════════════════
# SEÇÃO 11 — ENTER
# ══════════════════════════════════════════════════════════════

_cs_enter() {
    _cs_sync_from_readline
    # Durante bracketed paste, \n é parte do conteúdo colado
    if (( _CS_PASTING )); then
        _CS_PASTE_BUF+=$'\n'
        return
    fi

    _cs_tab_reset
    _GT_SUGGESTION=""; _GT_SUG_LOCKED=""

    # Verifica se a sintaxe está incompleta (multiline)
    # Acumula linhas anteriores + linha atual
    local full_cmd
    if [[ -n "$_CS_ML_BUFFER" ]]; then
        full_cmd="${_CS_ML_BUFFER}"$'\n'"${_CS_BUFFER}"
    else
        full_cmd="$_CS_BUFFER"
    fi

    # Testa se o comando está sintaticamente completo
    if [[ -n "$full_cmd" ]] && ! bash -n <(printf '%s\n' "$full_cmd") 2>/dev/null; then
        # Seta MULT_ON imediatamente ao detectar sintaxe incompleta.
        # Necessário para que _cs_hist_load use o parser robusto após a execução.
        # Se setado apenas no final de _cs_enter, _CS_ML_LINES já foi zerado
        # e o MULT_ON nunca seria ativado para funções digitadas linha a linha.
        MULT_ON=1
        # Sintaxe incompleta: acumula e mostra prompt secundário
        _CS_ML_BUFFER="$full_cmd"
        printf '\r\e[2K' >&2
        _cs_show_prompt
        printf '%s\n' "$_CS_BUFFER" >&2
        _CS_BUFFER=""
        _CS_POS=0
        _GT_SUGGESTION=""; _GT_SUG_LOCKED=""
        # Mostra prompt secundário (PS2)
        local ps2="${PS2:-"> "}"
        printf '%s' "$ps2" >&2
        READLINE_LINE=""; READLINE_POINT=0
        return
    fi

    # Sintaxe completa: executa
    local cmd_str="$full_cmd"
    _CS_ML_BUFFER=""   # limpa buffer multiline

    # !! NÃO ALTERAR ESTE BLOCO !!
    # Imprime apenas $_CS_PS1_LAST (última linha do PS1) + o comando digitado.
    # A linha superior do PS1 (ex: "user at host in ~/dir") já está na tela,
    # desenhada pelo _cs_redraw — reimprimi-la via _cs_show_prompt causaria
    # duplicação do prompt para qualquer PS1 multiline (com \n no meio).
    # Usar _cs_show_prompt aqui foi testado e confirmado como causa do bug.
    # Usar printf '\n' ou READLINE_LINE=" " também foi testado — o readline
    # apaga a linha do comando inteira, deixando só a saída sem prompt/cmd.
    # A única solução correta é esta: reescrever só a última linha do PS1.
    printf '\r\e[2K' >&2
    printf '%s%s\n' "$_CS_PS1_LAST" "$_CS_BUFFER" >&2

    _CS_HIST_POS=-1; _CS_HIST_SAVED=""; _CS_HIST_PREFIX=""
    _CS_BUFFER=""; _CS_POS=0

    if [[ -n "$cmd_str" ]]; then
        # Grava apenas se for comando de linha única (sem newlines internos)
        # Comandos multiline são gravados pelo próprio bash ao executar
        if [[ "$cmd_str" != *$'\n'* ]]; then
            history -s -- "$cmd_str"
        else
            # Para multiline: apaga o que o bash gravou linha a linha e grava o bloco completo
            # Descobre quantas linhas foram adicionadas e remove todas
            local _cs_nl_count
            _cs_nl_count=$(printf '%s' "$cmd_str" | grep -c $'\n')
            local _cs_i
            for (( _cs_i=0; _cs_i <= _cs_nl_count; _cs_i++ )); do
                history -d $(history 1 | awk '{print $1}') 2>/dev/null
            done
            history -s -- "$cmd_str"
        fi

        local stty_save
        stty_save=$(stty -g 2>/dev/null)

        # ── Remove binds para execução limpa do comando ───────
        # Letras e dígitos — remove via array sem eval
        local -a _cs_alpha=({a..z} {A..Z} {0..9})
        local _cs_c
        for _cs_c in "${_cs_alpha[@]}"; do
            bind -r "\"${_cs_c}\"" 2>/dev/null
        done

        local -a _cs_symbols=(
            ' ' '~' '!' '@' '#' '$' '%' '^' '&' '*' '(' ')' '-' '_'
            '=' '+' '[' ']' '{' '}' '|' ';' ':' "'" '"' '\' ',' '.'
            '/' '<' '>' '?' '`'
        )
        for _cs_c in "${_cs_symbols[@]}"; do
            bind -r "\"${_cs_c}\"" 2>/dev/null
        done

        bind -r '"\C-m"' '"\C-j"' '"\r"' '"\C-x\C-b"' \
                '"\e[3~"' '"\e[D"' '"\eOD"' '"\e[C"' '"\eOC"' \
                '"\C-a"' '"\e[H"' '"\eOH"' '"\C-e"' '"\e[F"' '"\eOF"' \
                '"\C-u"' '"\C-k"' '"\C-w"' '"\C-l"' \
                '"\e[A"' '"\eOA"' '"\e[B"' '"\eOB"' \
                '"\e[5~"' '"\e[6~"' '"\C-f"' '"\C-g"' 2>/dev/null

        #stty icanon echo icrnl 2>/dev/null
        PS1="$_CS_PS1_ORIG"

        # Se cmd_str é um caminho de diretório existente (autocd com espaços),
        # executa cd diretamente sem eval para preservar espaços no nome.
        # Aceita todas as formas: espaço literal, backslash-espaço, aspas duplas/simples.
        local _cs_trimmed="${cmd_str#"${cmd_str%%[![:space:]]*}"}"
        _cs_trimmed="${_cs_trimmed%"${_cs_trimmed##*[![:space:]]}"}"  # rtrim

        # Normaliza o caminho removendo aspas externas e backslashes de escape
        local _cs_path="$_cs_trimmed"

        # Remove aspas duplas externas: "caminho" → caminho
        if [[ "$_cs_path" == '"'*'"' ]]; then
            _cs_path="${_cs_path:1:${#_cs_path}-2}"
        fi

        # Remove aspas simples externas: 'caminho' → caminho
        if [[ "$_cs_path" == "'"*"'" ]]; then
            _cs_path="${_cs_path:1:${#_cs_path}-2}"
        fi

        # Remove backslashes de escape antes de espaços: "\ " → " "
        _cs_path="${_cs_path//\\ / }"

        # Expande ~ se presente
        _cs_path="${_cs_path/#\~/$HOME}"

        { [[ "$cmd_str" =~ zsh ]] || [[ "$cmd_str" =~ bash ]] || [[ "$cmd_str" =~ fish ]]; } && MULT_ON=1
        # Aliases não são expandidos corretamente pelo eval em certos contextos,
        # especialmente quando o script referenciado pelo alias usa argumentos
        # com flags ou caracteres especiais. A solução é expandir o alias
        # manualmente: extrai a definição real, remove o wrapper 'alias nome=...'
        # e concatena os argumentos originais antes de passar para o eval.
        #
        # Fluxo:
        #   alias meu-script='~/caminho/script.sh'
        #   meu-script --flag valor
        #   → eval '~/caminho/script.sh --flag valor'
        #
        # Usar bash -ic seria mais simples mas recarrega o .bashrc inteiro
        # a cada comando alias, tornando a execução muito lenta.

        stty sane # Restaura o terminal para o estado original, necessário para shell scripts com read
        local _cs_first_token="${cmd_str%% *}"

        # Detecta prefixo VAR=valor antes do comando real
        local _cs_env_prefix="" _cs_cmd_rest="$cmd_str"
        while [[ "$_cs_cmd_rest" =~ ^[[:space:]]*([A-Za-z_][A-Za-z_0-9]*=[^[:space:]]*)[[:space:]]+ ]]; do
            _cs_env_prefix+="${BASH_REMATCH[1]} "
            _cs_cmd_rest="${_cs_cmd_rest#*"${BASH_REMATCH[1]}"}"
            _cs_cmd_rest="${_cs_cmd_rest#"${_cs_cmd_rest%%[![:space:]]*}"}"
        done
        _cs_first_token="${_cs_cmd_rest%% *}"

        if [[ -n "$_cs_env_prefix" ]] && alias "$_cs_first_token" &>/dev/null 2>&1; then
            local _cs_alias_def
            _cs_alias_def=$(alias "$_cs_first_token" 2>/dev/null)
            _cs_alias_def="${_cs_alias_def#*\'}"
            _cs_alias_def="${_cs_alias_def%\'}"
            local _cs_alias_args="${_cs_cmd_rest#"$_cs_first_token"}"
            eval "env ${_cs_env_prefix} ${_cs_alias_def}${_cs_alias_args}"
        elif alias "$_cs_first_token" &>/dev/null 2>&1; then
            local _cs_alias_def
            _cs_alias_def=$(alias "$_cs_first_token" 2>/dev/null)
            _cs_alias_def="${_cs_alias_def#*\'}"
            _cs_alias_def="${_cs_alias_def%\'}"
            local _cs_alias_args="${_cs_cmd_rest#"$_cs_first_token"}"
            eval "${_cs_alias_def}${_cs_alias_args}"
        elif [[ -d "$_cs_path" ]]; then
            cd "$_cs_path" || true
        else
            eval "$cmd_str"
        fi

        _cs_exit_code=$? # Para ser usado no PS1 do bashrc

        [[ -n "$stty_save" ]] && stty "$stty_save" 2>/dev/null


        PS1=""
        _cs_ps1_update
        _cs_exit_code=0

        # ── Reinstala binds de caracteres sem eval ────────────
        # Função genérica de inserção com argumento capturado por closure via nameref
        # Estratégia: uma única função despachante lê o char do nome da função invocada.
        # bind -x chama a função pelo nome; o nome codifica o caractere.
        #
        # Para letras/dígitos: _cs_ki_<char> onde <char> é o caractere literal
        # (letras minúsculas, maiúsculas e dígitos são seguros como sufixo de nome).
        # Para símbolos: usamos funções nomeadas individualmente (já definidas globalmente).

        local _cs_lc _cs_uc _cs_d
        for _cs_lc in {a..z}; do
            bind -x "\"${_cs_lc}\": _cs_k_${_cs_lc}" 2>/dev/null
        done
        for _cs_uc in {A..Z}; do
            bind -x "\"${_cs_uc}\": _cs_k_${_cs_uc}" 2>/dev/null
        done
        for _cs_d in {0..9}; do
            bind -x "\"${_cs_d}\": _cs_k_n${_cs_d}" 2>/dev/null
        done

        # Reinstala símbolos (funções já existem no escopo global)
        bind -x '" ":  _cs_k_space'    2>/dev/null
        bind -x '"~":  _cs_k_tilde'    2>/dev/null
        bind -x '"!":  _cs_k_bang'     2>/dev/null
        bind -x '"@":  _cs_k_at'       2>/dev/null
        bind -x '"#":  _cs_k_hash'     2>/dev/null
        bind -x '"$":  _cs_k_dollar'   2>/dev/null
        bind -x '"%":  _cs_k_percent'  2>/dev/null
        bind -x '"^":  _cs_k_caret'    2>/dev/null
        bind -x '"&":  _cs_k_amp'      2>/dev/null
        bind -x '"*":  _cs_k_star'     2>/dev/null
        bind -x '"(":  _cs_k_lparen'   2>/dev/null
        bind -x '")":  _cs_k_rparen'   2>/dev/null
        bind -x '"-":  _cs_k_minus'    2>/dev/null
        bind -x '"_":  _cs_k_under'    2>/dev/null
        bind -x '"=":  _cs_k_equal'    2>/dev/null
        bind -x '"+":  _cs_k_plus'     2>/dev/null
        bind -x '"[":  _cs_k_lbrack'   2>/dev/null
        bind -x '"]":  _cs_k_rbrack'   2>/dev/null
        bind -x '"{":  _cs_k_lbrace'   2>/dev/null
        bind -x '"}":  _cs_k_rbrace'   2>/dev/null
        bind -x '"|":  _cs_k_pipe'     2>/dev/null
        bind -x '";":  _cs_k_semi'     2>/dev/null
        bind -x '":":  _cs_k_colon'    2>/dev/null
        bind -x "\"'\": _cs_k_squote"  2>/dev/null
        bind -x '"\"": _cs_k_dquote'   2>/dev/null
        bind -x '",":  _cs_k_comma'    2>/dev/null
        bind -x '".":  _cs_k_dot'      2>/dev/null
        bind -x '"/":  _cs_k_slash'    2>/dev/null
        bind -x '"<":  _cs_k_lt'       2>/dev/null
        bind -x '">":  _cs_k_gt'       2>/dev/null
        bind -x '"?":  _cs_k_question' 2>/dev/null
        bind -x '"\\": _cs_k_bslash'   2>/dev/null
        bind -x '"`":  _cs_k_backtick' 2>/dev/null

        # Reinstala binds de controle
        bind -x '"\C-x\C-b": _cs_backspace'  2>/dev/null
        bind -x '"\t":        _cs_do_tab'    2>/dev/null
        bind -x '"\e[1;2C":   _cs_do_tab'    2>/dev/null
        bind -x '"\e[Z": _cs_do_shift_tab'   2>/dev/null
        bind -x '"e[1;2D": _cs_do_shift_tab' 2>/dev/null
        bind -x '"\e[3~": _cs_delete'        2>/dev/null
        bind -x '"\e[D":  _cs_left'          2>/dev/null
        bind -x '"\eOD":  _cs_left'          2>/dev/null
        bind -x '"\e[C":  _cs_right'         2>/dev/null
        bind -x '"\eOC":  _cs_right'         2>/dev/null
        bind -x '"\C-a":  _cs_home'          2>/dev/null
        bind -x '"\e[H":  _cs_home'          2>/dev/null
        bind -x '"\eOH":  _cs_home'          2>/dev/null
        bind -x '"\C-e":  _cs_end'           2>/dev/null
        bind -x '"\e[F":  _cs_end'           2>/dev/null
        bind -x '"\eOF":  _cs_end'           2>/dev/null
        bind -x '"\C-u":  _cs_kill_to_start' 2>/dev/null
        bind -x '"\C-k":  _cs_kill_to_end'   2>/dev/null
        bind -x '"\C-w":  _cs_kill_word'     2>/dev/null
        bind -x '"\C-l":  _cs_clear_screen'  2>/dev/null
        bind -x '"\e[A":  _cs_hist_up'       2>/dev/null
        bind -x '"\eOA":  _cs_hist_up'       2>/dev/null
        bind -x '"\e[B":  _cs_hist_down'     2>/dev/null
        bind -x '"\eOB":  _cs_hist_down'     2>/dev/null
        bind -x '"\e[5~": _cs_page_up'       2>/dev/null
        bind -x '"\e[6~": _cs_page_down'     2>/dev/null
        bind -x '"\C-f":  _cs_accept_ghost'  2>/dev/null
        bind -x '"\C-g":  _cs_accept_ghost'  2>/dev/null
        bind -x '"\C-m":  _cs_enter'         2>/dev/null
        bind -x '"\e[200~": _cs_paste_start' 2>/dev/null
        bind -x '"\e[201~": _cs_paste_end'   2>/dev/null

        bind -x '"\e[1;5D": _cs_word_left'   2>/dev/null  # Ctrl+Left
        bind -x '"\e[1;5B": _cs_word_left'   2>/dev/null  # Ctrl+Down
        bind -x '"\e[1;5C": _cs_word_right'  2>/dev/null  # Ctrl+Right
        bind -x '"\e[1;5A": _cs_word_right'  2>/dev/null  # Ctrl+UP

        bind -x '"\e[3;5~": _cs_kill_word_delim_right'  2>/dev/null  # Ctrl+Delete
        bind -x '"\C-h":    _cs_kill_word_delim'        2>/dev/null  # Ctrl+Backspace
        bind -x '"\e[1;5F": _cs_kill_5'                 2>/dev/null  # Shift+Delete

        # Sincroniza histórico ghost após comando
        _gt_sync_hist
    fi

    # Se o cursor não está na coluna 0, pula linha antes do prompt
    printf '\e[6n' >&2
    local _cs_pos_report
    IFS='[;' read -sd R -ra _cs_pos_report -t 1 </dev/tty 2>/dev/null
    local _cs_col="${_cs_pos_report[2]:-1}"
    (( _cs_col > 1 )) && printf '\n' >&2
    _cs_show_prompt
    READLINE_LINE=""; READLINE_POINT=0
    tput sgr0
    if  (( _CS_ML_LINES > 0 )); then
        MULT_ON=1
    fi
}

# ══════════════════════════════════════════════════════════════
# SEÇÃO 12 — CTRL+C E PROMPT_COMMAND
# ══════════════════════════════════════════════════════════════

_cs_sigint() {
    PS1=""
    _cs_tab_reset
    _CS_BUFFER=""; _CS_POS=0; _CS_ML_BUFFER=""; _CS_ML_LINES=0
    _CS_PASTING=0; _CS_PASTE_BUF=""
    _CS_HIST_POS=-1; _CS_HIST_SAVED=""; _CS_HIST_PREFIX=""
    _GT_SUGGESTION=""; _GT_SUG_LOCKED=""
    READLINE_LINE=""; READLINE_POINT=0
}

_cs_prompt_cmd() {
    # Executa _prompt_command se ela existir no escopo atual (definida no ~/.bashrc).
    # Isso garante que notificações, fix_bash_history e demais hooks do usuário
    # sejam disparados normalmente, sem precisar duplicá-los aqui.
    PS1=""
    if declare -f _prompt_command &>/dev/null; then
        _prompt_command
    fi
    if (( _CS_ENTER_HANDLED )); then
        _CS_ENTER_HANDLED=0
        return 0
    fi
    _cs_ps1_update
    _gt_sync_hist
    _GT_SUGGESTION=""; _GT_SUG_LOCKED=""
    _CS_ML_BUFFER=""
    _cs_show_prompt
    _CS_BUFFER=""; _CS_POS=0
    READLINE_LINE=""; READLINE_POINT=0
}

# ══════════════════════════════════════════════════════════════
# SEÇÃO 13 — INSTALAÇÃO DE BINDS
# ══════════════════════════════════════════════════════════════

_cs_install_binds() {
    bind 'set echo-control-characters off' 2>/dev/null
    bind 'set enable-bracketed-paste on'   2>/dev/null
    bind 'set expand-tilde off'            2>/dev/null

    # ── Bracketed paste ───────────────────────────────────────
    # \e[200~ = início do paste; \e[201~= fim do paste
    _CS_PASTING=0
    _CS_PASTE_BUF=""

    _cs_paste_start() {
        _CS_PASTING=1
        _CS_PASTE_BUF=""
        READLINE_LINE=""
        READLINE_POINT=0
        _CS_WAYLAND_DISPLAY="$WAYLAND_DISPLAY"
        _CS_DISPLAY="$DISPLAY"

    }

    _cs_paste_end() {
        _CS_PASTING=0
        READLINE_LINE=""
        READLINE_POINT=0

        local pasted=""
        if [[ -n "$TERMUX_VERSION" ]] && command -v termux-clipboard-get &>/dev/null; then
            pasted=$(termux-clipboard-get 2>/dev/null)
        elif [[ -n "$_CS_WAYLAND_DISPLAY" ]] && command -v wl-paste &>/dev/null; then
            pasted=$(WAYLAND_DISPLAY="$_CS_WAYLAND_DISPLAY" \
                wl-paste --no-newline --type text/plain\;charset=utf-8 2>/dev/null)
            # Fallback sem type especificado
            if [[ -z "$pasted" ]]; then
                pasted=$(WAYLAND_DISPLAY="$_CS_WAYLAND_DISPLAY" \
                    wl-paste --no-newline 2>/dev/null)
            fi
        elif command -v xclip &>/dev/null; then
            pasted=$(DISPLAY="$_CS_DISPLAY" xclip -selection clipboard -o 2>/dev/null)
        elif command -v xsel &>/dev/null; then
            pasted=$(DISPLAY="$_CS_DISPLAY" xsel --clipboard --output 2>/dev/null)
        else
            pasted="$_CS_PASTE_BUF"
        fi

        pasted="${pasted//$'\r'/}"
        _CS_PASTE_BUF=""
        _CS_BUFFER="${_CS_BUFFER:0:$_CS_POS}${pasted}${_CS_BUFFER:$_CS_POS}"
        _CS_POS=$(( _CS_POS + ${#pasted} ))
        _CS_ML_LINES=1
        _gt_get_suggestion_fresh "$_CS_BUFFER"
        _cs_redraw
    }

    bind -x '"\e[200~": _cs_paste_start' 2>/dev/null
    bind -x '"\e[201~": _cs_paste_end'   2>/dev/null

    # ── Funções de inserção: letras minúsculas ────────────────
    # Definidas individualmente sem eval; o caractere é literal no corpo.
    _cs_k_a() { _cs_insert 'a'; }; bind -x '"a": _cs_k_a' 2>/dev/null
    _cs_k_b() { _cs_insert 'b'; }; bind -x '"b": _cs_k_b' 2>/dev/null
    _cs_k_c() { _cs_insert 'c'; }; bind -x '"c": _cs_k_c' 2>/dev/null
    _cs_k_d() { _cs_insert 'd'; }; bind -x '"d": _cs_k_d' 2>/dev/null
    _cs_k_e() { _cs_insert 'e'; }; bind -x '"e": _cs_k_e' 2>/dev/null
    _cs_k_f() { _cs_insert 'f'; }; bind -x '"f": _cs_k_f' 2>/dev/null
    _cs_k_g() { _cs_insert 'g'; }; bind -x '"g": _cs_k_g' 2>/dev/null
    _cs_k_h() { _cs_insert 'h'; }; bind -x '"h": _cs_k_h' 2>/dev/null
    _cs_k_i() { _cs_insert 'i'; }; bind -x '"i": _cs_k_i' 2>/dev/null
    _cs_k_j() { _cs_insert 'j'; }; bind -x '"j": _cs_k_j' 2>/dev/null
    _cs_k_k() { _cs_insert 'k'; }; bind -x '"k": _cs_k_k' 2>/dev/null
    _cs_k_l() { _cs_insert 'l'; }; bind -x '"l": _cs_k_l' 2>/dev/null
    _cs_k_m() { _cs_insert 'm'; }; bind -x '"m": _cs_k_m' 2>/dev/null
    _cs_k_n() { _cs_insert 'n'; }; bind -x '"n": _cs_k_n' 2>/dev/null
    _cs_k_o() { _cs_insert 'o'; }; bind -x '"o": _cs_k_o' 2>/dev/null
    _cs_k_p() { _cs_insert 'p'; }; bind -x '"p": _cs_k_p' 2>/dev/null
    _cs_k_q() { _cs_insert 'q'; }; bind -x '"q": _cs_k_q' 2>/dev/null
    _cs_k_r() { _cs_insert 'r'; }; bind -x '"r": _cs_k_r' 2>/dev/null
    _cs_k_s() { _cs_insert 's'; }; bind -x '"s": _cs_k_s' 2>/dev/null
    _cs_k_t() { _cs_insert 't'; }; bind -x '"t": _cs_k_t' 2>/dev/null
    _cs_k_u() { _cs_insert 'u'; }; bind -x '"u": _cs_k_u' 2>/dev/null
    _cs_k_v() { _cs_insert 'v'; }; bind -x '"v": _cs_k_v' 2>/dev/null
    _cs_k_w() { _cs_insert 'w'; }; bind -x '"w": _cs_k_w' 2>/dev/null
    _cs_k_x() { _cs_insert 'x'; }; bind -x '"x": _cs_k_x' 2>/dev/null
    _cs_k_y() { _cs_insert 'y'; }; bind -x '"y": _cs_k_y' 2>/dev/null
    _cs_k_z() { _cs_insert 'z'; }; bind -x '"z": _cs_k_z' 2>/dev/null

    # ── Funções de inserção: letras maiúsculas ────────────────
    _cs_k_A() { _cs_insert 'A'; }; bind -x '"A": _cs_k_A' 2>/dev/null
    _cs_k_B() { _cs_insert 'B'; }; bind -x '"B": _cs_k_B' 2>/dev/null
    _cs_k_C() { _cs_insert 'C'; }; bind -x '"C": _cs_k_C' 2>/dev/null
    _cs_k_D() { _cs_insert 'D'; }; bind -x '"D": _cs_k_D' 2>/dev/null
    _cs_k_E() { _cs_insert 'E'; }; bind -x '"E": _cs_k_E' 2>/dev/null
    _cs_k_F() { _cs_insert 'F'; }; bind -x '"F": _cs_k_F' 2>/dev/null
    _cs_k_G() { _cs_insert 'G'; }; bind -x '"G": _cs_k_G' 2>/dev/null
    _cs_k_H() { _cs_insert 'H'; }; bind -x '"H": _cs_k_H' 2>/dev/null
    _cs_k_I() { _cs_insert 'I'; }; bind -x '"I": _cs_k_I' 2>/dev/null
    _cs_k_J() { _cs_insert 'J'; }; bind -x '"J": _cs_k_J' 2>/dev/null
    _cs_k_K() { _cs_insert 'K'; }; bind -x '"K": _cs_k_K' 2>/dev/null
    _cs_k_L() { _cs_insert 'L'; }; bind -x '"L": _cs_k_L' 2>/dev/null
    _cs_k_M() { _cs_insert 'M'; }; bind -x '"M": _cs_k_M' 2>/dev/null
    _cs_k_N() { _cs_insert 'N'; }; bind -x '"N": _cs_k_N' 2>/dev/null
    _cs_k_O() { _cs_insert 'O'; }; bind -x '"O": _cs_k_O' 2>/dev/null
    _cs_k_P() { _cs_insert 'P'; }; bind -x '"P": _cs_k_P' 2>/dev/null
    _cs_k_Q() { _cs_insert 'Q'; }; bind -x '"Q": _cs_k_Q' 2>/dev/null
    _cs_k_R() { _cs_insert 'R'; }; bind -x '"R": _cs_k_R' 2>/dev/null
    _cs_k_S() { _cs_insert 'S'; }; bind -x '"S": _cs_k_S' 2>/dev/null
    _cs_k_T() { _cs_insert 'T'; }; bind -x '"T": _cs_k_T' 2>/dev/null
    _cs_k_U() { _cs_insert 'U'; }; bind -x '"U": _cs_k_U' 2>/dev/null
    _cs_k_V() { _cs_insert 'V'; }; bind -x '"V": _cs_k_V' 2>/dev/null
    _cs_k_W() { _cs_insert 'W'; }; bind -x '"W": _cs_k_W' 2>/dev/null
    _cs_k_X() { _cs_insert 'X'; }; bind -x '"X": _cs_k_X' 2>/dev/null
    _cs_k_Y() { _cs_insert 'Y'; }; bind -x '"Y": _cs_k_Y' 2>/dev/null
    _cs_k_Z() { _cs_insert 'Z'; }; bind -x '"Z": _cs_k_Z' 2>/dev/null

    # ── Funções de inserção: dígitos ──────────────────────────
    _cs_k_n0() { _cs_insert '0'; }; bind -x '"0": _cs_k_n0' 2>/dev/null
    _cs_k_n1() { _cs_insert '1'; }; bind -x '"1": _cs_k_n1' 2>/dev/null
    _cs_k_n2() { _cs_insert '2'; }; bind -x '"2": _cs_k_n2' 2>/dev/null
    _cs_k_n3() { _cs_insert '3'; }; bind -x '"3": _cs_k_n3' 2>/dev/null
    _cs_k_n4() { _cs_insert '4'; }; bind -x '"4": _cs_k_n4' 2>/dev/null
    _cs_k_n5() { _cs_insert '5'; }; bind -x '"5": _cs_k_n5' 2>/dev/null
    _cs_k_n6() { _cs_insert '6'; }; bind -x '"6": _cs_k_n6' 2>/dev/null
    _cs_k_n7() { _cs_insert '7'; }; bind -x '"7": _cs_k_n7' 2>/dev/null
    _cs_k_n8() { _cs_insert '8'; }; bind -x '"8": _cs_k_n8' 2>/dev/null
    _cs_k_n9() { _cs_insert '9'; }; bind -x '"9": _cs_k_n9' 2>/dev/null

    # ── Funções de inserção: símbolos ─────────────────────────
    _cs_k_space()    { _cs_insert ' ';  }; bind -x '" ":  _cs_k_space'    2>/dev/null
    _cs_k_tilde()    { _cs_insert '~';  }; bind -x '"~":  _cs_k_tilde'    2>/dev/null
    _cs_k_bang()     { _cs_insert '!';  }; bind -x '"!":  _cs_k_bang'     2>/dev/null
    _cs_k_at()       { _cs_insert '@';  }; bind -x '"@":  _cs_k_at'       2>/dev/null
    _cs_k_hash()     { _cs_insert '#';  }; bind -x '"#":  _cs_k_hash'     2>/dev/null
    _cs_k_dollar()   { _cs_insert '$';  }; bind -x '"$":  _cs_k_dollar'   2>/dev/null
    _cs_k_percent()  { _cs_insert '%';  }; bind -x '"%":  _cs_k_percent'  2>/dev/null
    _cs_k_caret()    { _cs_insert '^';  }; bind -x '"^":  _cs_k_caret'    2>/dev/null
    _cs_k_amp()      { _cs_insert '&';  }; bind -x '"&":  _cs_k_amp'      2>/dev/null
    _cs_k_star()     { _cs_insert '*';  }; bind -x '"*":  _cs_k_star'     2>/dev/null
    _cs_k_lparen()   { _cs_insert '(';  }; bind -x '"(":  _cs_k_lparen'   2>/dev/null
    _cs_k_rparen()   { _cs_insert ')';  }; bind -x '")":  _cs_k_rparen'   2>/dev/null
    _cs_k_minus()    { _cs_insert '-';  }; bind -x '"-":  _cs_k_minus'    2>/dev/null
    _cs_k_under()    { _cs_insert '_';  }; bind -x '"_":  _cs_k_under'    2>/dev/null
    _cs_k_equal()    { _cs_insert '=';  }; bind -x '"=":  _cs_k_equal'    2>/dev/null
    _cs_k_plus()     { _cs_insert '+';  }; bind -x '"+":  _cs_k_plus'     2>/dev/null
    _cs_k_lbrack()   { _cs_insert '[';  }; bind -x '"[":  _cs_k_lbrack'   2>/dev/null
    _cs_k_rbrack()   { _cs_insert ']';  }; bind -x '"]":  _cs_k_rbrack'   2>/dev/null
    _cs_k_lbrace()   { _cs_insert '{';  }; bind -x '"{":  _cs_k_lbrace'   2>/dev/null
    _cs_k_rbrace()   { _cs_insert '}';  }; bind -x '"}":  _cs_k_rbrace'   2>/dev/null
    _cs_k_pipe()     { _cs_insert '|';  }; bind -x '"|":  _cs_k_pipe'     2>/dev/null
    _cs_k_semi()     { _cs_insert ';';  }; bind -x '";":  _cs_k_semi'     2>/dev/null
    _cs_k_colon()    { _cs_insert ':';  }; bind -x '":":  _cs_k_colon'    2>/dev/null
    _cs_k_squote()   { _cs_insert "'";  }; bind -x "\"'\": _cs_k_squote"  2>/dev/null
    _cs_k_dquote()   { _cs_insert '"';  }; bind -x '"\"": _cs_k_dquote'   2>/dev/null
    _cs_k_comma()    { _cs_insert ',';  }; bind -x '",":  _cs_k_comma'    2>/dev/null
    _cs_k_dot()      { _cs_insert '.';  }; bind -x '".":  _cs_k_dot'      2>/dev/null
    _cs_k_slash()    { _cs_insert '/';  }; bind -x '"/":  _cs_k_slash'    2>/dev/null
    _cs_k_lt()       { _cs_insert '<';  }; bind -x '"<":  _cs_k_lt'       2>/dev/null
    _cs_k_gt()       { _cs_insert '>';  }; bind -x '">":  _cs_k_gt'       2>/dev/null
    _cs_k_question() { _cs_insert '?';  }; bind -x '"?":  _cs_k_question' 2>/dev/null
    _cs_k_bslash()   { _cs_insert '\'; }; bind -x '"\\": _cs_k_bslash'   2>/dev/null
    _cs_k_backtick() { _cs_insert '`';  }; bind -x '"`":  _cs_k_backtick' 2>/dev/null

    # Backspace via inputrc temporário
    local _cs_rc _cs_old_inputrc
    _cs_old_inputrc="${INPUTRC:-}"
    _cs_rc=$(mktemp "${TMPDIR}/cs-inputrc.XXXXXX" 2>/dev/null)
    {
        local _cs_user_rc="${INPUTRC:-$HOME/.inputrc}"
        [[ -f "$_cs_user_rc" ]] && printf '$include %s\n' "$_cs_user_rc"
        printf '"\C-?": "\C-x\C-b"\n'
        printf '"\C-h": "\C-x\C-b"\n'
    } > "$_cs_rc" 2>/dev/null
    INPUTRC="$_cs_rc" bind -f "$_cs_rc" 2>/dev/null
    rm -f "$_cs_rc" 2>/dev/null
    if [[ -z "$_cs_old_inputrc" ]]; then unset INPUTRC
    else INPUTRC="$_cs_old_inputrc"; fi

    bind -x '"\C-x\C-b": _cs_backspace'   2>/dev/null
    bind -x '"\t":        _cs_do_tab'     2>/dev/null
    bind -x '"\e[1;2C":   _cs_do_tab'     2>/dev/null
    bind -x '"\e[Z": _cs_do_shift_tab'    2>/dev/null
    bind -x '"\e[1;2D": _cs_do_shift_tab' 2>/dev/null
    bind -x '"\e[3~": _cs_delete'         2>/dev/null
    bind -x '"\e[D":  _cs_left'           2>/dev/null
    bind -x '"\eOD":  _cs_left'           2>/dev/null
    bind -x '"\e[C":  _cs_right'          2>/dev/null
    bind -x '"\eOC":  _cs_right'          2>/dev/null
    bind -x '"\C-a":  _cs_home'           2>/dev/null
    bind -x '"\e[H":  _cs_home'           2>/dev/null
    bind -x '"\eOH":  _cs_home'           2>/dev/null
    bind -x '"\C-e":  _cs_end'            2>/dev/null
    bind -x '"\e[F":  _cs_end'            2>/dev/null
    bind -x '"\eOF":  _cs_end'            2>/dev/null
    bind -x '"\C-u":  _cs_kill_to_start'  2>/dev/null
    bind -x '"\C-k":  _cs_kill_to_end'    2>/dev/null
    bind -x '"\C-w":  _cs_kill_word'      2>/dev/null
    bind -x '"\C-l":  _cs_clear_screen'   2>/dev/null
    bind -x '"\C-m":  _cs_enter'          2>/dev/null
    bind -x '"\e[A":  _cs_hist_up'        2>/dev/null
    bind -x '"\eOA":  _cs_hist_up'        2>/dev/null
    bind -x '"\e[B":  _cs_hist_down'      2>/dev/null
    bind -x '"\eOB":  _cs_hist_down'      2>/dev/null
    bind -x '"\e[5~": _cs_page_up'        2>/dev/null
    bind -x '"\e[6~": _cs_page_down'      2>/dev/null
    bind -x '"\C-f":  _cs_accept_ghost'   2>/dev/null
    bind -x '"\C-g":  _cs_accept_ghost'   2>/dev/null

    bind -x '"\e[1;5D": _cs_word_left'   2>/dev/null  # Ctrl+Left
    bind -x '"\e[1;5B": _cs_word_left'   2>/dev/null  # Ctrl+Down
    bind -x '"\e[1;5C": _cs_word_right'  2>/dev/null  # Ctrl+Right
    bind -x '"\e[1;5A": _cs_word_right'  2>/dev/null  # Ctrl+UP

    bind -x '"\e[3;5~": _cs_kill_word_delim_right'  2>/dev/null  # Ctrl+Delete
    bind -x '"\C-h":    _cs_kill_word_delim'        2>/dev/null  # Ctrl+Backspace
    bind -x '"\e[1;5F": _cs_kill_5'                 2>/dev/null  # Shift+Delete
    bind -x '"\e[1;2E": _cs_kill_5_right'           2>/dev/null  # Shift+5

    # Se não usar o trap, simplesmente históricos de apenas um comando poderão não ser exibidos corretamente.
    # Pois o _cs_sigint nunca é chamado! O Ctrl+C limpa a tela mas _CS_HIST_PREFIX fica com o valor do comando anterior.
    trap '_cs_sigint' INT # Mantenha descomentado
    _cs_sigint
}

# ══════════════════════════════════════════════════════════════
# SEÇÃO 14 — DESINSTALAR
# ══════════════════════════════════════════════════════════════

custom-shell-detach() {
    local -a _cs_alpha=({a..z} {A..Z} {0..9})
    local _cs_c
    for _cs_c in "${_cs_alpha[@]}"; do
        bind -r "\"${_cs_c}\"" 2>/dev/null
    done
    local -a _cs_syms=(
        ' ' '~' '!' '@' '#' '$' '%' '^' '&' '*' '(' ')'
        '-' '_' '=' '+' '[' ']' '{' '}' '|' ';' ':'
        ',' '.' '/' '<' '>' '?' '`'
    )
    for _cs_c in "${_cs_syms[@]}"; do
        bind -r "\"${_cs_c}\"" 2>/dev/null
    done
    bind -r "\"'\"" 2>/dev/null
    bind -r '"\""' 2>/dev/null
    bind -r '"\\"' 2>/dev/null
    bind -r '"\t"' '"\C-x\C-b"' '"\e[3~"' \
         '"\e[D"' '"\eOD"' '"\e[C"' '"\eOC"' \
         '"\C-a"' '"\e[H"' '"\eOH"' \
         '"\C-e"' '"\e[F"' '"\eOF"' \
         '"\C-u"' '"\C-k"' '"\C-w"' '"\C-l"' '"\C-m"' \
         '"\e[A"' '"\eOA"' '"\e[B"' '"\eOB"' \
         '"\e[5~"' '"\e[6~"' '"\C-f"' '"\C-g"' 2>/dev/null
    #trap - INT
    PS1="$_CS_PS1_ORIG"
    rm -f "$_GT_STATE_FILE" "$_CS_SINTAX_FILE" 2>/dev/null
    _CS_LOADED=0
    printf 'custom-shell-ghost desanexado.\n'
}

# ══════════════════════════════════════════════════════════════
# SEÇÃO 15 — ATIVAÇÃO
# ══════════════════════════════════════════════════════════════

_cs_install_binds
_cs_ps1_update
_gt_load_hist

if [[ -z "${PROMPT_COMMAND:-}" ]]; then
    PROMPT_COMMAND="_cs_prompt_cmd"
else
    PROMPT_COMMAND="_cs_prompt_cmd ${PROMPT_COMMAND}"
fi
