#!/usr/bin/env bash
# License: GPLv3
# Credits: Felipe Facundes

_ghost_path_cache_file="$HOME/.cache/ghost_path.cache"
_ghost_state_file="$HOME/.cache/ghost_mode"
_ghost_history_data=""
_ghost_suggestion=""
_ghost_path_cache=()
_ghost_prompt_len=0
_ghost_mode="clean"
_ghost_last_ps1=""

_ghost_load_state() {
    if [[ -f "$_ghost_state_file" ]]; then
        _ghost_mode=$(cat "$_ghost_state_file" 2>/dev/null || echo "clean")
    else
        _ghost_mode="clean"
    fi
}

_ghost_save_state() {
    mkdir -p "$(dirname "$_ghost_state_file")" 2>/dev/null
    echo "$_ghost_mode" | tee "$_ghost_state_file" > /dev/null
}

_ghost_init_history() {
    _ghost_history_data=$(
        fc -ln -10000 2>/dev/null | sed 's/^[[:space:]]*//' | tac | awk '!seen[$0]++'
    )
}

_ghost_update_prompt_len() {
    local current_ps1="${PS1@P}"
    if [[ "$current_ps1" != "$_ghost_last_ps1" || $_ghost_prompt_len -eq 0 ]]; then
        _ghost_last_ps1="$current_ps1"
        local plain
        plain=$(printf '%s' "$current_ps1" \
            | sed -E $'s/\x1b\\[[0-9;?]*[a-zA-Z]//g; s/\x01|\x02//g')
        local last="${plain##*$'\n'}"
        _ghost_prompt_len=${#last}

        # Extrai última linha do ps1 E remove \x01 \x02
        local ps1_last_raw="${current_ps1##*$'\n'}"
        _ghost_ps1_last=$(printf '%s' "$ps1_last_raw" \
            | sed $'s/\x01//g; s/\x02//g')
    fi
}

_ghost_refresh() {
    history -a
    _ghost_init_history
    _ghost_update_prompt_len
    if [[ "$_ghost_mode" == "ghost" ]]; then
        printf '\e[?2026h' >/dev/tty
    fi
}

ghost_path_cache() {
    IFS=':' read -ra paths <<< "$PATH"
    mapfile -t _ghost_path_cache < <(
        find "${paths[@]}" -maxdepth 1 -type f -executable 2>/dev/null |
        sed 's|.*/||' | sort -u
    )
    mkdir -p "$(dirname "$_ghost_path_cache_file")" 2>/dev/null
    [[ -f "$_ghost_path_cache_file" ]] && rm -f "$_ghost_path_cache_file"
    printf '%s\n' "${_ghost_path_cache[@]}" > "$_ghost_path_cache_file"
}

_ghost_load_path_cache() {
    local regenerate=false
    if [[ ! -f "$_ghost_path_cache_file" ]]; then
        regenerate=true
    else
        local file_time; file_time=$(stat -c %Y "$_ghost_path_cache_file" 2>/dev/null || stat -f %m "$_ghost_path_cache_file" 2>/dev/null)
        local now; now=$(date +%s)
        local age=$(( now - file_time ))
        [[ $age -gt 86400 ]] && regenerate=true
    fi
    if $regenerate; then
        ghost_path_cache
    else
        mapfile -t _ghost_path_cache < "$_ghost_path_cache_file"
    fi
}

_ghost_get_suggestion() {
    _ghost_suggestion=""
    [[ -z "$READLINE_LINE" ]] && return
    local prefix="$READLINE_LINE"
    while IFS= read -r line; do
        if [[ "$line" == "$prefix"* && "$line" != "$prefix" ]]; then
            _ghost_suggestion="${line#$prefix}"
            return
        fi
    done <<< "$_ghost_history_data"
    for cmd in "${_ghost_path_cache[@]}"; do
        if [[ "$cmd" == "$prefix"* && "$cmd" != "$prefix" ]]; then
            _ghost_suggestion="${cmd#$prefix}"
            return
        fi
    done
    local dirs; dirs=$(find . -maxdepth 1 -type d -name "${prefix}*" 2>/dev/null | head -1 | sed 's|^\./||')
    if [[ -n "$dirs" ]]; then _ghost_suggestion="${dirs#$prefix}"; return; fi
    local files; files=$(find . -maxdepth 1 -type f -name "${prefix}*" 2>/dev/null | head -1 | sed 's|^\./||')
    if [[ -n "$files" ]]; then _ghost_suggestion="${files#$prefix}"; return; fi
}

# ═══════════════════════════════════════════════
# SYNTAX HIGHLIGHT
# ═══════════════════════════════════════════════

_ghost_cmd_valid() {
    local cmd="${1%% *}"
    [[ -z "$cmd" ]] && return 1
    [[ "$cmd" =~ ^~ ]] && cmd="${cmd/#\~/$HOME}"
    if [[ "$cmd" == */* ]]; then
        local t="$cmd"; [[ "$cmd" != /* ]] && t="$PWD/$cmd"
        [[ -x "$t" ]] && return 0; return 1
    fi
    command -v "$cmd" &>/dev/null && return 0
    alias "$cmd" &>/dev/null && return 0
    return 1
}

_ghost_color_token() {
    local token="$1" is_first="${2:-0}"
    local G=$'\e[32m' R=$'\e[31m' P=$'\e[38;5;135m' Y=$'\e[33m' BL=$'\e[38;2;3;173;252m' RS=$'\e[0m'
    if [[ "$token" == */* ]]; then
        local e="$token"; [[ "$e" =~ ^~ ]] && e="${e/#\~/$HOME}"
        if   [[ -d "$e" ]];            then printf '%s%s%s' "$BL" "$token" "$RS"
        elif [[ -x "$e" && -f "$e" ]]; then printf '%s%s%s' "$G"  "$token" "$RS"
        else                                printf '%s%s%s' "$R"  "$token" "$RS"; fi
        return
    fi
    if (( is_first )); then
        if   declare -f "$token" &>/dev/null;    then printf '%s%s%s' "$P" "$token" "$RS"
        elif alias    "$token" &>/dev/null 2>&1; then printf '%s%s%s' "$Y" "$token" "$RS"
        elif _ghost_cmd_valid "$token";          then printf '%s%s%s' "$G" "$token" "$RS"
        else                                          printf '%s%s%s' "$R" "$token" "$RS"; fi
    else
        printf '%s' "$token"
    fi
}

_ghost_colorize() {
    local buf="$1"
    [[ -z "$buf" ]] && return
    local M=$'\e[35m' Y=$'\e[33m' C=$'\e[36m' RS=$'\e[0m'
    local result="" token="" is_first=1 i=0 c c2 sc str
    while (( i < ${#buf} )); do
        c="${buf:$i:1}"; c2="${buf:$i:2}"
        if [[ "$c" == '"' ]]; then
            [[ -n "$token" ]] && { result+="$(_ghost_color_token "$token" "$is_first")"; token=""; is_first=0; }
            str=""; (( i++ ))
            while (( i < ${#buf} )); do
                sc="${buf:$i:1}"; (( i++ ))
                [[ "$sc" == '\\' && $i -lt ${#buf} ]] && { str+="$sc${buf:$i:1}"; (( i++ )); continue; }
                [[ "$sc" == '"' ]] && break; str+="$sc"
            done
            result+="${M}\"${str}\"${RS}"; continue
        fi
        if [[ "$c" == "'" ]]; then
            [[ -n "$token" ]] && { result+="$(_ghost_color_token "$token" "$is_first")"; token=""; is_first=0; }
            str=""; (( i++ ))
            while (( i < ${#buf} )); do
                sc="${buf:$i:1}"; (( i++ ))
                [[ "$sc" == "'" ]] && break; str+="$sc"
            done
            result+="${M}'${str}'${RS}"; continue
        fi
        if [[ "$c2" == '&&' || "$c2" == '||' ]]; then
            [[ -n "$token" ]] && { result+="$(_ghost_color_token "$token" "$is_first")"; token=""; }
            result+="${Y}${c2}${RS}"; is_first=1; (( i+=2 )); continue
        fi
        if [[ "$c2" == '>>' || "$c2" == '=~' ]]; then
            [[ -n "$token" ]] && { result+="$(_ghost_color_token "$token" "$is_first")"; token=""; }
            result+="${C}${c2}${RS}"; is_first=0; (( i+=2 )); continue
        fi
        if [[ "$c" == '|' || "$c" == ';' || "$c" == '&' ]]; then
            [[ -n "$token" ]] && { result+="$(_ghost_color_token "$token" "$is_first")"; token=""; }
            result+="${Y}${c}${RS}"; is_first=1; (( i++ )); continue
        fi
        if [[ "$c" == '>' || "$c" == '<' ]]; then
            [[ -n "$token" ]] && { result+="$(_ghost_color_token "$token" "$is_first")"; token=""; is_first=0; }
            result+="${C}${c}${RS}"; (( i++ )); continue
        fi
        if [[ "$c" == ' ' ]]; then
            [[ -n "$token" ]] && { result+="$(_ghost_color_token "$token" "$is_first")"; token=""; is_first=0; }
            result+="$c"; (( i++ )); continue
        fi
        token+="$c"; (( i++ ))
    done
    [[ -n "$token" ]] && result+="$(_ghost_color_token "$token" "$is_first")"
    printf '%s' "$result"
}

# ═══════════════════════════════════════════════
# RENDER — ghost + syntax juntos
# Usa save/restore cursor igual ao ghost original
# O syntax redesenha o comando colorido no lugar certo
# O ghost desenha a sugestão depois
# ═══════════════════════════════════════════════

_ghost_render_ghost() {
    _ghost_update_prompt_len

    [[ $READLINE_POINT -eq ${#READLINE_LINE} ]] \
        && _ghost_get_suggestion \
        || _ghost_suggestion=""

    local col=$(( _ghost_prompt_len + READLINE_POINT + 1 ))
    local colored=""
    [[ -n "$READLINE_LINE" ]] && colored=$(_ghost_colorize "$READLINE_LINE")

    printf '\r\e[2K' >/dev/tty
    printf '%s' "$_ghost_ps1_last" >/dev/tty
    printf '%s' "$colored" >/dev/tty

    if [[ -n "$_ghost_suggestion" ]]; then
        printf '\e[38;5;244m%s\e[0m' "$_ghost_suggestion" >/dev/tty
    fi

    printf '\e[%dG' "$col" >/dev/tty
}

_ghost_left_ghost() {
    READLINE_POINT=$(( READLINE_POINT > 0 ? READLINE_POINT - 1 : 0 ))
    _ghost_render_ghost
}

_ghost_self_insert() {
    READLINE_LINE="${READLINE_LINE:0:$READLINE_POINT}${_ghost_char}${READLINE_LINE:$READLINE_POINT}"
    READLINE_POINT=$(( READLINE_POINT + 1 ))
    # Força o render acontecer após o readline terminar
    READLINE_LINE="$READLINE_LINE"  # no-op para forçar flush
    _ghost_render_ghost
}

_ghost_accept_all() {
    if [[ $READLINE_POINT -lt ${#READLINE_LINE} ]]; then
        READLINE_POINT=$(( READLINE_POINT + 1 ))
    elif [[ -n "$_ghost_suggestion" ]]; then
        READLINE_LINE+="$_ghost_suggestion"
        READLINE_POINT=${#READLINE_LINE}
        _ghost_suggestion=""
    fi
    _ghost_render_ghost
}

_ghost_is_delimiter() {
    [[ "$1" =~ [\ =/\;.,|\\:_-] ]]
}

_ghost_accept_word2() {
    if [[ $READLINE_POINT -lt ${#READLINE_LINE} ]]; then
        local after="${READLINE_LINE:$READLINE_POINT}"
        while [[ "${after:0:1}" == " " ]]; do
            READLINE_POINT=$(( READLINE_POINT + 1 ))
            after="${READLINE_LINE:$READLINE_POINT}"
        done
        while [[ -n "$after" && "${after:0:1}" != " " ]]; do
            READLINE_POINT=$(( READLINE_POINT + 1 ))
            after="${READLINE_LINE:$READLINE_POINT}"
        done
    elif [[ -n "$_ghost_suggestion" ]]; then
        local word="${_ghost_suggestion%% *}"
        [[ "$_ghost_suggestion" == *' '* ]] && word+=' '
        READLINE_LINE+="$word"
        READLINE_POINT=${#READLINE_LINE}
        _ghost_suggestion="${_ghost_suggestion#"$word"}"
    fi
    _ghost_render_ghost
}

_ghost_accept_word() {
    if [[ $READLINE_POINT -lt ${#READLINE_LINE} ]]; then
        local after="${READLINE_LINE:$READLINE_POINT}"
        while [[ -n "$after" ]] && _ghost_is_delimiter "${after:0:1}"; do
            READLINE_POINT=$(( READLINE_POINT + 1 ))
            after="${READLINE_LINE:$READLINE_POINT}"
        done
        while [[ -n "$after" ]] && ! _ghost_is_delimiter "${after:0:1}"; do
            READLINE_POINT=$(( READLINE_POINT + 1 ))
            after="${READLINE_LINE:$READLINE_POINT}"
        done
    elif [[ -n "$_ghost_suggestion" ]]; then
        local remaining="$_ghost_suggestion" word=""
        while [[ -n "$remaining" ]]; do
            local char="${remaining:0:1}"
            if _ghost_is_delimiter "$char"; then
                if [[ -n "$word" ]]; then break; fi
                word+="$char"; remaining="${remaining:1}"
                if [[ "$char" == " " ]]; then
                    while [[ "${remaining:0:1}" == " " ]]; do word+=" "; remaining="${remaining:1}"; done
                fi
                break
            else
                word+="$char"; remaining="${remaining:1}"
            fi
        done
        [[ -z "$word" ]] && word="$remaining"
        READLINE_LINE+="$word"
        READLINE_POINT=${#READLINE_LINE}
        _ghost_suggestion="${_ghost_suggestion#"$word"}"
    fi
    _ghost_render_ghost
}

_ghost_backspace_ghost() {
    if [[ $READLINE_POINT -gt 0 ]]; then
        READLINE_LINE="${READLINE_LINE:0:$((READLINE_POINT - 1))}${READLINE_LINE:$READLINE_POINT}"
        READLINE_POINT=$(( READLINE_POINT - 1 ))
    fi
    _ghost_render_ghost
}

_ghost_backward_kill_word_ghost() {
    if [[ $READLINE_POINT -gt 0 ]]; then
        local before="${READLINE_LINE:0:$READLINE_POINT}"
        local after="${READLINE_LINE:$READLINE_POINT}"
        local new_point=$READLINE_POINT
        while [[ $new_point -gt 0 ]] && _ghost_is_delimiter "${before:$((new_point-1)):1}"; do
            new_point=$(( new_point - 1 ))
        done
        while [[ $new_point -gt 0 ]] && ! _ghost_is_delimiter "${before:$((new_point-1)):1}"; do
            new_point=$(( new_point - 1 ))
        done
        READLINE_LINE="${before:0:$new_point}${after}"
        READLINE_POINT=$new_point
    fi
    _ghost_render_ghost
}

_ghost_setup_ghost_binds() {
    stty -echo </dev/tty >/dev/null 2>/dev/null
    for i in {32..126}; do
        oct=$(printf '\\%03o' "$i")
        bind -r "$oct" 2>/dev/null
    done
    bind -r '\e[1;2C' '\e[1;2D' '\e[C' '\ea' '\e,' '\ed' '\e.' '\ew' 2>/dev/null
    bind -r '\C-?' '\C-h' '\C-u' '\C-a' '\C-e' '\C-l' 2>/dev/null

    for i in {32..126}; do
        oct=$(printf '\\%03o' "$i")
        if [[ $i -eq 92 ]]; then
            bind -x "\"$oct\": _ghost_char='\\\\'; _ghost_self_insert"
        elif [[ $i -eq 39 ]]; then
            bind -x "\"$oct\": _ghost_char=\"'\"; _ghost_self_insert"
        else
            safe=$(printf '%q' "$(printf "\\$(printf '%03o' "$i")")")
            bind -x "\"$oct\": _ghost_char=$safe; _ghost_self_insert"
        fi
    done

    bind -x '"\e[D":    _ghost_left_ghost'
    bind -x '"\e[C":    _ghost_accept_all'
    bind -x '"\e[1;2C": _ghost_accept_word'
    bind -x '"\e[1;2D": _ghost_backward_kill_word_ghost'
    bind -x '"\ew":     _ghost_accept_word'
    bind -x '"\ef":     _ghost_accept_word2'
    bind -x '"\C-?":    _ghost_backspace_ghost'
    bind -x '"\C-h":    _ghost_backward_kill_word_ghost'
    bind '"\ea": backward-char'
    bind '"\e,": backward-char'
    bind '"\ed": forward-char'
    bind '"\e.": forward-char'
    bind -x '"\C-u": READLINE_LINE=""; READLINE_POINT=0; _ghost_suggestion=""; _ghost_render_ghost'
    bind -x '"\C-a": READLINE_POINT=0; _ghost_render_ghost'
    bind -x '"\C-e": READLINE_POINT=${#READLINE_LINE}; _ghost_render_ghost'
    bind -x '"\C-l": clear; _ghost_render_ghost'
}

_ghost_setup_clean_binds() {
    for i in {32..126}; do
        oct=$(printf '\\%03o' "$i")
        bind -r "$oct" 2>/dev/null
    done
    bind -r '\e[C' '\e[D' '\ea' '\ed' '\ew' '\C-?' '\C-h' '\C-u' '\C-a' '\C-e' '\C-l' 2>/dev/null

    for i in {32..126}; do
        if [[ $i -eq 92 ]]; then
            bind '"\\\\": self-insert'
        elif [[ $i -eq 34 ]]; then
            bind '"\\\"": self-insert'
        elif [[ $i -eq 39 ]]; then
            bind "\"\\'\": self-insert"
        else
            char=$(printf "\\$(printf '%03o' "$i")")
            bind "\"$char\": self-insert"
        fi
    done

    bind '"\e[D": backward-char'
    bind '"\e[C": forward-char'
    bind '"\ea": backward-char'
    bind '"\ed": forward-char'
    bind '"\C-?": backward-delete-char'
    bind '"\C-h": backward-kill-word'
    bind '"\C-u": unix-line-discard'
    bind '"\C-a": beginning-of-line'
    bind '"\C-e": end-of-line'
    bind '"\C-l": clear-screen'
}

_ghost_toggle() {
    _ghost_update_prompt_len
    if [[ "$_ghost_mode" == "clean" ]]; then
        _ghost_mode="ghost"
        _ghost_save_state
        _ghost_setup_ghost_binds
        printf '\e[?2026h' >/dev/tty
        _ghost_render_ghost
    else
        _ghost_mode="clean"
        stty sane </dev/tty >/dev/null 2>/dev/null
        _ghost_save_state
        _ghost_suggestion=""
        printf '\e[?2026l' >/dev/tty
        _ghost_setup_clean_binds
    fi
}

_ghost_pre_accept_line() {
    printf '\e[K' >/dev/tty
    _ghost_suggestion=""
    if [[ "$_ghost_mode" == "ghost" ]]; then
        printf '\e[?2026l' >/dev/tty
    fi
}

# Inicialização
_ghost_load_state
_ghost_init_history
_ghost_load_path_cache
_ghost_update_prompt_len

bind 'set show-mode-in-prompt off'

if [[ "$_ghost_mode" == "ghost" ]]; then
    _ghost_setup_ghost_binds
else
    _ghost_setup_clean_binds
fi

bind -r '\C-g'
bind -x '"\C-g": _ghost_toggle'

bind -x '"\C-x\C-m": _ghost_pre_accept_line'
bind '"\C-m": "\C-x\C-m\C-j"'

PROMPT_COMMAND="${PROMPT_COMMAND:+$PROMPT_COMMAND; }_ghost_refresh"