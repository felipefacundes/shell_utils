#!/usr/bin/env bash
# License: GPLv3
# Credits: Felipe Facundes
# ------------------------------------------------------------------------------
# md2pdf — Convert Markdown to PDF with ABNT formatting via XeLaTeX
#
# Usage:
#   md2pdf file.md
#   md2pdf file.md output.pdf
#   md2pdf *.md               (batch convert multiple files)
#
# Dependencies: pandoc, xelatex (texlive-core), Liberation Serif font
# Optional:     libreoffice (used as primary converter when available)
# Termux:       pandoc, groff (pdfroff used as pdf-engine; libreoffice not checked)
# ------------------------------------------------------------------------------

# --- Terminal colors ---------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# --- Detect environment (Termux vs desktop) ----------------------------------
if [[ -n "$TERMUX_VERSION" ]]; then
    IS_TERMUX=true
else
    IS_TERMUX=false
fi

# --- Check dependencies ------------------------------------------------------
if [[ "$IS_TERMUX" == true ]]; then
    for dep in pandoc groff; do
        if ! command -v "$dep" &>/dev/null; then
            echo -e "${RED}Error: '$dep' not found.${NC}"
            echo "Install with: apt install pandoc groff"
            exit 1
        fi
    done
    USE_LIBREOFFICE=false
else
    for dep in pandoc xelatex; do
        if ! command -v "$dep" &>/dev/null; then
            echo -e "${RED}Error: '$dep' not found.${NC}"
            echo "Install with: sudo pacman -S pandoc texlive-core texlive-latexextra texlive-fontsextra texlive-fontsrecommended"
            exit 1
        fi
    done
    # --- Detect LibreOffice --------------------------------------------------
    if command -v libreoffice >/dev/null 2>&1; then
        USE_LIBREOFFICE=true
    else
        USE_LIBREOFFICE=false
    fi
fi

# --- Usage -------------------------------------------------------------------
if [[ $# -eq 0 ]]; then
    echo "Usage: md2pdf <file.md> [output.pdf]"
    echo "       md2pdf *.md"
    exit 1
fi

# --- Temporary LaTeX header file ---------------------------------------------
# Created once and reused for all conversions in the session.
HEADER_TEX=$(mktemp /tmp/md2pdf-XXXXXX.tex)
trap "rm -f '$HEADER_TEX'" EXIT

cat > "$HEADER_TEX" << 'LATEX'
% --- ABNT formatting packages ------------------------------------------------
\usepackage{xcolor}
% 1.5 line spacing
\usepackage{setspace}
\onehalfspacing
% Justified text
\usepackage{ragged2e}
\justifying
% Blue headings
\usepackage{titlesec}
\titleformat{\section}
  {\normalfont\Large\bfseries\color{blue}}{\thesection}{1em}{}
\titleformat{\subsection}
  {\normalfont\large\bfseries\color{blue}}{\thesubsection}{1em}{}
\titleformat{\subsubsection}
  {\normalfont\normalsize\bfseries\color{blue}}{\thesubsubsection}{1em}{}
% Page break after document title block
% Ensures the title stays alone on the first page
\usepackage{etoolbox}
\makeatletter
\preto\@maketitle{\clearpage}
\appto\@maketitle{\clearpage}
\makeatother
LATEX

# --- Helper: create a minimal ODT reference document on the fly --------------
create_odt_reference() {
    # Produce an ODT reference file that carries the Liberation Serif font.
    # We create it via pandoc from an empty markdown so the structure is valid.
    local ref_odt
    ref_odt=$(mktemp /tmp/md2pdf-ref-XXXXXX.odt)
    pandoc -o "$ref_odt" \
        --metadata title="" \
        -V mainfont="Liberation Serif" \
        -V sansfont="Liberation Sans" \
        -V monofont="Liberation Mono" \
        /dev/null 2>/dev/null || true
    cat "$ref_odt"
    rm -f "$ref_odt"
}

# --- LibreOffice conversion function -----------------------------------------
convert_with_libreoffice() {
    local input="$1"
    local output="$2"
    local log_file="/tmp/md2pdf-$(basename "${input%.md}").log"
    echo -e "${YELLOW}Converting (LibreOffice):${NC} $input → $output"
    echo "[md2pdf] $(date '+%Y-%m-%d %H:%M:%S') — start: $input" > "$log_file"

    # Step 1a: Try Markdown → ODT via pandoc with full font/style options
    local tmp_odt
    tmp_odt=$(mktemp /tmp/md2pdf-XXXXXX.odt)
    trap "rm -f '$tmp_odt'" RETURN

    local pandoc_err
    pandoc_err=$(mktemp /tmp/md2pdf-pandoc-err-XXXXXX.txt)
    trap "rm -f '$pandoc_err'" RETURN

    echo "[md2pdf] Step 1a: pandoc → ODT (with reference-doc)" >> "$log_file"
    if pandoc "$input" -o "$tmp_odt" \
        --toc \
        --number-sections \
        --highlight-style=tango \
        -V mainfont="Liberation Serif" \
        -V sansfont="Liberation Sans" \
        -V monofont="Liberation Mono" \
        -V fontsize=12pt \
        -V "geometry:top=3cm, left=3cm, bottom=2cm, right=2cm" \
        -V colorlinks=true \
        -V linkcolor=blue \
        --reference-doc=<(create_odt_reference) \
        2>"$pandoc_err"; then
        echo "[md2pdf] Step 1a: success" >> "$log_file"
    else
        # Step 1b: Fallback — plain ODT without reference-doc
        echo "[md2pdf] Step 1a: failed — stderr below" >> "$log_file"
        cat "$pandoc_err" >> "$log_file"
        echo -e "${YELLOW}  ⚠ pandoc (with reference-doc) failed, trying plain ODT fallback…${NC}"
        echo -e "${YELLOW}  (see log: $log_file)${NC}"

        echo "[md2pdf] Step 1b: pandoc → ODT (plain fallback)" >> "$log_file"
        if pandoc "$input" -o "$tmp_odt" \
            --toc \
            --number-sections \
            --highlight-style=tango \
            2>"$pandoc_err"; then
            echo "[md2pdf] Step 1b: success" >> "$log_file"
        else
            echo "[md2pdf] Step 1b: failed — stderr below" >> "$log_file"
            cat "$pandoc_err" >> "$log_file"
            echo -e "${RED}✗ Failed to generate ODT for:${NC} $input"
            echo -e "${RED}  pandoc error output:${NC}"
            cat "$pandoc_err" >&2
            echo -e "${YELLOW}  Full log:${NC} $log_file"
            return 1
        fi
    fi

    # Step 2: Convert ODT → PDF via LibreOffice headless
    local lo_outdir
    lo_outdir=$(mktemp -d /tmp/md2pdf-lo-XXXXXX)
    trap "rm -rf '$lo_outdir'" RETURN

    # Isolated user profile — avoids lock conflicts with running LO instances
    local lo_profile
    lo_profile=$(mktemp -d /tmp/md2pdf-lo-profile-XXXXXX)
    trap "rm -rf '$lo_profile'" RETURN

    # Remove any stale lock files that cause "Unspecified Application Error"
    local lo_lock="$HOME/.config/libreoffice/4/.lock"
    [[ -f "$lo_lock" ]] && rm -f "$lo_lock" && \
        echo "[md2pdf] Removed stale LO lock: $lo_lock" >> "$log_file"

    echo "[md2pdf] Step 2: LibreOffice headless → PDF (outdir: $lo_outdir)" >> "$log_file"
    local lo_err
    lo_err=$(mktemp /tmp/md2pdf-lo-err-XXXXXX.txt)
    trap "rm -f '$lo_err'" RETURN

    # NOTE: --infilter is intentionally omitted — it conflicts with headless
    # pdf conversion and is the most common cause of "Unspecified Application Error".
    # A separate UserInstallation profile is used to prevent session lock conflicts.
    if timeout 120 libreoffice \
        --headless \
        -env:UserInstallation="file://$lo_profile" \
        --convert-to pdf \
        --outdir "$lo_outdir" \
        "$tmp_odt" \
        >"$lo_err" 2>&1; then
        cat "$lo_err" >> "$log_file"
        # LibreOffice names the PDF after the ODT basename (without path/extension)
        local odt_basename
        odt_basename=$(basename "${tmp_odt%.odt}")
        local lo_pdf="$lo_outdir/${odt_basename}.pdf"
        if [[ -f "$lo_pdf" ]]; then
            mv "$lo_pdf" "$output"
            echo "[md2pdf] Step 2: success → $output" >> "$log_file"
            echo -e "${GREEN}✓ Done:${NC} $output"
            return 0
        else
            # LibreOffice sometimes drops the tempfile hash — scan for any pdf
            local found_pdf
            found_pdf=$(find "$lo_outdir" -maxdepth 1 -name "*.pdf" | head -1)
            if [[ -n "$found_pdf" ]]; then
                mv "$found_pdf" "$output"
                echo "[md2pdf] Step 2: success (fallback scan) → $output" >> "$log_file"
                echo -e "${GREEN}✓ Done:${NC} $output"
                return 0
            fi
            echo "[md2pdf] Step 2: exited 0 but PDF not found. outdir contents:" >> "$log_file"
            ls -lh "$lo_outdir" >> "$log_file"
            echo -e "${RED}✗ LibreOffice ran but PDF was not created.${NC}"
            echo -e "${YELLOW}  outdir contents:${NC}"
            ls -lh "$lo_outdir" >&2
            echo -e "${YELLOW}  Full log:${NC} $log_file"
            return 1
        fi
    else
        local exit_code=$?
        cat "$lo_err" >> "$log_file"
        if [[ $exit_code -eq 124 ]]; then
            echo "[md2pdf] Step 2: LibreOffice timed out after 120s" >> "$log_file"
            echo -e "${RED}✗ LibreOffice timed out (120s). Try with pandoc instead.${NC}"
        else
            echo "[md2pdf] Step 2: LibreOffice failed (exit $exit_code)" >> "$log_file"
            echo -e "${RED}✗ LibreOffice failed to convert ODT to PDF.${NC}"
            echo -e "${RED}  LibreOffice output:${NC}"
            cat "$lo_err" >&2
        fi
        echo -e "${YELLOW}  Full log:${NC} $log_file"
        return 1
    fi
}

# --- Pandoc/XeLaTeX conversion function --------------------------------------
convert_with_pandoc() {
    local input="$1"
    local output="$2"
    echo -e "${YELLOW}Converting (pandoc):${NC} $input → $output"
    if pandoc "$input" -o "$output" \
        --pdf-engine=xelatex \
        -V mainfont="Liberation Serif" \
        -V sansfont="Liberation Sans" \
        -V monofont="Liberation Mono" \
        -V fontsize=12pt \
        -V "geometry:top=3cm, left=3cm, bottom=2cm, right=2cm" \
        -V colorlinks=true \
        -V linkcolor=blue \
        --toc \
        --number-sections \
        --highlight-style=tango \
        -H "$HEADER_TEX"; then
        echo -e "${GREEN}✓ Done:${NC} $output"
    else
        echo -e "${RED}✗ Failed to convert:${NC} $input"
        return 1
    fi
}

# --- Termux/pdfroff conversion function --------------------------------------
convert_with_pdfroff() {
    local input="$1"
    local output="$2"
    echo -e "${YELLOW}Converting (pdfroff):${NC} $input → $output"
    if pandoc "$input" -o "$output" \
        --pdf-engine=pdfroff \
        --toc \
        --number-sections \
        --highlight-style=tango; then
        echo -e "${GREEN}✓ Done:${NC} $output"
    else
        echo -e "${RED}✗ Failed to convert:${NC} $input"
        return 1
    fi
}

# --- Unified conversion dispatcher -------------------------------------------
convert_file() {
    local input="$1"
    local output="$2"
    if [[ "$IS_TERMUX" == true ]]; then
        convert_with_pdfroff "$input" "$output"
    elif [[ "$USE_LIBREOFFICE" == true ]]; then
        convert_with_libreoffice "$input" "$output"
    else
        convert_with_pandoc "$input" "$output"
    fi
}

# --- Process arguments -------------------------------------------------------
# Case: md2pdf input.md output.pdf  (two args, second ends in .pdf)
if [[ $# -eq 2 && "${2##*.}" == "pdf" ]]; then
    convert_file "$1" "$2"
    exit $?
fi

# Case: one or more .md files
for input in "$@"; do
    if [[ ! -f "$input" ]]; then
        echo -e "${RED}File not found:${NC} $input"
        continue
    fi
    if [[ "${input##*.}" != "md" ]]; then
        echo -e "${YELLOW}Warning: '$input' does not appear to be Markdown, skipping.${NC}"
        continue
    fi
    # Replace .md extension with .pdf
    output="${input%.md}.pdf"
    convert_file "$input" "$output"
done
