#!/usr/bin/env bash
# License: GPLv3
# Credits: Felipe Facundes

_ghost_path_cache_file="$HOME/.cache/ghost_path.cache"
_ghost_state_file="$HOME/.cache/ghost_mode"
_ghost_history_data=""
_ghost_suggestion=""
_ghost_path_cache=()
_ghost_prompt_len=0
_ghost_mode="clean"
_ghost_last_ps1=""
_ghost_regenerate=false
_ghost_lock_first_level=true

_ghost_load_state() {
    if [[ -f "$_ghost_state_file" ]]; then
        _ghost_mode=$(cat "$_ghost_state_file" 2>/dev/null || echo "clean")
    else
        _ghost_mode="clean"
    fi
}

_ghost_save_state() {
    mkdir -p "$(dirname "$_ghost_state_file")" 2>/dev/null
    echo "$_ghost_mode" | tee "$_ghost_state_file" > /dev/null
}

_ghost_init_history() {
    _ghost_history_data=$(
        fc -ln -10000 2>/dev/null | sed 's/^[[:space:]]*//' | tac | awk '!seen[$0]++'
    )
}

_ghost_update_prompt_len() {
    local current_ps1="${PS1@P}"
    
    if [[ "$current_ps1" != "$_ghost_last_ps1" || $_ghost_prompt_len -eq 0 ]]; then
        _ghost_last_ps1="$current_ps1"
        local plain
        plain=$(printf '%s' "$current_ps1" \
            | sed -E $'s/\x1b\\[[0-9;?]*[a-zA-Z]//g; s/\x01|\x02//g')
        local last="${plain##*$'\n'}"
        _ghost_prompt_len=${#last}
    fi
}

_ghost_refresh() {
    history -a
    _ghost_init_history
    _ghost_update_prompt_len
    
    if [[ "$_ghost_mode" == "ghost" ]]; then
        printf '\e[?2026h' >/dev/tty
    fi
}

ghost_path_cache() {
    IFS=':' read -ra paths <<< "$PATH"
    mapfile -t _ghost_path_cache < <(
        find "${paths[@]}" -maxdepth 1 -type f -executable 2>/dev/null | 
        sed 's|.*/||' | 
        sort -u
    )
    
    # Save to cache file
    mkdir -p "$(dirname "$_ghost_path_cache_file")" 2>/dev/null
    [[ -f "$_ghost_path_cache_file" ]] && rm -f "$_ghost_path_cache_file"
    printf '%s\n' "${_ghost_path_cache[@]}" > "$_ghost_path_cache_file"
}

_ghost_load_path_cache() {
    # Check if cache needs to be regenerated
    _ghost_regenerate=false
    
    if [[ ! -f "$_ghost_path_cache_file" ]]; then
        _ghost_regenerate=true
    else
        # Check if older than 24 hours
        local file_time; file_time=$(stat -c %Y "$_ghost_path_cache_file" 2>/dev/null || stat -f %m "$_ghost_path_cache_file" 2>/dev/null)
        local now; now=$(date +%s)
        local age=$(( now - file_time ))
        
        if [[ $age -gt 86400 ]]; then  # 86400 seconds = 24 hours
            _ghost_regenerate=true
        fi
    fi
    
    if $_ghost_regenerate; then
        ghost_path_cache
    else
        # Load from file
        mapfile -t _ghost_path_cache < "$_ghost_path_cache_file"
    fi
}

# Check if the command line has a real space outside quotes (argument position)
_ghost_is_argument_position() {
    local line="$1"
    local in_single_quote=false
    local in_double_quote=false
    local escaped=false
    local found_real_space=false
    
    for (( i=0; i<${#line}; i++ )); do
        local char="${line:$i:1}"
        
        if $escaped; then
            escaped=false
            continue
        fi
        
        if [[ "$char" == '\' ]]; then
            escaped=true
            continue
        fi
        
        if [[ "$char" == '"' && $in_single_quote == false ]]; then
            if $in_double_quote; then
                in_double_quote=false
            else
                in_double_quote=true
            fi
            continue
        fi
        
        if [[ "$char" == "'" && $in_double_quote == false ]]; then
            if $in_single_quote; then
                in_single_quote=false
            else
                in_single_quote=true
            fi
            continue
        fi
        
        # Only count space if NOT inside quotes
        if [[ "$char" == ' ' ]]; then
            if [[ $in_single_quote == false && $in_double_quote == false ]]; then
                found_real_space=true
            fi
        fi
    done
    
    # Return true only if found a real space AND not currently inside quotes
    if [[ $found_real_space == true && $in_single_quote == false && $in_double_quote == false ]]; then
        return 0
    else
        return 1
    fi
}

# Extract the last argument after the last real space (respecting quotes and escapes)
_ghost_get_last_arg() {
    local line="$1"
    local in_single_quote=false
    local in_double_quote=false
    local escaped=false
    local last_space=-1
    
    for (( i=0; i<${#line}; i++ )); do
        local char="${line:$i:1}"
        
        if $escaped; then
            escaped=false
            continue
        fi
        
        if [[ "$char" == '\' ]]; then
            escaped=true
            continue
        fi
        
        if [[ "$char" == '"' && $in_single_quote == false ]]; then
            if $in_double_quote; then
                in_double_quote=false
            else
                in_double_quote=true
            fi
            continue
        fi
        
        if [[ "$char" == "'" && $in_double_quote == false ]]; then
            if $in_single_quote; then
                in_single_quote=false
            else
                in_single_quote=true
            fi
            continue
        fi
        
        # Track the last real space position
        if [[ "$char" == ' ' ]]; then
            if [[ $in_single_quote == false && $in_double_quote == false ]]; then
                last_space=$i
            fi
        fi
    done
    
    if [[ $last_space -ge 0 ]]; then
        echo "${line:$((last_space + 1))}"
    else
        echo "$line"
    fi
}

# Extract the content inside quotes from a line
_ghost_extract_quoted_content() {
    local line="$1"
    local result=""
    local in_quote=false
    local quote_char=""
    local content=""
    
    for (( i=0; i<${#line}; i++ )); do
        local char="${line:$i:1}"
        
        if ! $in_quote; then
            if [[ "$char" == '"' || "$char" == "'" ]]; then
                in_quote=true
                quote_char="$char"
                content=""
            fi
        else
            if [[ "$char" == "$quote_char" ]]; then
                in_quote=false
                quote_char=""
                result="$content"
            else
                content+="$char"
            fi
        fi
    done
    
    # If still in quote, return the partial content
    if $in_quote; then
        echo "$content"
    else
        echo "$result"
    fi
}

# Second level suggestion for argument positions (after space)
# Only predicts local files/directories/symlinks, built-ins and variables
_ghost_get_suggestion_second_level_inline() {
    local arg_prefix="$1"
    _ghost_suggestion=""
    
    # Show first available file when prefix is empty
    if [[ -z "$arg_prefix" ]]; then
        local generic; generic=$(find . -maxdepth 1 ! -name '.*' 2>/dev/null | head -1 | sed 's|^\./||')
        if [[ -n "$generic" ]]; then
            _ghost_suggestion="$generic"
            return
        fi
        return
    fi
    
    # Handle quoted arguments - remove opening quote for matching
    local search_prefix="$arg_prefix"
    local quote_char=""
    
    if [[ "$arg_prefix" == '"'* ]]; then
        quote_char='"'
        search_prefix="${arg_prefix#\"}"
    elif [[ "$arg_prefix" == "'"* ]]; then
        quote_char="'"
        search_prefix="${arg_prefix#\'}"
    fi
    
    # 1. Local files, directories and symlinks
    local generic; generic=$(find . -maxdepth 1 -name "${search_prefix}*" 2>/dev/null | head -1 | sed 's|^\./||')
    if [[ -n "$generic" ]]; then
        if [[ -n "$quote_char" ]]; then
            _ghost_suggestion="${generic#$search_prefix}"
        else
            _ghost_suggestion="${generic#$arg_prefix}"
        fi
        return
    fi

    # 2. Bash builtins
    while IFS= read -r builtin_cmd; do
        if [[ "$builtin_cmd" == "$search_prefix"* && "$builtin_cmd" != "$search_prefix" ]]; then
            if [[ -n "$quote_char" ]]; then
                _ghost_suggestion="${builtin_cmd#$search_prefix}"
            else
                _ghost_suggestion="${builtin_cmd#$arg_prefix}"
            fi
            return
        fi
    done < <(compgen -b | sort)

    # 3. Environment variables
    if [[ "$search_prefix" == '$'* ]]; then
        local var_prefix="${search_prefix#$}"
        while IFS= read -r var_name; do
            if [[ "$var_name" == "$var_prefix"* && "$var_name" != "$var_prefix" ]]; then
                _ghost_suggestion="${var_name#$var_prefix}"
                return
            fi
        done < <(compgen -v | sort)
    fi
}

_ghost_get_suggestion() {
    _ghost_suggestion=""
    [[ -z "$READLINE_LINE" ]] && return
    
    local prefix="$READLINE_LINE"
    
    # Only check argument position if first level is unlocked (space was pressed)
    if ! $_ghost_lock_first_level && _ghost_is_argument_position "$prefix"; then
        local last_arg
        last_arg=$(_ghost_get_last_arg "$prefix")
        
        if [[ "$prefix" == *' ' && $READLINE_POINT -eq ${#READLINE_LINE} ]]; then
            _ghost_get_suggestion_second_level_inline ""
            return
        elif [[ -n "$last_arg" && "$last_arg" != "$prefix" ]]; then
            _ghost_get_suggestion_second_level_inline "$last_arg"
            return
        fi
    fi
    
    # First level prediction
    local search_prefix="$prefix"
    
    # Extract quoted content for better matching
    if [[ "$prefix" == *'"'* || "$prefix" == *"'"* ]]; then
        local extracted
        extracted=$(_ghost_extract_quoted_content "$prefix")
        if [[ -n "$extracted" ]]; then
            search_prefix="$extracted"
        fi
    fi
    
    # 1. History
    while IFS= read -r line; do
        if [[ "$line" == "$search_prefix"* && "$line" != "$search_prefix" ]]; then
            _ghost_suggestion="${line#$search_prefix}"
            return
        fi
    done <<< "$_ghost_history_data"
    
    # 2. PATH commands
    for cmd in "${_ghost_path_cache[@]}"; do
        if [[ "$cmd" == "$search_prefix"* && "$cmd" != "$search_prefix" ]]; then
            _ghost_suggestion="${cmd#$search_prefix}"
            return
        fi
    done

    # 3. Bash functions
    while IFS= read -r func_name; do
        if [[ "$func_name" == "$search_prefix"* && "$func_name" != "$search_prefix" ]]; then
            _ghost_suggestion="${func_name#$search_prefix}"
            return
        fi
    done < <(declare -F | cut -d' ' -f3 | sort)

    # 4. Builtins + aliases
    while IFS= read -r cmd; do
        if [[ "$cmd" == "$search_prefix"* && "$cmd" != "$search_prefix" ]]; then
            _ghost_suggestion="${cmd#$search_prefix}"
            return
        fi
    done < <({ compgen -b; alias -p | cut -d' ' -f2 | cut -d'=' -f1; } | sort)
    
    # 5. Environment variables
    if [[ "$search_prefix" == '$'* ]]; then
        local var_prefix="${search_prefix#$}"
        while IFS= read -r var_name; do
            if [[ "$var_name" == "$var_prefix"* && "$var_name" != "$var_prefix" ]]; then
                _ghost_suggestion="${var_name#$var_prefix}"
                return
            fi
        done < <(compgen -v | sort)
    fi

    # 6. Generic Search (local files)
    local generic; generic=$(find . -maxdepth 1 -name "${search_prefix}*" 2>/dev/null | head -1 | sed 's|^\./||')
    if [[ -n "$generic" ]]; then
        _ghost_suggestion="${generic#$search_prefix}"
        return
    fi
}

_ghost_render_ghost() {
    _ghost_update_prompt_len
    
    [[ $READLINE_POINT -eq ${#READLINE_LINE} ]] \
        && _ghost_get_suggestion \
        || _ghost_suggestion=""
    local col=$(( _ghost_prompt_len + ${#READLINE_LINE} + 1 ))
    if [[ -n "$_ghost_suggestion" ]]; then
        printf '\e[s\e[%dG\e[38;5;244m%s\e[0m\e[K\e[u\e[?2026l\e[?2026h' \
            "$col" "$_ghost_suggestion" >/dev/tty
    else
        printf '\e[s\e[%dG\e[K\e[u\e[?2026l\e[?2026h' "$col" >/dev/tty
    fi
}

_ghost_self_insert() {
    READLINE_LINE="${READLINE_LINE:0:$READLINE_POINT}${_ghost_char}${READLINE_LINE:$READLINE_POINT}"
    READLINE_POINT=$(( READLINE_POINT + 1 ))
    _ghost_render_ghost
}

# Space key - unlocks first level, allowing second level predictions
_ghost_space_insert() {
    _ghost_lock_first_level=false
    READLINE_LINE="${READLINE_LINE:0:$READLINE_POINT} ${READLINE_LINE:$READLINE_POINT}"
    READLINE_POINT=$(( READLINE_POINT + 1 ))
    _ghost_suggestion=""
    _ghost_render_ghost
}

# Right arrow: accepts entire ghost suggestion
_ghost_accept_all() {
    if [[ $READLINE_POINT -lt ${#READLINE_LINE} ]]; then
        READLINE_POINT=$(( READLINE_POINT + 1 ))
    elif [[ -n "$_ghost_suggestion" ]]; then
        READLINE_LINE+="$_ghost_suggestion"
        READLINE_POINT=${#READLINE_LINE}
        _ghost_suggestion=""
        _ghost_lock_first_level=true
    fi
    _ghost_render_ghost
}

# Checks if character is a delimiter
_ghost_is_delimiter() {
    [[ "$1" =~ [\ =/\;.,|\\:_-] ]]
}

# Alt+X: completes one phrase of the ghost suggestion
_ghost_accept_word2() {
    if [[ $READLINE_POINT -lt ${#READLINE_LINE} ]]; then
        local after="${READLINE_LINE:$READLINE_POINT}"
        while [[ "${after:0:1}" == " " ]]; do
            READLINE_POINT=$(( READLINE_POINT + 1 ))
            after="${READLINE_LINE:$READLINE_POINT}"
        done
        while [[ -n "$after" && "${after:0:1}" != " " ]]; do
            READLINE_POINT=$(( READLINE_POINT + 1 ))
            after="${READLINE_LINE:$READLINE_POINT}"
        done
    elif [[ -n "$_ghost_suggestion" ]]; then
        local word="${_ghost_suggestion%% *}"
        [[ "$_ghost_suggestion" == *' '* ]] && word+=' '
        READLINE_LINE+="$word"
        READLINE_POINT=${#READLINE_LINE}
        _ghost_suggestion="${_ghost_suggestion#"$word"}"
        _ghost_lock_first_level=true
    fi
    _ghost_render_ghost
}

# Alt+W: completes one word of the ghost suggestion (with delimiters)
_ghost_accept_word() {
    if [[ $READLINE_POINT -lt ${#READLINE_LINE} ]]; then
        local after="${READLINE_LINE:$READLINE_POINT}"
        while [[ -n "$after" ]] && _ghost_is_delimiter "${after:0:1}"; do
            READLINE_POINT=$(( READLINE_POINT + 1 ))
            after="${READLINE_LINE:$READLINE_POINT}"
        done
        while [[ -n "$after" ]] && ! _ghost_is_delimiter "${after:0:1}"; do
            READLINE_POINT=$(( READLINE_POINT + 1 ))
            after="${READLINE_LINE:$READLINE_POINT}"
        done
    elif [[ -n "$_ghost_suggestion" ]]; then
        local remaining="$_ghost_suggestion"
        local word=""
        
        while [[ -n "$remaining" ]]; do
            local char="${remaining:0:1}"
            if _ghost_is_delimiter "$char"; then
                if [[ -n "$word" ]]; then
                    break
                fi
                word+="$char"
                remaining="${remaining:1}"
                if [[ "$char" == " " ]]; then
                    while [[ "${remaining:0:1}" == " " ]]; do
                        word+=" "
                        remaining="${remaining:1}"
                    done
                fi
                break
            else
                word+="$char"
                remaining="${remaining:1}"
            fi
        done
        
        [[ -z "$word" ]] && word="$remaining"
        
        READLINE_LINE+="$word"
        READLINE_POINT=${#READLINE_LINE}
        _ghost_suggestion="${_ghost_suggestion#"$word"}"
        _ghost_lock_first_level=true
    fi
    _ghost_render_ghost
}

_ghost_backspace_ghost() {
    if [[ $READLINE_POINT -gt 0 ]]; then
        READLINE_LINE="${READLINE_LINE:0:$((READLINE_POINT - 1))}${READLINE_LINE:$READLINE_POINT}"
        READLINE_POINT=$(( READLINE_POINT - 1 ))
    fi
    _ghost_render_ghost
}

# Ctrl+Delete: forward kill word
_ghost_kill_word_ghost() {
    if [[ $READLINE_POINT -lt ${#READLINE_LINE} ]]; then
        local before="${READLINE_LINE:0:$READLINE_POINT}"
        local after="${READLINE_LINE:$READLINE_POINT}"
        local new_point=$READLINE_POINT
        
        # Skip initial spaces/delimiters
        while [[ $new_point -lt ${#READLINE_LINE} ]] && _ghost_is_delimiter "${after:0:1}"; do
            new_point=$((new_point + 1))
            after="${READLINE_LINE:$new_point}"
        done
        
        # Skip word characters
        while [[ $new_point -lt ${#READLINE_LINE} ]] && ! _ghost_is_delimiter "${after:0:1}"; do
            new_point=$((new_point + 1))
            after="${READLINE_LINE:$new_point}"
        done
        
        READLINE_LINE="${before}${after}"
    fi
    _ghost_render_ghost
}

# Ctrl+Backspace: deletes previous word (with multiple delimiters)
_ghost_backward_kill_word_ghost() {
    if [[ $READLINE_POINT -gt 0 ]]; then
        local before="${READLINE_LINE:0:$READLINE_POINT}"
        local after="${READLINE_LINE:$READLINE_POINT}"
        local new_point=$READLINE_POINT
        
        while [[ $new_point -gt 0 ]] && _ghost_is_delimiter "${before:$((new_point - 1)):1}"; do
            new_point=$((new_point - 1))
        done
        
        while [[ $new_point -gt 0 ]] && ! _ghost_is_delimiter "${before:$((new_point - 1)):1}"; do
            new_point=$((new_point - 1))
        done
        
        READLINE_LINE="${before:0:$new_point}${after}"
        READLINE_POINT=$new_point
    fi
    _ghost_render_ghost
}

# Setup binds for ghost mode
_ghost_setup_ghost_binds() {
    # Clear previous binds
    for i in {32..126}; do
        oct=$(printf '\\%03o' "$i")
        bind -r "$oct" 2>/dev/null
    done
    bind -r '\e[3;5~' 2>/dev/null
    bind -r '\e[1;2C' 2>/dev/null
    bind -r '\e[1;2D' 2>/dev/null
    bind -r '\e[C' 2>/dev/null
    bind -r '\ea' 2>/dev/null
    bind -r '\e,' 2>/dev/null
    bind -r '\ed' 2>/dev/null
    bind -r '\e.' 2>/dev/null
    bind -r '\ew' 2>/dev/null
    bind -r '\C-?' 2>/dev/null
    bind -r '\C-h' 2>/dev/null
    bind -r '\C-u' 2>/dev/null
    bind -r '\C-a' 2>/dev/null
    bind -r '\C-e' 2>/dev/null
    bind -r '\C-l' 2>/dev/null
    
    # Printable characters with bind -x (EXCEPT space - 32)
    for i in {33..126}; do
        oct=$(printf '\\%03o' "$i")
        if [[ $i -eq 92 ]]; then
            bind -x "\"$oct\": _ghost_char='\\\\'; _ghost_self_insert"
        elif [[ $i -eq 39 ]]; then
            bind -x "\"$oct\": _ghost_char=\"'\"; _ghost_self_insert"
        else
            safe=$(printf '%q' "$(printf "\\$(printf '%03o' "$i")")")
            bind -x "\"$oct\": _ghost_char=$safe; _ghost_self_insert"
        fi
    done
    
    # Space key - unlocks second level
    bind -x '" ": _ghost_space_insert'
    
    # Alt+Space - also unlocks second level
    bind -x '"\e ": _ghost_space_insert'
    
    # Ghost mode control keys
    bind -x '"\e[3;5~": _ghost_kill_word_ghost'           # Ctrl+Delete: forward kill word
    bind -x '"\e[C": _ghost_accept_all'                   # Right arrow: accepts entire ghost
    bind -x '"\e[1;2C": _ghost_accept_word'               # Shift+Right: completes 1 word
    bind -x '"\e[1;2D": _ghost_backward_kill_word_ghost'  # Shift+Left: deletes 1 word
    bind -x '"\ew": _ghost_accept_word'                   # Alt+W: completes 1 word
    bind -x '"\ex": _ghost_accept_word2'                  # Alt+X: completes 1 phrase
    bind -x '"\C-?": _ghost_backspace_ghost'              # Backspace
    bind -x '"\C-h": _ghost_backward_kill_word_ghost'     # Ctrl+Backspace: deletes 1 word
    
    # Alt+A and Alt+D: native navigation
    bind '"\ea": backward-char'
    bind '"\e,": backward-char'
    bind '"\ed": forward-char'
    bind '"\e.": forward-char'
    
    bind -x '"\C-u": READLINE_LINE=""; READLINE_POINT=0; _ghost_suggestion=""; _ghost_render_ghost'
    bind -x '"\C-a": READLINE_POINT=0; _ghost_render_ghost'
    bind -x '"\C-e": READLINE_POINT=${#READLINE_LINE}; _ghost_render_ghost'
    bind -x '"\C-l": clear; _ghost_render_ghost'
}

# Setup binds for clean mode
_ghost_setup_clean_binds() {
    for i in {32..126}; do
        oct=$(printf '\\%03o' "$i")
        bind -r "$oct" 2>/dev/null
    done
    bind -r '\e[3;5~' 2>/dev/null
    bind -r '\e[C' 2>/dev/null
    bind -r '\e[D' 2>/dev/null
    bind -r '\ea' 2>/dev/null
    bind -r '\ed' 2>/dev/null
    bind -r '\ew' 2>/dev/null
    bind -r '\C-?' 2>/dev/null
    bind -r '\C-h' 2>/dev/null
    bind -r '\C-u' 2>/dev/null
    bind -r '\C-a' 2>/dev/null
    bind -r '\C-e' 2>/dev/null
    bind -r '\C-l' 2>/dev/null
    
    for i in {33..126}; do
        if [[ $i -eq 92 ]]; then
            bind '"\\\\": self-insert'
        elif [[ $i -eq 34 ]]; then
            bind '"\\\"": self-insert'
        elif [[ $i -eq 39 ]]; then
            bind "\"\\'\": self-insert"
        else
            char=$(printf "\\$(printf '%03o' "$i")")
            bind "\"$char\": self-insert"
        fi
    done
    
    bind '" ": self-insert'
    bind '"\e ": self-insert'
    bind '"\e[D": backward-char'
    bind '"\e[C": forward-char'
    bind '"\ea": backward-char'
    bind '"\ed": forward-char'
    bind '"\C-?": backward-delete-char'
    bind '"\C-h": backward-kill-word'
    bind '"\e[3;5~": kill-word'
    bind '"\C-u": unix-line-discard'
    bind '"\C-a": beginning-of-line'
    bind '"\C-e": end-of-line'
    bind '"\C-l": clear-screen'
}

# Toggle ghost mode with Ctrl+G
_ghost_toggle() {
    _ghost_update_prompt_len
    
    if [[ "$_ghost_mode" == "clean" ]]; then
        _ghost_mode="ghost"
        _ghost_save_state
        _ghost_setup_ghost_binds
        printf '\e[?2026h' >/dev/tty
        _ghost_render_ghost
    else
        _ghost_mode="clean"
        _ghost_save_state
        _ghost_suggestion=""
        printf '\e[?2026l' >/dev/tty
        _ghost_setup_clean_binds
    fi
}

_ghost_pre_accept_line() {
    printf '\e[K' >/dev/tty
    _ghost_suggestion=""
    if [[ "$_ghost_mode" == "ghost" ]]; then
        printf '\e[?2026l' >/dev/tty
    fi
}

# Initialization
_ghost_load_state
_ghost_init_history
_ghost_load_path_cache
_ghost_update_prompt_len

bind 'set show-mode-in-prompt off'

if [[ "$_ghost_mode" == "ghost" ]]; then
    _ghost_setup_ghost_binds
else
    _ghost_setup_clean_binds
fi

bind -r '\C-g'
bind -x '"\C-g": _ghost_toggle'

bind -x '"\C-x\C-m": _ghost_pre_accept_line'
bind '"\C-m": "\C-x\C-m\C-j"'

PROMPT_COMMAND="${PROMPT_COMMAND:+$PROMPT_COMMAND; }_ghost_refresh"