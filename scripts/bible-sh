# ─── Constants & Paths ────────────────────────────────────────────────────────
NC="\033[0m"
RED="\033[1;31m"
SCRIPT="${0##*/}"
CACHEDIR="${HOME}/.cache"
CACHE_BIBLES="${CACHEDIR}/${SCRIPT%.*}"
BIBLES_DIR="${CACHE_BIBLES}/bibles/sql"
HISTORY_FILE="${CACHE_BIBLES}/BIBLES_HISTORY_FILE.db"
LAST_CHAPTER_FILE="${CACHE_BIBLES}/BIBLES_LAST_CHAPTER_FILE.db"
RANDOM_CHAPTER_FILE="${CACHE_BIBLES}/BIBLES_RANDOM_CHAPTER_FILE.db"
DEFAULT_BIBLE_FILE="${CACHE_BIBLES}/BIBLES_DEFAULT.conf"

[[ ! -d "${BIBLES_DIR}" ]] && mkdir -p "${BIBLES_DIR}"

# ─── Dependency Checks ────────────────────────────────────────────────────────
if ! command -v dialog &>/dev/null; then
    echo "${MESSAGES[dialog_not_installed]}"
    exit 1
fi

if ! command -v sqlite3 &>/dev/null; then
    echo "${MESSAGES[sqlite_not_installed]}"
    exit 1
fi

if ! command -v git &>/dev/null; then
    echo "${MESSAGES[git_not_installed]}"
    exit 1
fi

# ─── Bible name helper ────────────────────────────────────────────────────────
# Returns the display name from a sqlite filepath, e.g. /path/to/kja.sqlite -> KJA
bible_display_name() {
    local filepath="$1"
    local base
    base=$(basename "$filepath")
    base="${base%.*}"          # remove extension
    echo "${base^^}"           # uppercase
}

# ─── Bible Download ───────────────────────────────────────────────────────────
download_bibles() {
    local tmp_dir
    tmp_dir=$(mktemp -d "${CACHEDIR}/bibles_clone_XXXXXX")

    clear
    echo "${MESSAGES[downloading_bibles]}"

    if git clone --depth=1 "https://github.com/felipefacundes/biblias" "$tmp_dir" 2>/dev/null; then
        # Find and copy all .sqlite files recursively (case-insensitive)
        find "$tmp_dir" -iname "*.sqlite" | while read -r f; do
            cp "$f" "${BIBLES_DIR}/"
        done
        rm -rf "$tmp_dir"
        return 0
    else
        rm -rf "$tmp_dir"
        echo "${MESSAGES[download_failed]}"
        return 1
    fi
}

# ─── Bible Selection ──────────────────────────────────────────────────────────
# Populates DB_FILE global. Returns 1 if no bibles found after download attempt.
select_bible() {
    local -a sqlite_files
    local -a menu_opts

    # Find all .sqlite files (case-insensitive)
    while IFS= read -r f; do
        sqlite_files+=("$f")
    done < <(find "${BIBLES_DIR}" -maxdepth 1 -iname "*.sqlite" 2>/dev/null | sort)

    # If none found, try to download
    if [[ ${#sqlite_files[@]} -eq 0 ]]; then
        download_bibles || {
            dialog --title "${MESSAGES[error]}" \
                   --msgbox "${MESSAGES[no_bible_found]}\n${MESSAGES[no_bible_found_detail]} ${BIBLES_DIR}" \
                   10 60 >/dev/tty 2>&1
            return 1
        }
        # Re-scan after download
        while IFS= read -r f; do
            sqlite_files+=("$f")
        done < <(find "${BIBLES_DIR}" -maxdepth 1 -iname "*.sqlite" 2>/dev/null | sort)
    fi

    if [[ ${#sqlite_files[@]} -eq 0 ]]; then
        dialog --title "${MESSAGES[error]}" \
               --msgbox "${MESSAGES[no_bible_found]}\n${MESSAGES[no_bible_found_detail]} ${BIBLES_DIR}" \
               10 60 >/dev/tty 2>&1
        return 1
    fi

    # Read current default
    local current_default=""
    [[ -f "$DEFAULT_BIBLE_FILE" ]] && current_default=$(cat "$DEFAULT_BIBLE_FILE")

    # If there is a stored default and the file exists, use it directly (skip menu)
    if [[ -n "$current_default" && -f "$current_default" ]]; then
        DB_FILE="$current_default"
        BIBLE_NAME=$(bible_display_name "$DB_FILE")
        return 0
    fi

    # Build menu: tag = filepath, item = display name [+ default marker]
    for f in "${sqlite_files[@]}"; do
        local dname
        dname=$(bible_display_name "$f")
        local marker=""
        [[ "$f" == "$current_default" ]] && marker=" ${MESSAGES[current_default]}"
        menu_opts+=("$f" "${dname}${marker}")
    done
    # Extra option to download/refresh
    menu_opts+=("__download__" "↓ Download / Refresh Bibles (git)")

    local hint
    hint="${MESSAGES[add_bibles_hint]} ${BIBLES_DIR}"

    local choice
    choice=$(dialog --title "${MESSAGES[app_name]}" \
                    --menu "${MESSAGES[select_bible]}\n\n${hint}" \
                    25 70 18 "${menu_opts[@]}" \
                    2>&1 >/dev/tty)

    [[ $? -ne 0 ]] && return 1

    if [[ "$choice" == "__download__" ]]; then
        download_bibles
        select_bible   # recurse
        return $?
    fi

    DB_FILE="$choice"
    BIBLE_NAME=$(bible_display_name "$DB_FILE")

    # Ask to set as default
    dialog --title "${MESSAGES[app_name]}" \
           --yesno "${MESSAGES[set_as_default]}: ${BIBLE_NAME}?" \
           7 50 >/dev/tty 2>&1
    [[ $? -eq 0 ]] && echo "$DB_FILE" > "$DEFAULT_BIBLE_FILE"

    return 0
}

# ─── Cleanup / Trap ───────────────────────────────────────────────────────────
cleanup() {
    clear
    stty icanon echo icrnl 2>/dev/null
    stty sane 2>/dev/null
    stty "$original_stty" 2>/dev/null
    printf "\033[?25h"
    printf "\033[2K\033[G"
    printf "\n${MESSAGES[script_interrupted]}\n"
    exit 1
}
trap cleanup INT

